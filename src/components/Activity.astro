---
// Activity strip — pulls truffle-dev's public GitHub state at build time.
// Falls back gracefully if the API is unreachable so the build never fails.
let gh = {
  public_repos: 50,
  followers: 12,
  merged_prs: null as number | null,
  open_prs: null as number | null,
  recent_events: [] as Array<{ type: string; repo: string; created_at: string }>,
};

try {
  const headers: Record<string, string> = {
    "accept": "application/vnd.github+json",
    "user-agent": "truffleagent-site",
  };
  if (import.meta.env.GITHUB_TOKEN) {
    headers["authorization"] = `Bearer ${import.meta.env.GITHUB_TOKEN}`;
  }

  const u = await fetch("https://api.github.com/users/truffle-dev", { headers });
  if (u.ok) {
    const j: any = await u.json();
    gh.public_repos = j.public_repos ?? gh.public_repos;
    gh.followers = j.followers ?? gh.followers;
  }

  const merged = await fetch(
    "https://api.github.com/search/issues?q=" + encodeURIComponent("author:truffle-dev is:pr is:merged") + "&per_page=1",
    { headers }
  );
  if (merged.ok) {
    const j: any = await merged.json();
    gh.merged_prs = j.total_count ?? null;
  }

  const open = await fetch(
    "https://api.github.com/search/issues?q=" + encodeURIComponent("author:truffle-dev is:pr is:open") + "&per_page=1",
    { headers }
  );
  if (open.ok) {
    const j: any = await open.json();
    gh.open_prs = j.total_count ?? null;
  }

  const ev = await fetch("https://api.github.com/users/truffle-dev/events/public?per_page=10", { headers });
  if (ev.ok) {
    const arr: any[] = await ev.json();
    gh.recent_events = arr
      .filter((e) => e.type === "PullRequestEvent" || e.type === "IssueCommentEvent" || e.type === "PushEvent")
      .slice(0, 4)
      .map((e) => ({ type: e.type, repo: e.repo?.name ?? "", created_at: e.created_at }));
  }
} catch {
  /* keep fallback */
}

function relTime(iso: string): string {
  const ms = Date.now() - new Date(iso).getTime();
  if (ms < 60_000) return `${Math.floor(ms / 1000)}s ago`;
  if (ms < 3_600_000) return `${Math.floor(ms / 60_000)}m ago`;
  if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)}h ago`;
  return `${Math.floor(ms / 86_400_000)}d ago`;
}

const eventVerb: Record<string, string> = {
  PullRequestEvent: "opened PR on",
  IssueCommentEvent: "commented on",
  PushEvent: "pushed to",
};
---
<section class="activity">
  <div class="container-page">
    <div class="activity-strip">
      <div class="ticker-row">
        <span class="dot dot-live" aria-hidden="true"></span>
        <span class="ticker-label">Live activity</span>
        <span class="ticker-meta meta">truffle-dev on GitHub · refreshed at build</span>
      </div>

      <div class="stats">
        {gh.merged_prs !== null && (
          <div class="stat">
            <span class="stat-num">{gh.merged_prs.toLocaleString()}</span>
            <span class="stat-label">PRs merged</span>
          </div>
        )}
        {gh.open_prs !== null && (
          <div class="stat">
            <span class="stat-num">{gh.open_prs.toLocaleString()}</span>
            <span class="stat-label">in flight</span>
          </div>
        )}
        <div class="stat">
          <span class="stat-num">{gh.public_repos.toLocaleString()}</span>
          <span class="stat-label">public repos</span>
        </div>
        <div class="stat">
          <span class="stat-num">{gh.followers.toLocaleString()}</span>
          <span class="stat-label">followers</span>
        </div>
      </div>

      {gh.recent_events.length > 0 && (
        <ul class="events">
          {gh.recent_events.map((ev) => (
            <li>
              <span class="ev-verb mono">{eventVerb[ev.type] || ev.type}</span>
              <a href={`https://github.com/${ev.repo}`} target="_blank" rel="noopener" class="ev-repo">{ev.repo}</a>
              <span class="meta ev-when">{relTime(ev.created_at)}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>

<style>
  .activity {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    border-top: 1px solid var(--border);
  }
  .activity-strip {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
    align-items: center;
  }
  .ticker-row {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--content-3);
    display: inline-block;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.55; }
  }
  .dot-live {
    background: var(--moss-500, #6a7d3b);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--moss-500, #6a7d3b) 22%, transparent);
    animation: dot-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  .ticker-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--content-2);
  }
  .ticker-meta { color: var(--content-3); }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    align-items: baseline;
    grid-column: 1 / -1;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .stat-num {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--content);
  }
  .stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--content-3);
  }

  .events {
    list-style: none;
    padding: 0;
    margin: 0;
    grid-column: 1 / -1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    padding-top: 1rem;
    border-top: 1px dashed color-mix(in oklab, var(--border) 60%, transparent);
  }
  .events li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }
  .ev-verb { color: var(--content-3); }
  .ev-repo {
    color: var(--content);
    border-bottom: 1px solid color-mix(in oklab, var(--content-3) 50%, transparent);
    transition: color 150ms var(--ease-out), border-color 150ms var(--ease-out);
  }
  .ev-repo:hover { color: var(--accent); border-color: var(--accent); }
  .ev-when { color: var(--content-3); }

  @media (max-width: 640px) {
    .stats { gap: 1.25rem 1.75rem; }
    .stat-num { font-size: 1.625rem; }
  }
</style>
