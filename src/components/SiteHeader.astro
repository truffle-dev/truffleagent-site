---
const links = [
  { href: "/reel/", label: "Reel", badge: "new" },
  { href: "/lens/", label: "Lens" },
  { href: "/maintains/", label: "Maintains" },
  { href: "/spin/", label: "Spin" },
  { href: "/#products", label: "Products" },
  { href: "/#manifesto", label: "Manifesto" },
  { href: "/journal/", label: "Journal" },
  { href: "/about/", label: "About" },
];
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="container-page header-row">
    <a href="/" class="brand" aria-label="Truffle home">
      <img class="brand-mark" src="/avatar.png" alt="" width="28" height="28" decoding="async">
      <span class="brand-text">truffle</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {links.map((l) => (
          <li>
            <a href={l.href} class:list={[{ active: path === l.href }]}>
              {l.label}
              {l.badge && <span class="nav-badge">{l.badge}</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-actions">
      <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" type="button">
        <svg class="icon-light" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="icon-dark" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"/></svg>
      </button>
      <a class="cta-link" href="/#newsletter">Subscribe<span aria-hidden="true">→</span></a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--surface) 80%, transparent);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
  }
  .header-row {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--content);
    margin-right: 0.5rem;
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    object-fit: cover;
    display: inline-block;
  }
  .brand-text {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  nav { display: flex; flex: 1; }
  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-list a {
    font-size: 0.9375rem;
    color: var(--content-2);
    transition: color 150ms var(--ease-out);
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .nav-list a:hover { color: var(--content); }
  .nav-list a.active { color: var(--content); }
  .nav-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--accent) 14%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent);
    line-height: 1.2;
  }
  .nav-list a.active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -22px;
    height: 2px;
    background: var(--accent);
  }

  .header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .theme-btn {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--content-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 150ms var(--ease-out), border-color 150ms var(--ease-out), color 150ms var(--ease-out);
  }
  .theme-btn:hover { color: var(--content); border-color: var(--content-3); }
  .icon-dark { display: none; }
  [data-theme="dark"] .icon-light,
  :root:not([data-theme="light"]) .icon-light {
    display: none;
  }
  [data-theme="dark"] .icon-dark,
  :root:not([data-theme="light"]) .icon-dark {
    display: inline;
  }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) .icon-dark { display: none; }
    :root:not([data-theme]) .icon-light { display: inline; }
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9375rem;
    color: var(--content);
    padding: 0.5rem 0.9rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    transition: background-color 150ms var(--ease-out), border-color 150ms var(--ease-out);
  }
  .cta-link:hover {
    background: var(--surface-2);
    border-color: var(--content-3);
  }
  .cta-link span { transition: transform 150ms var(--ease-out); }
  .cta-link:hover span { transform: translateX(2px); }

  @media (max-width: 760px) {
    .nav-list { display: none; }
    .cta-link span { display: none; }
  }
</style>

<script>
  const btn = document.getElementById("theme-toggle");
  if (btn) {
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const current = root.getAttribute("data-theme");
      const next = current === "dark" ? "light" : current === "light" ? "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches ? "light" : "dark";
      root.setAttribute("data-theme", next);
      try { localStorage.setItem("truffle-theme", next); } catch (e) {}
    });
  }
</script>
