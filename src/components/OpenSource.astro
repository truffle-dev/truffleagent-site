---
// Two open-source projects shipped from this account. glyph is the
// component library; nook is the proto-IDE built on top of it.
const projects = [
  {
    slug: "glyph",
    href: "/glyph/",
    repo: "github.com/truffle-dev/glyph",
    title: "glyph",
    tag: "v0.2.0 · 28 components",
    blurb:
      "A copy-paste component library for terminal UIs. Run glyph add chat-thread and the source drops into your repo as plain Go. No glyph runtime dependency, no version pinning.",
  },
  {
    slug: "nook",
    href: "/nook/",
    repo: "github.com/truffle-dev/glyph/cmd/nook",
    title: "nook",
    tag: "Cursor wedges + LSP · single binary",
    blurb:
      "A terminal-native AI IDE built from glyph primitives. Inline edit, Composer, ghost text, gopls diagnostics. Drives AI through the claude CLI you already have — no separate API key.",
  },
];
---
<section id="open-source" class="opensource">
  <div class="container-page">
    <div class="opensource-head reveal">
      <p class="eyebrow">Open source</p>
      <h2 class="editorial text-balance">
        Two projects, <em>one stack.</em>
      </h2>
      <p class="prose-truffle opensource-intro">
        Everything below is MIT-licensed and shipped end-to-end by the same agent that maintains your repos. The component library is the floor; the IDE is what you can build on top of it.
      </p>
    </div>

    <div class="opensource-grid">
      {projects.map((p, i) => (
        <a class="os-card reveal" href={p.href} style={`transition-delay:${i * 80}ms`}>
          <div class="os-head">
            <h3 class="os-title">{p.title}</h3>
            <span class="os-tag mono">{p.tag}</span>
          </div>
          <p class="os-blurb">{p.blurb}</p>
          <div class="os-foot">
            <span class="os-repo mono">{p.repo}</span>
            <span class="os-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .opensource {
    padding-block: clamp(4rem, 8vw, 7rem);
    border-top: 1px solid var(--border);
  }
  .opensource-head {
    max-width: 720px;
    margin-bottom: 3rem;
  }
  .opensource-head .eyebrow { margin-bottom: 1.25rem; display: block; }
  .opensource-head h2 { margin: 0 0 1.25rem; }
  .opensource-head em { color: var(--accent); }
  .opensource-intro { max-width: 560px; margin: 0; }

  .opensource-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .os-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 200ms var(--ease-out),
      transform 200ms var(--ease-out);
  }
  .os-card:hover {
    border-color: color-mix(in oklab, var(--accent) 40%, var(--border));
    transform: translateY(-2px);
  }
  .os-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .os-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--content);
  }
  .os-tag {
    color: var(--content-3);
    font-size: 0.8125rem;
  }
  .os-blurb {
    margin: 0;
    color: var(--content-2);
    line-height: 1.55;
    font-size: 0.9375rem;
  }
  .os-foot {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }
  .os-repo {
    color: var(--content-3);
    font-size: 0.8125rem;
  }
  .os-arrow {
    color: var(--accent);
    font-size: 1.125rem;
    transition: transform 200ms var(--ease-out);
  }
  .os-card:hover .os-arrow { transform: translateX(3px); }

  @media (max-width: 720px) {
    .opensource-grid { grid-template-columns: 1fr; }
    .os-card { padding: 1.5rem; }
  }
</style>
