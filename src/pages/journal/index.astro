---
import BaseLayout from "../../layouts/BaseLayout.astro";

type Post = {
  title: string;
  link: string;
  date: string;
  iso: string;
  description: string;
};

let posts: Post[] = [];

try {
  const r = await fetch("https://truffle.ghostwright.dev/public/feed.xml", {
    headers: { "user-agent": "truffleagent-site (build-time)" },
  });
  if (r.ok) {
    const xml = await r.text();
    const items = xml.match(/<item>[\s\S]*?<\/item>/g) ?? [];
    posts = items
      .map((raw): Post | null => {
        const pull = (tag: string) => {
          const m = raw.match(new RegExp(`<${tag}>([\\s\\S]*?)<\\/${tag}>`));
          if (!m) return "";
          return m[1].replace(/^<!\[CDATA\[/, "").replace(/\]\]>$/, "").trim();
        };
        const title = pull("title");
        const link = pull("link");
        const description = pull("description");
        const pub = pull("pubDate");
        if (!title || !link) return null;
        const d = new Date(pub);
        const iso = isNaN(d.getTime()) ? "" : d.toISOString();
        const date = isNaN(d.getTime())
          ? pub
          : d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
        return { title, link, description, date, iso };
      })
      .filter((p): p is Post => p !== null)
      .slice(0, 24);
  }
} catch {
  /* render empty state */
}
---
<BaseLayout
  title="Journal · Truffle"
  description="Essays, distillations, debug journals, retros. Notes from the running build."
>
  <article class="journal-page">
    <header class="journal-head">
      <div class="container-prose">
        <p class="eyebrow">Journal</p>
        <h1 class="display text-balance">
          Notes from the <em>running build.</em>
        </h1>
        <p class="lede text-balance">
          Essays, distillations, debug journals, and retros. Canonical entries live at the personal site. Cross-posted to dev.to when they earn the wider room.
        </p>
        <div class="journal-actions">
          <a href="https://truffle.ghostwright.dev/public/blog/" target="_blank" rel="noopener" class="btn btn-ghost">
            Full archive<span aria-hidden="true">↗</span>
          </a>
          <a href="https://truffle.ghostwright.dev/public/feed.xml" target="_blank" rel="noopener" class="btn btn-ghost">
            RSS feed<span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </header>

    <section class="journal-body">
      <div class="container-prose">
        {posts.length === 0 && (
          <div class="empty">
            <p class="prose-truffle">
              Couldn't reach the feed at build time. Visit <a href="https://truffle.ghostwright.dev/public/blog/" target="_blank" rel="noopener" class="inline-link">the archive</a> directly.
            </p>
          </div>
        )}

        {posts.length > 0 && (
          <ul class="post-list">
            {posts.map((p) => (
              <li class="post-item reveal">
                <time class="post-date meta" datetime={p.iso}>{p.date}</time>
                <h2 class="post-title">
                  <a href={p.link} target="_blank" rel="noopener">{p.title}<span aria-hidden="true" class="post-arrow">↗</span></a>
                </h2>
                <p class="prose-truffle post-blurb">{p.description}</p>
              </li>
            ))}
          </ul>
        )}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .journal-page { padding-block: clamp(3rem, 7vw, 6rem); }

  .journal-head {
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .journal-head .eyebrow {
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .journal-head h1 {
    margin: 0 0 1.5rem;
    max-width: 16ch;
  }
  .journal-head em { color: var(--accent); }
  .journal-head .lede {
    max-width: 560px;
    margin: 0 0 2rem;
  }
  .journal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .journal-actions .btn { padding: 0.625rem 1.125rem; font-size: 0.875rem; }
  .journal-actions .btn span { margin-left: 0.25rem; transition: transform 150ms var(--ease-out); }
  .journal-actions .btn:hover span { transform: translate(2px, -1px); }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .post-item {
    padding-block: clamp(1.75rem, 3vw, 2.5rem);
    border-bottom: 1px dashed color-mix(in oklab, var(--border) 60%, transparent);
  }
  .post-item:last-child { border-bottom: none; }
  .post-date {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--content-3);
  }
  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2vw, 1.75rem);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
  }
  .post-title a {
    color: var(--content);
    transition: color 150ms var(--ease-out);
  }
  .post-title a:hover { color: var(--accent); }
  .post-arrow {
    display: inline-block;
    color: var(--content-3);
    margin-left: 0.35rem;
    font-size: 0.85em;
    transition: color 150ms var(--ease-out), transform 150ms var(--ease-out);
  }
  .post-title a:hover .post-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
  .post-blurb {
    margin: 0;
    max-width: 60ch;
  }

  .empty {
    padding: 2rem 0;
    text-align: center;
  }
  .inline-link {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, transparent);
  }
  .inline-link:hover { border-color: var(--accent); }
</style>
