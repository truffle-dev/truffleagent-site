---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Spin the Wheel · Free Random Picker and Decision Wheel";
const description =
  "Free online spinner wheel. Add names, spin, pick a winner. Works offline, saves to your browser, shares by link. No ads. No accounts. No trackers.";
const ogImage = "/spin/og";
const canonical = "https://truffleagent.com/spin/";

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Spin the Wheel",
  alternateName: ["Wheel of Names", "Random Picker", "Decision Wheel"],
  url: canonical,
  applicationCategory: "UtilityApplication",
  operatingSystem: "Any (Web)",
  browserRequirements: "Requires JavaScript",
  isAccessibleForFree: true,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  description,
  featureList: [
    "Pick a random winner from any list",
    "Save multiple wheels in your browser",
    "Share a wheel by link",
    "Team split mode",
    "Eliminate mode",
    "Accumulate mode",
    "Order mode",
    "Custom palettes and pointer",
    "Background scenes",
    "Selectable sound packs",
    "Embed on any page",
    "Works offline (PWA)",
    "No ads or tracking",
  ],
  author: { "@type": "Person", name: "Truffle" },
};

const faq = [
  {
    q: "How does the wheel pick a winner?",
    a: "Each entry is a slice of the wheel. The wheel spins and the slice under the pointer when it stops is the winner. Larger weights mean larger slices and a higher chance of being chosen.",
  },
  {
    q: "Is the spinner free?",
    a: "Yes. No ads, no signup, no paid tier. The full feature set is free forever.",
  },
  {
    q: "Does the spinner work offline?",
    a: "Yes. After your first visit, the page is cached as a Progressive Web App and works without an internet connection.",
  },
  {
    q: "Can I save my wheels?",
    a: "Yes. Wheels are saved automatically to your browser's localStorage. You can keep up to 20 named wheels and switch between them from the wheel picker.",
  },
  {
    q: "Can I share a wheel with someone else?",
    a: "Yes. Tap Share to copy a link that encodes the wheel's entries in the URL. Anyone who opens it sees the same wheel, ready to spin.",
  },
  {
    q: "Does it track me or use cookies?",
    a: "No. There are no ads, no analytics, no third-party scripts. Everything runs in your browser.",
  },
  {
    q: "Can I weight entries so some win more often?",
    a: "Yes. Tap an entry's weight number to set a value from 1 to 10. The slice scales with the weight.",
  },
  {
    q: "Can I embed the wheel on my own page?",
    a: "Yes. The wheel-picker menu has an Embed option that gives you an iframe snippet. Visitors can spin but not edit.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical}>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(webAppJsonLd)} />
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
  <script slot="head" is:inline>
    (function () {
      try {
        var p = new URLSearchParams(location.search);
        if (p.get("embed") === "1") {
          document.documentElement.dataset.embed = "1";
        }
      } catch (e) {}
      try {
        var m = document.querySelector('link[rel="manifest"]');
        if (m) {
          m.href = "/spin/manifest.webmanifest";
        } else {
          m = document.createElement("link");
          m.rel = "manifest";
          m.href = "/spin/manifest.webmanifest";
          document.head.appendChild(m);
        }
      } catch (e) {}
      try {
        if (
          "serviceWorker" in navigator &&
          document.documentElement.dataset.embed !== "1"
        ) {
          window.addEventListener("load", function () {
            navigator.serviceWorker
              .register("/spin/sw.js", { scope: "/spin/" })
              .catch(function () {});
          });
        }
      } catch (e) {}
    })();
  </script>
  <section class="spin-page" aria-labelledby="spin-title">
    <header class="spin-header">
      <p class="spin-eyebrow">Spin</p>
      <h1 id="spin-title" class="spin-title">
        Pick <em>anything.</em>
      </h1>
      <p class="spin-lede">
        Names, tasks, restaurants, prizes. Type entries, press spin, get a
        winner. Saves to your browser. Share with one link. No ads, ever.
      </p>
    </header>

    <div class="spin-stage">
      <div class="spin-wheel-pane">
        <div class="spin-wheel-frame">
          <div class="spin-pointer spin-pointer-top" aria-hidden="true"></div>
          <canvas id="spin-canvas" width="640" height="640" role="img" aria-label="Decision wheel"></canvas>
          <div id="spin-empty-overlay" class="spin-empty-overlay" hidden>
            <p class="spin-empty-title" id="spin-empty-title">Your wheel is empty.</p>
            <button type="button" id="spin-empty-cta" class="spin-empty-cta">
              <span aria-hidden="true">+</span>
              <span id="spin-empty-cta-label">Add your first entry</span>
            </button>
          </div>
          <button id="spin-center" class="spin-center-btn" type="button" aria-label="Spin the wheel">
            <span class="spin-center-label">Spin</span>
          </button>
        </div>
        <p class="spin-hint" id="spin-hint" aria-live="polite">
          Press <kbd>Space</kbd> or tap the center to spin.
        </p>
      </div>

      <aside class="spin-side" aria-label="Entries">
        <div class="spin-side-head">
          <div class="spin-head-row spin-head-row-top">
            <div class="spin-wheel-picker">
              <button id="spin-picker-btn" type="button" class="spin-picker-btn" aria-haspopup="true" aria-expanded="false" aria-controls="spin-picker-panel">
                <span id="spin-picker-name" class="spin-picker-name">My wheel</span>
                <svg class="spin-picker-chev" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <span id="spin-count" class="spin-count-chip">0</span>
              <div id="spin-picker-panel" class="spin-picker-panel" hidden role="menu" aria-label="Wheels">
                <ul id="spin-picker-list" class="spin-picker-list" role="none"></ul>
                <div class="spin-picker-divider"></div>
                <div class="spin-picker-grouplabel">Presets</div>
                <div class="spin-picker-presets" role="none">
                  <button type="button" id="spin-preset-yes-no" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="8 12.5 11 15 16 9"/></svg>
                    Yes / No
                  </button>
                  <button type="button" id="spin-preset-coin-flip" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="13" r="5.5"/><circle cx="15" cy="11" r="5.5"/></svg>
                    Coin flip
                  </button>
                  <button type="button" id="spin-preset-standup-order" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="5" cy="7" r="1.5"/><circle cx="5" cy="13" r="1.5"/><circle cx="5" cy="19" r="1.5"/><line x1="10" y1="7" x2="20" y2="7"/><line x1="10" y1="13" x2="20" y2="13"/><line x1="10" y1="19" x2="20" y2="19"/></svg>
                    Standup order
                  </button>
                  <button type="button" id="spin-preset-restaurant-picker" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 3v8m0 0a2 2 0 0 0 2-2V3M4 3v6a2 2 0 0 0 2 2"/><path d="M6 11v10"/><path d="M14 21V13a4 4 0 0 1 4-4V3"/><path d="M18 13H14"/></svg>
                    Restaurant picker
                  </button>
                  <button type="button" id="spin-preset-birthday-month" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"/><line x1="3" y1="11" x2="21" y2="11"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="16" y1="3" x2="16" y2="7"/></svg>
                    Birthday month
                  </button>
                </div>
                <div class="spin-picker-divider"></div>
                <div class="spin-picker-actions" role="none">
                  <button type="button" id="spin-picker-new" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New wheel
                  </button>
                  <button type="button" id="spin-picker-rename" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                    Rename
                  </button>
                  <button type="button" id="spin-picker-dupe" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                    Duplicate
                  </button>
                  <button type="button" id="spin-picker-shuffle" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
                    Shuffle entries
                  </button>
                  <button type="button" id="spin-picker-reset-counts" class="spin-picker-action" role="menuitem" hidden>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                    Reset win counts
                  </button>
                  <button type="button" id="spin-picker-export" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Export JSON
                  </button>
                  <button type="button" id="spin-picker-import" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    Import JSON
                  </button>
                  <button type="button" id="spin-picker-embed" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                    Embed code
                  </button>
                  <button type="button" id="spin-picker-reset-defaults" class="spin-picker-action" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></svg>
                    Reset look
                  </button>
                  <button type="button" id="spin-picker-clear-entries" class="spin-picker-action spin-picker-action-danger" role="menuitem" hidden>
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="14" y2="6"/><line x1="3" y1="12" x2="14" y2="12"/><line x1="3" y1="18" x2="14" y2="18"/><line x1="18" y1="9" x2="22" y2="13"/><line x1="22" y1="9" x2="18" y2="13"/></svg>
                    <span id="spin-picker-clear-entries-label">Clear entries</span>
                  </button>
                  <button type="button" id="spin-picker-delete" class="spin-picker-action spin-picker-action-danger" role="menuitem">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                    Delete
                  </button>
                </div>
              </div>
              <input type="file" id="spin-import-file" accept=".json,application/json" hidden />
              <input type="color" id="spin-color-picker" hidden aria-hidden="true" tabindex="-1" />
            </div>
            <div class="spin-head-actions">
              <button id="spin-share" type="button" class="spin-cta-chip" title="Copy share link" aria-label="Copy share link">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                <span>Share</span>
              </button>
              <button id="spin-mute" type="button" class="spin-icon-btn spin-icon-btn-pill" title="Mute sound" aria-label="Mute sound" aria-pressed="false">
                <svg class="spin-mute-on" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
                <svg class="spin-mute-off" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
              </button>
            </div>
          </div>

          <div class="spin-toolbar-section">
            <span class="spin-toolbar-grouplabel">Mode</span>
            <div class="spin-mode-chips" role="group" aria-label="Spin mode">
              <button id="spin-mode-single" type="button" class="spin-mode-chip" aria-pressed="true" title="One winner per spin">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="8.5"/></svg>
                <span>Single</span>
              </button>
              <button id="spin-eliminate" type="button" class="spin-mode-chip" aria-pressed="false" title="Winner removed each spin">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                <span>Eliminate</span>
              </button>
              <button id="spin-accumulate" type="button" class="spin-mode-chip" aria-pressed="false" title="Track win counts">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="20" x2="4" y2="13"/><line x1="10" y1="20" x2="10" y2="8"/><line x1="16" y1="20" x2="16" y2="11"/><line x1="3" y1="20" x2="17" y2="20"/></svg>
                <span>Accumulate</span>
              </button>
              <button id="spin-order" type="button" class="spin-mode-chip" title="Spin for full ordering">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="10" y1="6" x2="20" y2="6"/><line x1="10" y1="12" x2="20" y2="12"/><line x1="10" y1="18" x2="20" y2="18"/><path d="M4 4h1.5v4"/><path d="M4 14h2.5c0 1-2 2-2 3h2"/></svg>
                <span>Order</span>
              </button>
              <button id="spin-teams" type="button" class="spin-mode-chip" aria-expanded="false" title="Split into teams">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="8" cy="9" r="2.5"/><circle cx="16" cy="9" r="2.5"/><path d="M3 19c.5-2.5 2.5-4 5-4s4.5 1.5 5 4"/><path d="M11 19c.5-2.5 2.5-4 5-4s4.5 1.5 5 4"/></svg>
                <span>Teams</span>
              </button>
              <button id="spin-rotation" type="button" class="spin-mode-chip" aria-pressed="false" title="Weekly rotation — winner removed and the roster rehydrates when empty">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12a8 8 0 1 1-2.5-5.8"/><polyline points="20 4 20 8 16 8"/></svg>
                <span>Rotation</span>
              </button>
            </div>
          </div>

          <div class="spin-toolbar-section">
            <span class="spin-toolbar-grouplabel">Look</span>
            <div class="spin-style-icons" role="group" aria-label="Wheel look settings">
              <button id="spin-palette-btn" type="button" class="spin-icon-btn" title="Palette" aria-label="Color palette" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a9 9 0 1 0 0 18c1.5 0 2-1 2-2 0-1.5-1.5-2-1.5-3.5 0-1 .8-1.5 1.8-1.5H17a4 4 0 0 0 4-4 9 9 0 0 0-9-7z"/><circle cx="7.5" cy="11" r="1"/><circle cx="11" cy="7" r="1"/><circle cx="15.5" cy="8" r="1"/><circle cx="17.5" cy="12.5" r="1"/></svg>
                <span class="spin-icon-label">Palette</span>
              </button>
              <button id="spin-pointer-btn" type="button" class="spin-icon-btn" title="Pointer" aria-label="Pointer settings" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 3 8.5 8.5 15.5 8.5"/><circle cx="12" cy="15" r="5"/></svg>
                <span class="spin-icon-label">Pointer</span>
              </button>
              <button id="spin-labelrot-btn" type="button" class="spin-icon-btn" title="Labels" aria-label="Label rotation" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 19 L9 5 L13 19"/><line x1="6.5" y1="14" x2="11.5" y2="14"/><path d="M15 9 a4 4 0 0 1 4 4 a4 4 0 0 1 -4 4"/><polyline points="13 15 15 17 17 15"/></svg>
                <span class="spin-icon-label">Labels</span>
              </button>
              <button id="spin-size-btn" type="button" class="spin-icon-btn" title="Size" aria-label="Wheel size" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 9 4 4 9 4"/><polyline points="20 9 20 4 15 4"/><polyline points="4 15 4 20 9 20"/><polyline points="20 15 20 20 15 20"/></svg>
                <span class="spin-icon-label">Size</span>
              </button>
              <button id="spin-sound-btn" type="button" class="spin-icon-btn" title="Sound" aria-label="Sound style" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12 L7 12 L11 7 L11 17 L7 12"/><path d="M14 9 a4 4 0 0 1 0 6"/><path d="M17 6 a8 8 0 0 1 0 12"/></svg>
                <span class="spin-icon-label">Sound</span>
              </button>
              <button id="spin-scene-btn" type="button" class="spin-icon-btn" title="Scene" aria-label="Background scene" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 14 l5 -4 l4 3 l3 -2 l6 5"/><circle cx="8" cy="9" r="1.4"/></svg>
                <span class="spin-icon-label">Scene</span>
              </button>
            </div>
          </div>

          <button id="spin-shuffle" type="button" class="spin-hidden-handle" aria-hidden="true" tabindex="-1"></button>
          <button id="spin-reset" type="button" class="spin-hidden-handle" aria-hidden="true" tabindex="-1"></button>
        </div>

        <div id="spin-import-notice" class="spin-import-notice" hidden role="status">
          <span class="spin-shared-pill" aria-hidden="true">shared</span>
          <span class="spin-import-notice-text">Imported from a shared link. Edit any entry to make it your own.</span>
        </div>

        <div id="spin-teams-config" class="spin-teams-config" hidden role="group" aria-label="Team split settings">
          <span class="spin-teams-label">Teams</span>
          <div class="spin-teams-stepper" role="group" aria-label="Team count stepper">
            <button id="spin-teams-dec" type="button" class="spin-teams-step" aria-label="Fewer teams">−</button>
            <span id="spin-teams-count" class="spin-teams-count" aria-live="polite">3</span>
            <button id="spin-teams-inc" type="button" class="spin-teams-step" aria-label="More teams">+</button>
          </div>
          <button id="spin-teams-go" type="button" class="spin-teams-go">Split</button>
          <button id="spin-teams-cancel" type="button" class="spin-teams-cancel" aria-label="Cancel team split">×</button>
        </div>

        <div id="spin-pointer-config" class="spin-pointer-config" hidden role="group" aria-label="Pointer settings">
          <span class="spin-pointer-cfg-label">Position</span>
          <div class="spin-pointer-chips" role="group" aria-label="Pointer position">
            <button id="spin-pointer-pos-top" type="button" class="spin-pointer-chip" aria-pressed="true">Top</button>
            <button id="spin-pointer-pos-right" type="button" class="spin-pointer-chip" aria-pressed="false">Right</button>
          </div>
          <span class="spin-pointer-cfg-label">Color</span>
          <div class="spin-pointer-swatches" role="group" aria-label="Pointer color">
            <button type="button" class="spin-pointer-swatch spin-pointer-swatch-ink" data-color="ink" aria-pressed="true" aria-label="Ink"></button>
            <button type="button" class="spin-pointer-swatch spin-pointer-swatch-accent" data-color="accent" aria-pressed="false" aria-label="Indigo"></button>
            <button type="button" class="spin-pointer-swatch spin-pointer-swatch-amber" data-color="amber" aria-pressed="false" aria-label="Amber"></button>
          </div>
          <button id="spin-pointer-cancel" type="button" class="spin-pointer-cancel" aria-label="Close pointer settings">×</button>
        </div>

        <div id="spin-labelrot-config" class="spin-labelrot-config" hidden role="group" aria-label="Label rotation settings">
          <span class="spin-labelrot-label">Labels</span>
          <div class="spin-labelrot-chips" role="group" aria-label="Label rotation mode">
            <button id="spin-labelrot-auto" type="button" class="spin-labelrot-chip" data-mode="auto" aria-pressed="true">Auto</button>
            <button id="spin-labelrot-tangent" type="button" class="spin-labelrot-chip" data-mode="tangent" aria-pressed="false">Tangent</button>
            <button id="spin-labelrot-radial" type="button" class="spin-labelrot-chip" data-mode="radial" aria-pressed="false">Radial</button>
          </div>
          <button id="spin-labelrot-cancel" type="button" class="spin-labelrot-cancel" aria-label="Close label rotation settings">×</button>
        </div>

        <div id="spin-palette-config" class="spin-palette-config" hidden role="group" aria-label="Theme palette settings">
          <span class="spin-palette-cfg-label">Palette</span>
          <div id="spin-palette-chips" class="spin-palette-chips" role="group" aria-label="Palette choice"></div>
          <button id="spin-palette-cancel" type="button" class="spin-palette-cancel" aria-label="Close palette settings">×</button>
        </div>

        <div id="spin-size-config" class="spin-size-config" hidden role="group" aria-label="Wheel size settings">
          <span class="spin-size-label">Size</span>
          <div class="spin-size-chips" role="group" aria-label="Wheel size">
            <button id="spin-size-s" type="button" class="spin-size-chip" data-size="s" aria-pressed="false">S</button>
            <button id="spin-size-m" type="button" class="spin-size-chip" data-size="m" aria-pressed="false">M</button>
            <button id="spin-size-l" type="button" class="spin-size-chip" data-size="l" aria-pressed="true">L</button>
            <button id="spin-size-full" type="button" class="spin-size-chip" data-size="full" aria-pressed="false">Full</button>
          </div>
          <button id="spin-size-cancel" type="button" class="spin-size-cancel" aria-label="Close size settings">×</button>
        </div>

        <div id="spin-sound-config" class="spin-sound-config" hidden role="group" aria-label="Sound style settings">
          <span class="spin-sound-label">Sound</span>
          <div class="spin-sound-chips" role="group" aria-label="Sound style">
            <button type="button" class="spin-sound-chip" data-pack="classic" aria-pressed="true">Classic</button>
            <button type="button" class="spin-sound-chip" data-pack="soft" aria-pressed="false">Soft</button>
            <button type="button" class="spin-sound-chip" data-pack="arcade" aria-pressed="false">Arcade</button>
            <button type="button" class="spin-sound-chip" data-pack="sparkle" aria-pressed="false">Sparkle</button>
          </div>
          <button id="spin-sound-preview" type="button" class="spin-sound-preview" aria-label="Preview sound style">Preview</button>
          <button id="spin-sound-cancel" type="button" class="spin-sound-cancel" aria-label="Close sound settings">×</button>
        </div>

        <div id="spin-scene-config" class="spin-scene-config" hidden role="group" aria-label="Background scene settings">
          <span class="spin-scene-label">Scene</span>
          <div class="spin-scene-chips" role="group" aria-label="Background scene"></div>
          <button id="spin-scene-cancel" type="button" class="spin-scene-cancel" aria-label="Close scene settings">×</button>
        </div>

        <div id="spin-rotation-bar" class="spin-rotation-bar" hidden>
          <div class="spin-rotation-bar-line">
            <span id="spin-rotation-status" class="spin-rotation-status"></span>
            <button id="spin-rotation-rehydrate" type="button" class="spin-rotation-rehydrate" hidden>Start new cycle</button>
          </div>
          <p id="spin-rotation-hint" class="spin-rotation-hint" hidden></p>
        </div>

        <ul id="spin-list" class="spin-list" aria-label="Entries list"></ul>

        <form id="spin-add-form" class="spin-add">
          <input
            type="text"
            id="spin-add-input"
            class="spin-add-input"
            placeholder="Add an entry…"
            autocomplete="off"
            maxlength="80"
            aria-label="New entry"
          />
          <button type="submit" class="spin-add-btn" aria-label="Add entry">Add</button>
        </form>

        <details class="spin-bulk">
          <summary>Paste a list</summary>
          <textarea id="spin-bulk-input" rows="4" placeholder="One per line, or comma-separated"></textarea>
          <button id="spin-bulk-apply" type="button" class="spin-bulk-btn">Replace entries</button>
        </details>

        <details class="spin-history">
          <summary>Recent spins<span id="spin-history-count" class="spin-history-count" hidden></span></summary>
          <ul id="spin-history-list" class="spin-history-list" aria-label="Recent spins"></ul>
          <button id="spin-history-clear" type="button" class="spin-history-clear" hidden>Clear history</button>
        </details>
      </aside>
    </div>

    <section class="spin-suggest" aria-labelledby="spin-suggest-title">
      <details class="spin-suggest-card">
        <summary>
          <span class="spin-suggest-eyebrow">Have an idea?</span>
          <span id="spin-suggest-title" class="spin-suggest-title">Request a feature</span>
          <span class="spin-suggest-hint" aria-hidden="true"></span>
        </summary>
        <div class="spin-suggest-body">
          <p class="spin-suggest-lead">What would make this wheel better for the way you use it? One line is plenty. I read every one.</p>
          <form id="spin-suggest-form" class="spin-suggest-form" novalidate>
            <label class="spin-suggest-label" for="spin-suggest-text">Your idea</label>
            <textarea id="spin-suggest-text" name="text" class="spin-suggest-text" rows="4" maxlength="2000" placeholder="e.g. let me upload a CSV, or pick a wheel by URL alias" required></textarea>
            <div class="spin-suggest-row">
              <label class="spin-suggest-emaillabel" for="spin-suggest-email">Email (optional, for replies)</label>
              <input id="spin-suggest-email" name="email" type="email" class="spin-suggest-email" maxlength="254" placeholder="you@example.com" autocomplete="email" />
            </div>
            <div class="spin-suggest-actions">
              <button type="submit" class="spin-suggest-send">Send</button>
              <button type="button" id="spin-suggest-copy" class="spin-suggest-copy">Copy email instead</button>
              <span id="spin-suggest-status" class="spin-suggest-status" aria-live="polite"></span>
            </div>
            <p class="spin-suggest-note">Sends to <code>truffle@truffleagent.com</code> via your mail app. No account. No tracking.</p>
          </form>
        </div>
      </details>
    </section>

    <section class="spin-about" aria-labelledby="spin-about-title">
      <h2 id="spin-about-title" class="spin-about-h">A calm random picker. <em>Built like a tool, not a toy.</em></h2>
      <p class="spin-about-lead">
        Spin the Wheel is a free online decision wheel. Add entries, press
        spin, get a winner. Use it for stand-up order, raffles, classroom
        questions, dinner choices, tournament brackets, or any time you need
        a clean random pick. Your wheel lives in your browser and works
        offline. No accounts. No ads. No analytics that fingerprint you.
      </p>
      <ul class="spin-about-features">
        <li><strong>Multiple wheels.</strong> Save up to 20 named wheels and switch between them.</li>
        <li><strong>Modes.</strong> Single winner, eliminate, accumulate, order, or team split.</li>
        <li><strong>Sound packs.</strong> Classic, Soft, Arcade, or Sparkle.</li>
        <li><strong>Scenes.</strong> Five page backgrounds, from warm Paper to deep Noir.</li>
        <li><strong>Share.</strong> One link encodes the whole wheel.</li>
        <li><strong>Embed.</strong> Drop the wheel into any blog or doc.</li>
        <li><strong>Offline.</strong> Installs as a PWA on phones and laptops.</li>
        <li><strong>Keyboard.</strong> Space spins, Esc closes, ? shows shortcuts.</li>
      </ul>
    </section>

    <section class="spin-presets" aria-labelledby="spin-presets-title">
      <h2 id="spin-presets-title" class="spin-presets-h">
        Start with a <em>ready-made wheel.</em>
      </h2>
      <p class="spin-presets-lead">
        Five canonical wheels, each with its own page, its own answers,
        and a one-tap launch into a fresh saved wheel.
      </p>
      <ul class="spin-presets-grid">
        <li class="spin-preset-card"><a class="spin-preset-link" data-preset="yes-no" href="/spin/yes-no/"><span class="spin-preset-title">Yes / No</span><span class="spin-preset-blurb">50 / 50 for the small calls.</span><span class="spin-preset-arrow" aria-hidden="true">&rarr;</span></a></li>
        <li class="spin-preset-card"><a class="spin-preset-link" data-preset="coin-flip" href="/spin/coin-flip/"><span class="spin-preset-title">Coin flip</span><span class="spin-preset-blurb">Heads or tails, one tap.</span><span class="spin-preset-arrow" aria-hidden="true">&rarr;</span></a></li>
        <li class="spin-preset-card"><a class="spin-preset-link" data-preset="standup-order" href="/spin/standup-order/"><span class="spin-preset-title">Standup order</span><span class="spin-preset-blurb">Speaking order for daily standup.</span><span class="spin-preset-arrow" aria-hidden="true">&rarr;</span></a></li>
        <li class="spin-preset-card"><a class="spin-preset-link" data-preset="restaurant-picker" href="/spin/restaurant-picker/"><span class="spin-preset-title">Restaurant picker</span><span class="spin-preset-blurb">Cuisines, weighted by appetite.</span><span class="spin-preset-arrow" aria-hidden="true">&rarr;</span></a></li>
        <li class="spin-preset-card"><a class="spin-preset-link" data-preset="birthday-month" href="/spin/birthday-month/"><span class="spin-preset-title">Birthday month</span><span class="spin-preset-blurb">Twelve months, uniform odds.</span><span class="spin-preset-arrow" aria-hidden="true">&rarr;</span></a></li>
      </ul>
    </section>

    <section class="spin-faq" aria-labelledby="spin-faq-title">
      <h2 id="spin-faq-title" class="spin-faq-h">Frequently asked questions</h2>
      <div class="spin-faq-list">
        {faq.map((item) => (
          <details class="spin-faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <footer class="spin-foot">
      <p>
        Made on <a href="/">Truffle</a>. Open source soon. No ads. No trackers.
        Your wheel lives in your browser.
      </p>
    </footer>

    <a class="spin-embed-credit" href="/spin/" target="_blank" rel="noopener">
      spin · truffleagent.com
    </a>
  </section>

  <div id="spin-winner" class="spin-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="spin-winner-name">
    <div class="spin-modal-card">
      <p id="spin-modal-label" class="spin-modal-label">Winner</p>
      <p id="spin-winner-name" class="spin-modal-name"></p>
      <ol id="spin-order-list" class="spin-order-list" hidden aria-label="Spin order"></ol>
      <div id="spin-teams-list" class="spin-teams-list" hidden aria-label="Teams"></div>
      <div class="spin-modal-actions">
        <button id="spin-winner-remove" type="button" class="spin-btn">Remove + spin</button>
        <button id="spin-winner-again" type="button" class="spin-btn spin-btn-primary">Spin again</button>
        <button id="spin-winner-share" type="button" class="spin-btn">Share image</button>
        <button id="spin-winner-close" type="button" class="spin-btn-ghost">Close</button>
      </div>
    </div>
  </div>

  <div id="spin-embed-modal" class="spin-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="spin-embed-title">
    <div class="spin-modal-card spin-embed-card">
      <button id="spin-embed-x" type="button" class="spin-help-x" aria-label="Close embed dialog">×</button>
      <p class="spin-modal-label">Embed</p>
      <p id="spin-embed-title" class="spin-help-title">Drop the wheel anywhere</p>
      <p class="spin-embed-lead">Paste this snippet into a blog post, doc, or any HTML page. The current wheel state travels in the URL. Visitors can spin but not edit.</p>
      <textarea id="spin-embed-code" class="spin-embed-textarea" readonly rows="4" aria-label="Embed snippet"></textarea>
      <div class="spin-modal-actions">
        <button id="spin-embed-copy" type="button" class="spin-btn spin-btn-primary">Copy code</button>
        <button id="spin-embed-close" type="button" class="spin-btn-ghost">Close</button>
      </div>
    </div>
  </div>

  <div id="spin-help" class="spin-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="spin-help-title">
    <div class="spin-modal-card spin-help-card">
      <button id="spin-help-close-x" type="button" class="spin-help-x" aria-label="Close keyboard shortcuts">×</button>
      <p class="spin-modal-label">Shortcuts</p>
      <p id="spin-help-title" class="spin-help-title">Keyboard</p>
      <dl class="spin-help-list">
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Space</kbd></dt><dd>Spin the wheel</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Esc</kbd></dt><dd>Close any dialog</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">?</kbd></dt><dd>Toggle this cheatsheet</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Enter</kbd></dt><dd>Add entry (while typing)</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Tab</kbd></dt><dd>Move through entries</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Alt</kbd> + <kbd class="spin-kbd">↑</kbd> / <kbd class="spin-kbd">↓</kbd></dt><dd>Reorder entry up / down</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Backspace</kbd></dt><dd>Delete entry (when input is empty)</dd></div>
        <div class="spin-help-row"><dt><kbd class="spin-kbd">Ctrl</kbd> / <kbd class="spin-kbd">⌘</kbd> + <kbd class="spin-kbd">Z</kbd></dt><dd>Undo last entry delete</dd></div>
      </dl>
      <p class="spin-help-foot">Shortcuts skip when an input is focused.</p>
    </div>
