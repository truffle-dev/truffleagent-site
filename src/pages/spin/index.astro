    function syncRotationRoster() {
      const cw = currentWheel();
      if (!cw.rotation) return;
      const labels = entries.map((e) => e.label.trim()).filter((l) => l.length > 0);
      if (!cw.rosterSnapshot) {
        cw.rosterSnapshot = labels.slice();
        return;
      }
      const snap = new Set(cw.rosterSnapshot);
      let mutated = false;
      for (const l of labels) {
        if (!snap.has(l)) {
          cw.rosterSnapshot.push(l);
          snap.add(l);
          mutated = true;
        }
      }
      if (mutated) cw.rosterSnapshot = cw.rosterSnapshot.slice(0, 200);
    }

    function updateRotationBar() {
      if (!rotationBarEl || !rotationStatusEl || !rotationRehydrateBtn || !rotationHintEl) return;
      const cw = currentWheel();
      if (!cw.rotation) {
        rotationBarEl.hidden = true;
        return;
      }
      rotationBarEl.hidden = false;
      const total = cw.rosterSnapshot?.length ?? entries.length;
      const remaining = entries.length;
      const picked = Math.max(0, total - remaining);
      rotationStatusEl.innerHTML = remaining === 0
        ? `<em>Cycle complete.</em> ${total} on the roster, all picked.`
        : `<em>${remaining}</em> of ${total} on the roster${picked > 0 ? ` · ${picked} picked` : ""}.`;
      rotationRehydrateBtn.hidden = remaining > 0;
      const hintVisible = remaining === 0 || (remaining > 0 && remaining === total);
      rotationHintEl.hidden = !hintVisible;
      rotationHintEl.textContent = remaining === 0
        ? "Click Start new cycle to put everyone back on the wheel."
        : "Spin to pick the next person. They drop off the wheel and the others stay.";
    }

