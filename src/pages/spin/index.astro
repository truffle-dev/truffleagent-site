---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Spin · pick anything, no ads";
const description =
  "A calm, fast decision wheel. Add names, spin, get a winner. No accounts, no ads, no trackers. Saves locally and shares by link.";
---

<BaseLayout title={title} description={description}>
  <section class="spin-page" aria-labelledby="spin-title">
    <header class="spin-header">
      <p class="spin-eyebrow">Spin</p>
      <h1 id="spin-title" class="spin-title">
        Pick <em>anything.</em>
      </h1>
      <p class="spin-lede">
        Names, tasks, restaurants, prizes. Type entries, press spin, get a
        winner. Saves to your browser. Share with one link. No ads, ever.
      </p>
    </header>

    <div class="spin-stage">
      <div class="spin-wheel-pane">
        <div class="spin-wheel-frame">
          <div class="spin-pointer" aria-hidden="true"></div>
          <canvas id="spin-canvas" width="640" height="640" role="img" aria-label="Decision wheel"></canvas>
          <button id="spin-center" class="spin-center-btn" type="button" aria-label="Spin the wheel">
            <span class="spin-center-label">Spin</span>
          </button>
        </div>
        <p class="spin-hint" id="spin-hint" aria-live="polite">
          Press <kbd>Space</kbd> or tap the center to spin.
        </p>
      </div>

      <aside class="spin-side" aria-label="Entries">
        <div class="spin-side-head">
          <div class="spin-wheel-picker">
            <button id="spin-picker-btn" type="button" class="spin-picker-btn" aria-haspopup="true" aria-expanded="false" aria-controls="spin-picker-panel">
              <span id="spin-picker-name" class="spin-picker-name">My wheel</span>
              <svg class="spin-picker-chev" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <span id="spin-count" class="spin-count">0</span>
            <div id="spin-picker-panel" class="spin-picker-panel" hidden role="menu" aria-label="Wheels">
              <ul id="spin-picker-list" class="spin-picker-list" role="none"></ul>
              <div class="spin-picker-divider"></div>
              <div class="spin-picker-actions" role="none">
                <button type="button" id="spin-picker-new" class="spin-picker-action" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  New wheel
                </button>
                <button type="button" id="spin-picker-rename" class="spin-picker-action" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                  Rename
                </button>
                <button type="button" id="spin-picker-dupe" class="spin-picker-action" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  Duplicate
                </button>
                <button type="button" id="spin-picker-export" class="spin-picker-action" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  Export JSON
                </button>
                <button type="button" id="spin-picker-import" class="spin-picker-action" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  Import JSON
                </button>
                <button type="button" id="spin-picker-delete" class="spin-picker-action spin-picker-action-danger" role="menuitem">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  Delete
                </button>
              </div>
            </div>
            <input type="file" id="spin-import-file" accept=".json,application/json" hidden />
            <input type="color" id="spin-color-picker" hidden aria-hidden="true" tabindex="-1" />
          </div>
          <div class="spin-side-actions">
            <button id="spin-share" type="button" class="spin-icon-btn" title="Copy share link" aria-label="Copy share link">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </button>
            <button id="spin-mute" type="button" class="spin-icon-btn" title="Mute sound" aria-label="Mute sound" aria-pressed="false">
              <svg class="spin-mute-on" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
              <svg class="spin-mute-off" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            </button>
            <button id="spin-shuffle" type="button" class="spin-icon-btn" title="Shuffle order" aria-label="Shuffle order">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
            </button>
            <button id="spin-reset" type="button" class="spin-icon-btn" title="Reset to defaults" aria-label="Reset to defaults">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            </button>
          </div>
        </div>

        <ul id="spin-list" class="spin-list" aria-label="Entries list"></ul>

        <form id="spin-add-form" class="spin-add">
          <input
            type="text"
            id="spin-add-input"
            class="spin-add-input"
            placeholder="Add an entry…"
            autocomplete="off"
            maxlength="80"
            aria-label="New entry"
          />
          <button type="submit" class="spin-add-btn" aria-label="Add entry">Add</button>
        </form>

        <details class="spin-bulk">
          <summary>Paste a list</summary>
          <textarea id="spin-bulk-input" rows="4" placeholder="One per line, or comma-separated"></textarea>
          <button id="spin-bulk-apply" type="button" class="spin-bulk-btn">Replace entries</button>
        </details>
      </aside>
    </div>

    <footer class="spin-foot">
      <p>
        Made on <a href="/">Truffle</a>. Open source soon. No ads. No trackers.
        Your wheel lives in your browser.
      </p>
    </footer>
  </section>

  <div id="spin-winner" class="spin-modal" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="spin-winner-name">
    <div class="spin-modal-card">
      <p class="spin-modal-label">Winner</p>
      <p id="spin-winner-name" class="spin-modal-name"></p>
      <div class="spin-modal-actions">
        <button id="spin-winner-remove" type="button" class="spin-btn">Remove + spin</button>
        <button id="spin-winner-again" type="button" class="spin-btn spin-btn-primary">Spin again</button>
        <button id="spin-winner-close" type="button" class="spin-btn-ghost">Close</button>
      </div>
    </div>
  </div>

  <canvas id="spin-confetti" class="spin-confetti" aria-hidden="true"></canvas>
  <div id="spin-toast" class="spin-toast" hidden aria-live="polite"></div>

  <style is:global>
    .spin-page {
      max-width: 1240px;
      margin: 0 auto;
      padding: clamp(2rem, 4vw, 3.5rem) clamp(1rem, 3vw, 2rem) 4rem;
    }

    .spin-header {
      text-align: center;
      max-width: 720px;
      margin: 0 auto 2.5rem;
    }
    .spin-eyebrow {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--content-3);
      margin: 0 0 0.75rem;
    }
    .spin-title {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
      color: var(--content);
    }
    .spin-title em {
      font-style: italic;
      color: var(--accent);
    }
    .spin-lede {
      font-size: 17px;
      line-height: 1.55;
      color: var(--content-2);
      margin: 0;
    }

    .spin-stage {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      align-items: start;
    }
    @media (min-width: 880px) {
      .spin-stage {
        grid-template-columns: minmax(0, 1.35fr) minmax(280px, 1fr);
      }
    }

    .spin-wheel-pane {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .spin-wheel-frame {
      position: relative;
      width: 100%;
      max-width: 640px;
      aspect-ratio: 1 / 1;
    }

    #spin-canvas {
      width: 100%;
      height: 100%;
      display: block;
      filter: drop-shadow(0 12px 32px rgba(20, 17, 11, 0.12));
    }

    .spin-pointer {
      position: absolute;
      top: -6px;
      left: 50%;
      transform: translateX(-50%);
      width: 0;
      height: 0;
      border-left: 14px solid transparent;
      border-right: 14px solid transparent;
      border-top: 26px solid var(--content);
      z-index: 2;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
    }

    .spin-center-btn {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 22%;
      height: 22%;
      min-width: 84px;
      min-height: 84px;
      border-radius: 50%;
      border: 4px solid var(--surface);
      background: var(--accent);
      color: white;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.2rem, 2.5vw, 1.75rem);
      font-weight: 500;
      cursor: pointer;
      transition: transform 0.15s var(--ease-out), box-shadow 0.15s var(--ease-out), background 0.2s;
      box-shadow: 0 6px 18px rgba(72, 80, 196, 0.35);
    }
    .spin-center-btn:hover {
      transform: translate(-50%, -50%) scale(1.04);
      box-shadow: 0 10px 24px rgba(72, 80, 196, 0.45);
    }
    .spin-center-btn:active {
      transform: translate(-50%, -50%) scale(0.97);
    }
    .spin-center-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: translate(-50%, -50%);
    }

    .spin-hint {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      margin: 0;
      text-align: center;
    }
    .spin-hint kbd {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 1px 6px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--surface-2);
      color: var(--content-2);
    }

    .spin-side {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .spin-side-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }
    .spin-side-title {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      margin: 0;
      color: var(--content);
    }
    .spin-count {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      margin-left: 0.5rem;
      font-weight: 400;
    }
    .spin-side-actions {
      display: flex;
      gap: 0.25rem;
    }

    .spin-wheel-picker {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      min-width: 0;
      flex: 1;
    }
    .spin-picker-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 4px 8px 4px 4px;
      cursor: pointer;
      color: var(--content);
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.1;
      min-width: 0;
      max-width: 100%;
      transition: background 0.12s, border-color 0.12s;
    }
    .spin-picker-btn:hover {
      background: var(--surface-3);
      border-color: var(--border);
    }
    .spin-picker-btn[aria-expanded="true"] {
      background: var(--surface-3);
      border-color: var(--border);
    }
    .spin-picker-name {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 14ch;
    }
    .spin-picker-chev {
      color: var(--content-3);
      transition: transform 0.15s var(--ease-out);
      flex-shrink: 0;
    }
    .spin-picker-btn[aria-expanded="true"] .spin-picker-chev {
      transform: rotate(180deg);
    }
    .spin-picker-panel {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      z-index: 20;
      min-width: 220px;
      max-width: 320px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.18), 0 2px 6px -2px rgba(0, 0, 0, 0.08);
      padding: 4px;
      display: flex;
      flex-direction: column;
    }
    .spin-picker-list {
      list-style: none;
      margin: 0;
      padding: 0;
      max-height: 220px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .spin-picker-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 7px 8px;
      border-radius: 6px;
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content);
      background: transparent;
      border: 0;
      width: 100%;
      text-align: left;
      transition: background 0.1s;
    }
    .spin-picker-item:hover {
      background: var(--surface-2);
    }
    .spin-picker-item-check {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      color: var(--accent);
      opacity: 0;
    }
    .spin-picker-item[aria-current="true"] .spin-picker-item-check {
      opacity: 1;
    }
    .spin-picker-item-name {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .spin-picker-item-count {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--content-3);
      flex-shrink: 0;
    }
    .spin-picker-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 6px;
    }
    .spin-picker-actions {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .spin-picker-action {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 7px 8px;
      border-radius: 6px;
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--content-2);
      background: transparent;
      border: 0;
      text-align: left;
      transition: background 0.1s, color 0.1s;
    }
    .spin-picker-action:hover {
      background: var(--surface-2);
      color: var(--content);
    }
    .spin-picker-action-danger:hover {
      color: var(--color-rust-500);
    }
    .spin-picker-action[disabled] {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .spin-icon-btn {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--content-3);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .spin-icon-btn:hover {
      background: var(--surface-3);
      color: var(--content);
      border-color: var(--border);
    }

    .spin-list {
      list-style: none;
      padding: 0;
      margin: 0;
      max-height: clamp(320px, 50vh, 520px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .spin-list-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 6px 8px;
      border-radius: 8px;
      transition: background 0.12s;
    }
    .spin-list-item:hover {
      background: var(--surface-3);
    }
    .spin-list-color {
      width: 18px;
      height: 18px;
      border-radius: 5px;
      flex-shrink: 0;
      border: 1px solid rgba(20, 17, 11, 0.18);
      padding: 0;
      cursor: pointer;
      position: relative;
      transition: transform 0.12s, box-shadow 0.12s;
    }
    .spin-list-color:hover {
      transform: scale(1.12);
    }
    .spin-list-color:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .spin-list-color[data-custom="true"]::after {
      content: "";
      position: absolute;
      right: -2px;
      bottom: -2px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid currentColor;
    }
    .spin-list-input {
      flex: 1;
      border: 0;
      background: transparent;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content);
      padding: 4px 0;
      min-width: 0;
    }
    .spin-list-input:focus {
      outline: none;
    }
    .spin-list-input:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .spin-list-remove {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      border: 0;
      background: transparent;
      color: var(--content-4);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.12s, background 0.12s, color 0.12s;
    }
    .spin-list-item:hover .spin-list-remove,
    .spin-list-item:focus-within .spin-list-remove {
      opacity: 1;
    }
    .spin-list-remove:hover {
      background: var(--surface);
      color: var(--color-rust-500);
    }

    .spin-add {
      display: flex;
      gap: 0.5rem;
    }
    .spin-add-input {
      flex: 1;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 14px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .spin-add-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
    }
    .spin-add-btn {
      padding: 0.55rem 1rem;
      border-radius: 8px;
      border: 0;
      background: var(--accent);
      color: white;
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s;
    }
    .spin-add-btn:hover {
      background: var(--accent-2);
    }

    .spin-bulk {
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }
    .spin-bulk summary {
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      letter-spacing: 0.05em;
      list-style: none;
      user-select: none;
    }
    .spin-bulk summary::-webkit-details-marker { display: none; }
    .spin-bulk summary::before {
      content: "+";
      display: inline-block;
      width: 1em;
      color: var(--content-4);
    }
    .spin-bulk[open] summary::before { content: "−"; }
    .spin-bulk textarea {
      width: 100%;
      margin-top: 0.5rem;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-mono);
      font-size: 13px;
      resize: vertical;
    }
    .spin-bulk textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
    }
    .spin-bulk-btn {
      margin-top: 0.5rem;
      padding: 0.45rem 0.85rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 13px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .spin-bulk-btn:hover {
      background: var(--surface-3);
    }

    .spin-foot {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 13px;
      color: var(--content-3);
    }
    .spin-foot a {
      color: var(--accent);
      text-decoration: none;
    }
    .spin-foot a:hover {
      text-decoration: underline;
    }

    .spin-modal {
      position: fixed;
      inset: 0;
      background: color-mix(in oklab, var(--surface) 70%, black);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      z-index: 50;
      animation: spin-fade-in 0.2s var(--ease-out);
    }
    .spin-modal[hidden] {
      display: none;
    }
    @keyframes spin-fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .spin-modal-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      max-width: 420px;
      width: 100%;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
      animation: spin-pop 0.3s var(--ease-out);
    }
    @keyframes spin-pop {
      from { transform: scale(0.92); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .spin-modal-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 0.5rem;
    }
    .spin-modal-name {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--content);
      margin: 0 0 1.5rem;
      word-break: break-word;
    }
    .spin-modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
    }
    .spin-btn {
      padding: 0.6rem 1.1rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .spin-btn:hover {
      background: var(--surface-3);
    }
    .spin-btn-primary {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }
    .spin-btn-primary:hover {
      background: var(--accent-2);
      border-color: var(--accent-2);
    }
    .spin-btn-ghost {
      padding: 0.6rem 1.1rem;
      border-radius: 8px;
      border: 0;
      background: transparent;
      color: var(--content-3);
      font-family: var(--font-sans);
      font-size: 14px;
      cursor: pointer;
    }
    .spin-btn-ghost:hover {
      color: var(--content);
    }

    /* Confetti overlay */
    .spin-confetti {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 60;
    }

    /* Mute toggle icon swap */
    .spin-mute-off { display: none; }
    .spin-icon-btn[aria-pressed="true"] .spin-mute-on { display: none; }
    .spin-icon-btn[aria-pressed="true"] .spin-mute-off { display: inline; }
    .spin-icon-btn[aria-pressed="true"] {
      color: var(--content-4);
    }

    /* Toast */
    .spin-toast {
      position: fixed;
      bottom: clamp(1rem, 3vw, 2rem);
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--content);
      color: var(--surface);
      padding: 0.6rem 1.1rem;
      border-radius: 999px;
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: -0.005em;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transition: opacity 0.2s var(--ease-out), transform 0.2s var(--ease-out);
      z-index: 80;
      pointer-events: none;
      max-width: 90vw;
      text-align: center;
    }
    .spin-toast.is-visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .spin-toast[hidden] {
      display: none;
    }

    /* Reduce motion */
    @media (prefers-reduced-motion: reduce) {
      .spin-modal,
      .spin-modal-card {
        animation: none;
      }
      .spin-confetti {
        display: none;
      }
    }
  </style>

  <script>
    type Entry = { id: string; label: string; color?: string };
    type Wheel = { id: string; name: string; entries: Entry[] };
    type PersistV1 = { entries: Entry[]; version: 1; muted?: boolean };
    type PersistV2 = { version: 2; wheels: Wheel[]; currentId: string; muted?: boolean };
    type AnyPersist = PersistV1 | PersistV2;

    const STORAGE_KEY = "spinwheel:v1";
    const MAX_WHEELS = 20;
    const MAX_WHEEL_NAME = 40;
    const DEFAULT_ENTRIES: Entry[] = [
      { id: "1", label: "Pizza" },
      { id: "2", label: "Tacos" },
      { id: "3", label: "Sushi" },
      { id: "4", label: "Ramen" },
      { id: "5", label: "Burger" },
      { id: "6", label: "Salad" },
    ];
    const PALETTE = [
      "#4850c4", // truffle indigo
      "#6a7d3b", // moss
      "#b07d2a", // amber
      "#a14a2a", // rust
      "#3b3527", // ink-2
      "#84785a", // paper-500
      "#5d68d0", // truffle-400
      "#3b41a3", // truffle-600
    ];

    const canvas = document.getElementById("spin-canvas") as HTMLCanvasElement | null;
    const centerBtn = document.getElementById("spin-center") as HTMLButtonElement | null;
    const list = document.getElementById("spin-list") as HTMLUListElement | null;
    const countEl = document.getElementById("spin-count");
    const addForm = document.getElementById("spin-add-form") as HTMLFormElement | null;
    const addInput = document.getElementById("spin-add-input") as HTMLInputElement | null;
    const bulkInput = document.getElementById("spin-bulk-input") as HTMLTextAreaElement | null;
    const bulkApply = document.getElementById("spin-bulk-apply");
    const shuffleBtn = document.getElementById("spin-shuffle");
    const resetBtn = document.getElementById("spin-reset");
    const shareBtn = document.getElementById("spin-share");
    const muteBtn = document.getElementById("spin-mute");
    const hintEl = document.getElementById("spin-hint");
    const modal = document.getElementById("spin-winner") as HTMLDivElement | null;
    const winnerName = document.getElementById("spin-winner-name");
    const removeBtn = document.getElementById("spin-winner-remove");
    const againBtn = document.getElementById("spin-winner-again");
    const closeBtn = document.getElementById("spin-winner-close");
    const confetti = document.getElementById("spin-confetti") as HTMLCanvasElement | null;
    const toast = document.getElementById("spin-toast") as HTMLDivElement | null;
    const pickerBtn = document.getElementById("spin-picker-btn") as HTMLButtonElement | null;
    const pickerName = document.getElementById("spin-picker-name");
    const pickerPanel = document.getElementById("spin-picker-panel") as HTMLDivElement | null;
    const pickerListEl = document.getElementById("spin-picker-list") as HTMLUListElement | null;
    const pickerNew = document.getElementById("spin-picker-new");
    const pickerRename = document.getElementById("spin-picker-rename");
    const pickerDupe = document.getElementById("spin-picker-dupe");
    const pickerDelete = document.getElementById("spin-picker-delete") as HTMLButtonElement | null;
    const pickerExport = document.getElementById("spin-picker-export");
    const pickerImport = document.getElementById("spin-picker-import");
    const importFileInput = document.getElementById("spin-import-file") as HTMLInputElement | null;
    const colorPicker = document.getElementById("spin-color-picker") as HTMLInputElement | null;

    if (!canvas || !centerBtn || !list || !addForm || !addInput || !modal) {
      console.error("[spin] missing required DOM nodes");
    }

    const ctx = canvas!.getContext("2d")!;
    const confettiCtx = confetti ? confetti.getContext("2d") : null;

    const initialState = loadState();
    let wheels: Wheel[] = initialState.wheels;
    let currentId: string = initialState.currentId;
    let muted: boolean = initialState.muted;

    function currentWheel(): Wheel {
      return wheels.find((w) => w.id === currentId) ?? wheels[0];
    }
    function currentEntries(): Entry[] {
      return currentWheel().entries;
    }

    // entries alias targets the active wheel
    let entries: Entry[] = currentEntries();
    let rotation = 0;
    let spinning = false;
    let lastWinnerIdx: number | null = null;

    function loadState(): { wheels: Wheel[]; currentId: string; muted: boolean } {
      const defaultWheel = (): Wheel => ({
        id: newId(),
        name: "My wheel",
        entries: [...DEFAULT_ENTRIES],
      });
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) {
          const w = defaultWheel();
          return { wheels: [w], currentId: w.id, muted: false };
        }
        const parsed = JSON.parse(raw) as AnyPersist;
        if (parsed && (parsed as PersistV2).version === 2 && Array.isArray((parsed as PersistV2).wheels)) {
          const p = parsed as PersistV2;
          const cleaned = p.wheels
            .filter((w) => w && typeof w.id === "string" && typeof w.name === "string" && Array.isArray(w.entries))
            .map((w) => ({
              id: w.id,
              name: w.name.slice(0, MAX_WHEEL_NAME) || "Untitled",
              entries: w.entries.filter((e) => e && typeof e.label === "string").slice(0, 200),
            }))
            .slice(0, MAX_WHEELS);
          if (cleaned.length === 0) {
            const w = defaultWheel();
            return { wheels: [w], currentId: w.id, muted: !!p.muted };
          }
          const cid = cleaned.find((w) => w.id === p.currentId)?.id ?? cleaned[0].id;
          return { wheels: cleaned, currentId: cid, muted: !!p.muted };
        }
        // v1 migration
        if (parsed && (parsed as PersistV1).version === 1 && Array.isArray((parsed as PersistV1).entries)) {
          const p = parsed as PersistV1;
          const w: Wheel = {
            id: newId(),
            name: "My wheel",
            entries: p.entries.filter((e) => e && typeof e.label === "string").slice(0, 200),
          };
          return { wheels: [w], currentId: w.id, muted: !!p.muted };
        }
      } catch {
        // fall through
      }
      const w = defaultWheel();
      return { wheels: [w], currentId: w.id, muted: false };
    }

    function save() {
      const cw = currentWheel();
      if (cw) cw.entries = entries;
      try {
        const data: PersistV2 = { version: 2, wheels, currentId, muted };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      } catch {
        // ignore quota
      }
    }

    function switchWheel(id: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      const w = wheels.find((x) => x.id === id);
      if (!w || w.id === currentId) {
        closePicker();
        return;
      }
      // Persist current wheel's edits before switching
      currentWheel().entries = entries;
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      closePicker();
      showToast(`Switched to ${w.name}`);
    }

    function createWheel(name?: string, withEntries?: Entry[]): Wheel | null {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return null;
      }
      if (wheels.length >= MAX_WHEELS) {
        showToast(`Max ${MAX_WHEELS} wheels`);
        return null;
      }
      const finalName = (name ?? "").trim().slice(0, MAX_WHEEL_NAME) || `Wheel ${wheels.length + 1}`;
      const w: Wheel = {
        id: newId(),
        name: finalName,
        entries: withEntries ?? [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))],
      };
      // Persist active wheel's current entries
      currentWheel().entries = entries;
      wheels.push(w);
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      return w;
    }

    function renameWheel(id: string, newName: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      const trimmed = newName.trim().slice(0, MAX_WHEEL_NAME);
      if (!trimmed) return;
      w.name = trimmed;
      save();
      renderPicker();
    }

    function duplicateWheel(id: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      if (wheels.length >= MAX_WHEELS) {
        showToast(`Max ${MAX_WHEELS} wheels`);
        return;
      }
      const copy: Wheel = {
        id: newId(),
        name: `${w.name} copy`.slice(0, MAX_WHEEL_NAME),
        entries: w.entries.map((e) => ({ ...e, id: newId() })),
      };
      // Persist active wheel's entries before insert
      currentWheel().entries = entries;
      wheels.push(copy);
      currentId = copy.id;
      entries = copy.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(`Duplicated to ${copy.name}`);
    }

    function deleteWheel(id: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      if (wheels.length <= 1) {
        showToast("Cannot delete the only wheel");
        return;
      }
      const idx = wheels.findIndex((x) => x.id === id);
      if (idx < 0) return;
      const wasCurrent = wheels[idx].id === currentId;
      const removedName = wheels[idx].name;
      wheels.splice(idx, 1);
      if (wasCurrent) {
        const nextIdx = Math.min(idx, wheels.length - 1);
        currentId = wheels[nextIdx].id;
        entries = wheels[nextIdx].entries;
        rotation = 0;
        lastWinnerIdx = null;
      }
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(`Deleted ${removedName}`);
    }

    function renderPicker() {
      if (!pickerListEl || !pickerName) return;
      const cw = currentWheel();
      pickerName.textContent = cw.name;
      pickerListEl.innerHTML = "";
      for (const w of wheels) {
        const li = document.createElement("li");
        li.setAttribute("role", "none");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "spin-picker-item";
        btn.setAttribute("role", "menuitem");
        if (w.id === currentId) btn.setAttribute("aria-current", "true");
        btn.innerHTML = `
          <svg class="spin-picker-item-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="spin-picker-item-name"></span>
          <span class="spin-picker-item-count"></span>
        `;
        (btn.querySelector(".spin-picker-item-name") as HTMLElement).textContent = w.name;
        (btn.querySelector(".spin-picker-item-count") as HTMLElement).textContent = String(w.entries.length);
        btn.addEventListener("click", () => switchWheel(w.id));
        li.appendChild(btn);
        pickerListEl.appendChild(li);
      }
      if (pickerDelete) pickerDelete.disabled = wheels.length <= 1;
    }

    function openPicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = false;
      pickerBtn.setAttribute("aria-expanded", "true");
      renderPicker();
    }
    function closePicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = true;
      pickerBtn.setAttribute("aria-expanded", "false");
    }
    function togglePicker() {
      if (!pickerPanel) return;
      if (pickerPanel.hidden) openPicker();
      else closePicker();
    }

    function newId(): string {
      return Math.random().toString(36).slice(2, 10);
    }

    function fitCanvas() {
      const rect = canvas!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const size = Math.floor(rect.width * dpr);
      if (canvas!.width !== size || canvas!.height !== size) {
        canvas!.width = size;
        canvas!.height = size;
      }
    }

    function drawWheel() {
      fitCanvas();
      const w = canvas!.width;
      const h = canvas!.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(cx, cy) - 2;

      ctx.clearRect(0, 0, w, h);

      if (entries.length === 0) {
        ctx.fillStyle = "rgba(132, 120, 90, 0.18)";
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = "rgba(132, 120, 90, 0.6)";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.font = `italic ${Math.round(r * 0.12)}px Fraunces, Georgia, serif`;
        ctx.fillText("Add an entry to begin", cx, cy);
        return;
      }

      const n = entries.length;
      const sliceAngle = (Math.PI * 2) / n;

      // Slices
      for (let i = 0; i < n; i++) {
        const start = rotation + i * sliceAngle - Math.PI / 2;
        const end = start + sliceAngle;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, start, end);
        ctx.closePath();
        ctx.fillStyle = entries[i].color || PALETTE[i % PALETTE.length];
        ctx.fill();
      }

      // Outer ring
      ctx.strokeStyle = "rgba(20, 17, 11, 0.18)";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.stroke();

      // Labels
      const fontSize = Math.max(11, Math.min(22, Math.round(r * 0.085)));
      ctx.font = `500 ${fontSize}px Inter, system-ui, sans-serif`;
      ctx.textBaseline = "middle";
      ctx.fillStyle = "#fff";
      ctx.shadowColor = "rgba(0, 0, 0, 0.25)";
      ctx.shadowBlur = 2;

      for (let i = 0; i < n; i++) {
        const mid = rotation + i * sliceAngle + sliceAngle / 2 - Math.PI / 2;
        const text = entries[i].label || "—";
        const labelR = r * 0.62;
        ctx.save();
        ctx.translate(cx + Math.cos(mid) * labelR, cy + Math.sin(mid) * labelR);
        ctx.rotate(mid + Math.PI / 2);
        ctx.textAlign = "center";
        const maxW = r * 0.55;
        const displayed = clipText(ctx, text, maxW);
        ctx.fillText(displayed, 0, 0);
        ctx.restore();
      }

      ctx.shadowBlur = 0;
    }

    function clipText(ctx: CanvasRenderingContext2D, text: string, maxW: number): string {
      if (ctx.measureText(text).width <= maxW) return text;
      let lo = 0, hi = text.length;
      while (lo < hi) {
        const mid = (lo + hi + 1) >>> 1;
        if (ctx.measureText(text.slice(0, mid) + "…").width <= maxW) lo = mid;
        else hi = mid - 1;
      }
      return text.slice(0, lo) + "…";
    }

    let colorPickerTarget: Entry | null = null;
    function openColorPicker(entry: Entry, current: string) {
      if (!colorPicker) return;
      colorPickerTarget = entry;
      // <input type="color"> expects #rrggbb
      colorPicker.value = toColorHex(current);
      colorPicker.click();
    }
    function toColorHex(c: string): string {
      const v = (c || "").trim().toLowerCase();
      if (/^#[0-9a-f]{6}$/.test(v)) return v;
      if (/^#[0-9a-f]{3}$/.test(v)) {
        return (
          "#" + v[1] + v[1] + v[2] + v[2] + v[3] + v[3]
        );
      }
      return "#4850c4";
    }
    if (colorPicker) {
      colorPicker.addEventListener("input", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        drawWheel();
      });
      colorPicker.addEventListener("change", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        renderList();
        drawWheel();
        save();
        colorPickerTarget = null;
      });
    }

    function renderList() {
      list!.innerHTML = "";
      countEl!.textContent = String(entries.length);
      entries.forEach((entry, i) => {
        const li = document.createElement("li");
        li.className = "spin-list-item";

        const color = document.createElement("button");
        color.type = "button";
        color.className = "spin-list-color";
        const auto = PALETTE[i % PALETTE.length];
        const effective = entry.color || auto;
        color.style.background = effective;
        color.style.color = effective;
        if (entry.color) color.dataset.custom = "true";
        color.title = entry.color
          ? "Click to change color · shift-click to reset"
          : "Click to choose a color";
        color.setAttribute(
          "aria-label",
          entry.color
            ? `Color for ${entry.label || "entry"}: custom. Shift-click to reset to auto.`
            : `Color for ${entry.label || "entry"}: auto. Click to choose.`,
        );
        color.addEventListener("click", (e) => {
          if ((e as MouseEvent).shiftKey) {
            if (entry.color) {
              entry.color = undefined;
              renderList();
              drawWheel();
              save();
            }
            return;
          }
          openColorPicker(entry, effective);
        });
        color.addEventListener("contextmenu", (e) => {
          if (!entry.color) return;
          e.preventDefault();
          entry.color = undefined;
          renderList();
          drawWheel();
          save();
        });
        li.appendChild(color);

        const input = document.createElement("input");
        input.type = "text";
        input.className = "spin-list-input";
        input.value = entry.label;
        input.maxLength = 80;
        input.dataset.id = entry.id;
        input.setAttribute("aria-label", `Entry ${i + 1}`);
        input.addEventListener("input", (e) => {
          entry.label = (e.target as HTMLInputElement).value;
          drawWheel();
          save();
        });
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            addInput!.focus();
          }
        });
        li.appendChild(input);

        const rm = document.createElement("button");
        rm.type = "button";
        rm.className = "spin-list-remove";
        rm.setAttribute("aria-label", `Remove ${entry.label}`);
        rm.innerHTML =
          '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        rm.addEventListener("click", () => {
          entries = entries.filter((e) => e.id !== entry.id);
          renderList();
          drawWheel();
          save();
        });
        li.appendChild(rm);

        list!.appendChild(li);
      });
    }

    function addEntry(label: string) {
      const clean = label.trim();
      if (!clean) return;
      entries.push({ id: newId(), label: clean });
      renderList();
      drawWheel();
      save();
    }

    addForm!.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = addInput!.value;
      addEntry(v);
      addInput!.value = "";
      addInput!.focus();
    });

    bulkApply!.addEventListener("click", () => {
      const raw = bulkInput!.value || "";
      const parts = raw
        .split(/[\n,]/)
        .map((s) => s.trim())
        .filter(Boolean)
        .slice(0, 200);
      if (parts.length === 0) return;
      entries = parts.map((label) => ({ id: newId(), label }));
      renderList();
      drawWheel();
      save();
      bulkInput!.value = "";
    });

    shuffleBtn!.addEventListener("click", () => {
      for (let i = entries.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [entries[i], entries[j]] = [entries[j], entries[i]];
      }
      renderList();
      drawWheel();
      save();
    });

    resetBtn!.addEventListener("click", () => {
      if (!confirm("Reset to the default entries?")) return;
      entries = [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))];
      renderList();
      drawWheel();
      save();
    });

    function easeOutCubicBezier(t: number): number {
      // Approximation of cubic-bezier(0.16, 1, 0.3, 1)
      const c = 1 - t;
      return 1 - c * c * c;
    }

    function spin() {
      if (spinning) return;
      if (entries.length === 0) {
        hintEl!.textContent = "Add at least one entry to spin.";
        return;
      }
      spinning = true;
      centerBtn!.disabled = true;

      // Prime / resume audio context on user gesture (mobile autoplay policy)
      if (!muted) {
        const c = getAudio();
        if (c && c.state === "suspended") {
          c.resume().catch(() => {});
        }
      }

      const n = entries.length;
      const sliceAngle = (Math.PI * 2) / n;

      // Pick winner uniformly, then compute target rotation so that
      // pointer (top, -PI/2) lands in the middle of the winning slice.
      const winnerIdx = Math.floor(Math.random() * n);
      const sliceMid = winnerIdx * sliceAngle + sliceAngle / 2;
      // Slice i is drawn from rotation + i*sliceAngle - PI/2 to next.
      // Pointer is at -PI/2 in absolute coords (top of canvas).
      // We want: pointer ∈ (rotation + winnerIdx*sliceAngle - PI/2,
      //                     rotation + (winnerIdx+1)*sliceAngle - PI/2)
      // Solve for rotation: rotation = -PI/2 - sliceMid + (-PI/2) ...
      // Simpler: want rotation + sliceMid - PI/2 ≡ -PI/2 (mod 2π)
      //   so rotation ≡ -sliceMid (mod 2π)
      const targetMod = ((-sliceMid) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
      // turns must be an integer; non-integer * 2π leaves a residual rotation
      // that desynchronises the wheel from the chosen winner.
      const turns = 5 + Math.floor(Math.random() * 3); // 5, 6, or 7 full turns
      const currentMod = ((rotation % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
      let deltaToTarget = targetMod - currentMod;
      if (deltaToTarget <= 0) deltaToTarget += Math.PI * 2;
      const totalDelta = turns * Math.PI * 2 + deltaToTarget;
      // Add jitter within slice (90% inside center)
      const jitter = (Math.random() - 0.5) * sliceAngle * 0.7;
      const totalDeltaJittered = totalDelta + jitter;

      const startRotation = rotation;
      const duration = 5200 + Math.random() * 800; // 5.2 - 6s
      const startTs = performance.now();

      hintEl!.textContent = "Spinning…";

      let lastSliceIdx = -1;
      const twoPi = Math.PI * 2;

      function frame(now: number) {
        const t = Math.min(1, (now - startTs) / duration);
        const eased = easeOutCubicBezier(t);
        rotation = startRotation + totalDeltaJittered * eased;
        drawWheel();

        // Tick whenever the pointer crosses a slice boundary
        const norm = ((-rotation % twoPi) + twoPi) % twoPi;
        const curSlice = Math.floor(norm / sliceAngle) % n;
        if (curSlice !== lastSliceIdx) {
          lastSliceIdx = curSlice;
          // Skip the very first frame so we don't double-tick at t=0
          if (now - startTs > 30) tick();
        }

        if (t < 1) {
          requestAnimationFrame(frame);
        } else {
          spinning = false;
          centerBtn!.disabled = false;
          lastWinnerIdx = winnerIdx;
          fanfare();
          // Burst from the canvas center on screen for a wheel-anchored feel
          let originX: number | undefined;
          let originY: number | undefined;
          if (canvas) {
            const r = canvas.getBoundingClientRect();
            originX = r.left + r.width / 2;
            originY = r.top + r.height / 2;
          }
          burstConfetti(originX, originY);
          showWinner(entries[winnerIdx]);
        }
      }
      requestAnimationFrame(frame);
    }

    function showWinner(entry: Entry) {
      winnerName!.textContent = entry.label;
      modal!.hidden = false;
      modal!.setAttribute("aria-hidden", "false");
      hintEl!.textContent = `Winner: ${entry.label}`;
      // Focus the primary action for keyboard users
      (againBtn as HTMLButtonElement).focus();
    }

    function hideWinner() {
      modal!.hidden = true;
      modal!.setAttribute("aria-hidden", "true");
    }

    centerBtn!.addEventListener("click", spin);

    againBtn!.addEventListener("click", () => {
      hideWinner();
      spin();
    });

    removeBtn!.addEventListener("click", () => {
      if (lastWinnerIdx !== null && entries[lastWinnerIdx]) {
        const removedId = entries[lastWinnerIdx].id;
        entries = entries.filter((e) => e.id !== removedId);
        renderList();
        save();
      }
      hideWinner();
      drawWheel();
      if (entries.length > 0) spin();
    });

    closeBtn!.addEventListener("click", hideWinner);

    modal!.addEventListener("click", (e) => {
      if (e.target === modal) hideWinner();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !modal!.hidden) {
        hideWinner();
        return;
      }
      if (e.key === " " && !modal!.hidden) return;
      const tag = (document.activeElement?.tagName || "").toLowerCase();
      if (tag === "input" || tag === "textarea") return;
      if (e.key === " " || e.code === "Space") {
        e.preventDefault();
        if (!spinning) spin();
      }
    });

    window.addEventListener("resize", () => {
      drawWheel();
      fitConfetti();
    });

    // === Web Audio (lazy) ===
    let audioCtx: AudioContext | null = null;
    function getAudio(): AudioContext | null {
      if (audioCtx) return audioCtx;
      try {
        const AC =
          (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!AC) return null;
        audioCtx = new AC();
      } catch {
        audioCtx = null;
      }
      return audioCtx;
    }

    function tick() {
      if (muted) return;
      const c = getAudio();
      if (!c) return;
      const t = c.currentTime;
      const osc = c.createOscillator();
      const gain = c.createGain();
      osc.type = "triangle";
      osc.frequency.value = 720 + Math.random() * 220;
      gain.gain.setValueAtTime(0, t);
      gain.gain.linearRampToValueAtTime(0.045, t + 0.004);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.065);
      osc.connect(gain).connect(c.destination);
      osc.start(t);
      osc.stop(t + 0.08);
    }

    function fanfare() {
      if (muted) return;
      const c = getAudio();
      if (!c) return;
      // C5, E5, G5, C6 — a small bright ascent
      const notes = [523.25, 659.25, 783.99, 1046.5];
      const t0 = c.currentTime;
      notes.forEach((freq, i) => {
        const t = t0 + i * 0.08;
        const osc = c.createOscillator();
        const gain = c.createGain();
        osc.type = "sine";
        osc.frequency.value = freq;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.11, t + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.45);
        osc.connect(gain).connect(c.destination);
        osc.start(t);
        osc.stop(t + 0.5);
      });
    }

    function updateMuteBtn() {
      if (!muteBtn) return;
      muteBtn.setAttribute("aria-pressed", muted ? "true" : "false");
      muteBtn.setAttribute("title", muted ? "Unmute sound" : "Mute sound");
      muteBtn.setAttribute(
        "aria-label",
        muted ? "Unmute sound" : "Mute sound",
      );
    }

    // === Confetti ===
    type Particle = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      rot: number;
      vr: number;
      size: number;
      color: string;
      life: number;
      shape: number;
    };
    let particles: Particle[] = [];
    let confettiActive = false;
    let confettiDpr = 1;

    function fitConfetti() {
      if (!confetti) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      confettiDpr = dpr;
      const w = window.innerWidth;
      const h = window.innerHeight;
      confetti.width = Math.floor(w * dpr);
      confetti.height = Math.floor(h * dpr);
      confetti.style.width = w + "px";
      confetti.style.height = h + "px";
    }

    function burstConfetti(originX?: number, originY?: number) {
      if (!confetti || !confettiCtx) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      fitConfetti();
      const cx = originX ?? window.innerWidth / 2;
      const cy = originY ?? window.innerHeight / 2;
      const count = 140;
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 6 + Math.random() * 11;
        particles.push({
          x: cx,
          y: cy,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 5,
          rot: Math.random() * Math.PI * 2,
          vr: (Math.random() - 0.5) * 0.5,
          size: 5 + Math.random() * 9,
          color: PALETTE[Math.floor(Math.random() * PALETTE.length)],
          life: 1,
          shape: Math.random() < 0.55 ? 0 : 1,
        });
      }
      if (!confettiActive) {
        confettiActive = true;
        requestAnimationFrame(confettiFrame);
      }
    }

    function confettiFrame() {
      if (!confetti || !confettiCtx) {
        confettiActive = false;
        return;
      }
      const w = window.innerWidth;
      const h = window.innerHeight;
      confettiCtx.setTransform(confettiDpr, 0, 0, confettiDpr, 0, 0);
      confettiCtx.clearRect(0, 0, w, h);
      const gravity = 0.27;
      const drag = 0.992;
      let alive: Particle[] = [];
      for (const p of particles) {
        p.vy += gravity;
        p.vx *= drag;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        p.life -= 1 / 220;
        if (p.life <= 0 || p.y > h + 40) continue;
        alive.push(p);
        confettiCtx.save();
        confettiCtx.globalAlpha = Math.min(1, p.life * 1.6);
        confettiCtx.translate(p.x, p.y);
        confettiCtx.rotate(p.rot);
        confettiCtx.fillStyle = p.color;
        if (p.shape === 0) {
          confettiCtx.fillRect(-p.size / 2, -p.size / 3, p.size, p.size / 1.6);
        } else {
          confettiCtx.beginPath();
          confettiCtx.arc(0, 0, p.size / 2.4, 0, Math.PI * 2);
          confettiCtx.fill();
        }
        confettiCtx.restore();
      }
      particles = alive;
      if (alive.length > 0) {
        requestAnimationFrame(confettiFrame);
      } else {
        confettiActive = false;
        confettiCtx.clearRect(0, 0, w, h);
      }
    }

    // === Share link ===
    function buildShareUrl(): string {
      const cw = currentWheel();
      const limited = entries.slice(0, 200);
      const payload: { n: string; e: string[]; c?: (string | null)[] } = {
        n: cw.name.slice(0, MAX_WHEEL_NAME),
        e: limited.map((x) => x.label),
      };
      if (limited.some((x) => x.color)) {
        payload.c = limited.map((x) => x.color || null);
      }
      const json = JSON.stringify(payload);
      const b64 = btoa(unescape(encodeURIComponent(json)))
        .replace(/\+/g, "-")
        .replace(/\//g, "_")
        .replace(/=+$/, "");
      return `${location.origin}/spin/?w=${b64}`;
    }

    function tryDecodeShareParam(): { name: string; entries: Entry[] } | null {
      try {
        const params = new URLSearchParams(location.search);
        const w = params.get("w");
        if (!w) return null;
        let b64 = w.replace(/-/g, "+").replace(/_/g, "/");
        while (b64.length % 4 !== 0) b64 += "=";
        const json = decodeURIComponent(escape(atob(b64)));
        const parsed = JSON.parse(json);
        if (!parsed || !Array.isArray(parsed.e)) return null;
        const rawColors: unknown[] = Array.isArray(parsed.c) ? parsed.c : [];
        const out: Entry[] = [];
        for (let i = 0; i < Math.min(parsed.e.length, 200); i++) {
          const raw = parsed.e[i];
          if (typeof raw !== "string") continue;
          const label = raw.trim();
          if (label.length === 0 || label.length > 80) continue;
          const e: Entry = { id: newId(), label };
          const rc = rawColors[i];
          if (typeof rc === "string" && /^#[0-9a-fA-F]{6}$/.test(rc)) {
            e.color = rc.toLowerCase();
          }
          out.push(e);
        }
        if (out.length === 0) return null;
        const rawName = typeof parsed.n === "string" ? parsed.n.trim() : "";
        const name = rawName.slice(0, MAX_WHEEL_NAME) || "Shared wheel";
        return { name, entries: out };
      } catch {
        return null;
      }
    }

    async function copyShareLink() {
      if (entries.length === 0) {
        showToast("Add an entry first");
        return;
      }
      const url = buildShareUrl();
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(url);
          showToast("Share link copied");
        } else {
          // Fallback for non-secure contexts
          const ta = document.createElement("textarea");
          ta.value = url;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          showToast("Share link copied");
        }
      } catch {
        showToast("Could not copy. URL: " + url.slice(0, 40) + "…");
      }
    }

    // === Toast ===
    let toastTimer: number | null = null;
    function showToast(msg: string) {
      if (!toast) return;
      toast.textContent = msg;
      toast.hidden = false;
      // Force reflow so the transition fires
      void toast.offsetWidth;
      toast.classList.add("is-visible");
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove("is-visible");
        window.setTimeout(() => {
          if (toast && !toast.classList.contains("is-visible")) {
            toast.hidden = true;
          }
        }, 220);
      }, 2200);
    }

    // === Wire new buttons ===
    if (shareBtn) {
      shareBtn.addEventListener("click", () => {
        copyShareLink();
      });
    }
    if (muteBtn) {
      muteBtn.addEventListener("click", () => {
        muted = !muted;
        save();
        updateMuteBtn();
        showToast(muted ? "Sound off" : "Sound on");
      });
    }

    // === Wheel picker wiring ===
    if (pickerBtn) {
      pickerBtn.addEventListener("click", (e) => {
        e.stopPropagation();
        togglePicker();
      });
    }
    document.addEventListener("click", (e) => {
      if (!pickerPanel || pickerPanel.hidden) return;
      const t = e.target as Node | null;
      if (t && (pickerPanel.contains(t) || pickerBtn?.contains(t))) return;
      closePicker();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && pickerPanel && !pickerPanel.hidden) {
        closePicker();
        pickerBtn?.focus();
      }
    });
    if (pickerNew) {
      pickerNew.addEventListener("click", () => {
        closePicker();
        const name = window.prompt("Name for the new wheel?", `Wheel ${wheels.length + 1}`);
        if (name === null) return;
        const created = createWheel(name, []);
        if (created) showToast(`Created ${created.name}`);
      });
    }
    if (pickerRename) {
      pickerRename.addEventListener("click", () => {
        closePicker();
        const cw = currentWheel();
        const name = window.prompt("Rename wheel:", cw.name);
        if (name === null) return;
        const trimmed = name.trim();
        if (!trimmed) return;
        renameWheel(cw.id, trimmed);
        showToast("Renamed");
      });
    }
    if (pickerDupe) {
      pickerDupe.addEventListener("click", () => {
        closePicker();
        duplicateWheel(currentId);
      });
    }
    if (pickerDelete) {
      pickerDelete.addEventListener("click", () => {
        closePicker();
        const cw = currentWheel();
        if (wheels.length <= 1) {
          showToast("Cannot delete the only wheel");
          return;
        }
        if (!confirm(`Delete "${cw.name}"? This cannot be undone.`)) return;
        deleteWheel(cw.id);
      });
    }
    if (pickerExport) {
      pickerExport.addEventListener("click", () => {
        closePicker();
        exportAllWheels();
      });
    }
    if (pickerImport) {
      pickerImport.addEventListener("click", () => {
        closePicker();
        importFileInput?.click();
      });
    }
    if (importFileInput) {
      importFileInput.addEventListener("change", async () => {
        const file = importFileInput.files?.[0];
        if (!file) return;
        try {
          const text = await file.text();
          importFromJson(text);
        } catch {
          showToast("Could not read file");
        }
        importFileInput.value = "";
      });
    }

    function exportAllWheels() {
      const payload = {
        format: "spinwheel",
        version: 2,
        exportedAt: new Date().toISOString(),
        wheels: wheels.map((w) => ({
          name: w.name,
          entries: w.entries.map((e) =>
            e.color ? { label: e.label, color: e.color } : e.label,
          ),
        })),
      };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      const stamp = new Date().toISOString().slice(0, 10);
      a.href = url;
      a.download = `spinwheel-export-${stamp}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 1500);
      showToast(`Exported ${wheels.length} wheel${wheels.length === 1 ? "" : "s"}`);
    }

    function importFromJson(text: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      let parsed: unknown;
      try {
        parsed = JSON.parse(text);
      } catch {
        showToast("Not valid JSON");
        return;
      }
      // Accept either the full export shape or a single wheel
      type ImportEntry = { label: string; color?: string };
      const incoming: { name: string; entries: ImportEntry[] }[] = [];
      const p = parsed as { wheels?: unknown; name?: unknown; entries?: unknown };
      const normalizeEntries = (raw: unknown[]): ImportEntry[] => {
        const out: ImportEntry[] = [];
        for (const e of raw) {
          let label: string | null = null;
          let color: string | undefined;
          if (typeof e === "string") {
            label = e;
          } else if (e && typeof e === "object") {
            const obj = e as { label?: unknown; color?: unknown };
            if (typeof obj.label === "string") label = obj.label;
            if (typeof obj.color === "string" && /^#[0-9a-fA-F]{6}$/.test(obj.color)) {
              color = obj.color.toLowerCase();
            }
          }
          if (label === null) continue;
          const trimmed = label.trim();
          if (trimmed.length === 0 || trimmed.length > 80) continue;
          out.push(color ? { label: trimmed, color } : { label: trimmed });
          if (out.length >= 200) break;
        }
        return out;
      };
      if (Array.isArray(p?.wheels)) {
        for (const raw of p.wheels) {
          const w = raw as { name?: unknown; entries?: unknown };
          if (!Array.isArray(w?.entries)) continue;
          const items = normalizeEntries(w.entries as unknown[]);
          if (items.length === 0) continue;
          const name = typeof w.name === "string" ? w.name.slice(0, MAX_WHEEL_NAME) : "Imported";
          incoming.push({ name: name || "Imported", entries: items });
        }
      } else if (Array.isArray(p?.entries)) {
        const items = normalizeEntries(p.entries as unknown[]);
        if (items.length > 0) {
          const name = typeof p.name === "string" ? p.name.slice(0, MAX_WHEEL_NAME) : "Imported";
          incoming.push({ name: name || "Imported", entries: items });
        }
      }
      if (incoming.length === 0) {
        showToast("No wheels found in file");
        return;
      }
      const slots = MAX_WHEELS - wheels.length;
      const toAdd = incoming.slice(0, Math.max(0, slots));
      if (toAdd.length === 0) {
        showToast(`Max ${MAX_WHEELS} wheels — make room first`);
        return;
      }
      // Persist active wheel's edits before appending
      currentWheel().entries = entries;
      const existing = new Set(wheels.map((w) => w.name));
      let last: Wheel | null = null;
      for (const w of toAdd) {
        let name = w.name;
        let n = 2;
        while (existing.has(name)) name = `${w.name} (${n++})`;
        existing.add(name);
        const wheel: Wheel = {
          id: newId(),
          name,
          entries: w.entries.map((it) =>
            it.color ? { id: newId(), label: it.label, color: it.color } : { id: newId(), label: it.label },
          ),
        };
        wheels.push(wheel);
        last = wheel;
      }
      if (last) {
        currentId = last.id;
        entries = last.entries;
        rotation = 0;
        lastWinnerIdx = null;
      }
      save();
      renderPicker();
      renderList();
      drawWheel();
      const skipped = incoming.length - toAdd.length;
      showToast(
        skipped > 0
          ? `Imported ${toAdd.length} wheel${toAdd.length === 1 ? "" : "s"} (${skipped} skipped: max reached)`
          : `Imported ${toAdd.length} wheel${toAdd.length === 1 ? "" : "s"}`,
      );
    }

    // === Init: handle ?w= shared wheel + apply settings ===
    (function initFromUrl() {
      const shared = tryDecodeShareParam();
      if (shared && shared.entries.length > 0) {
        // Import as a NEW wheel so existing wheels are never clobbered
        const created = createWheel(shared.name, shared.entries);
        // Strip ?w= to keep the URL clean for further sharing
        try {
          const url = new URL(location.href);
          url.searchParams.delete("w");
          history.replaceState({}, "", url.toString());
        } catch {
          // ignore
        }
        if (created) {
          setTimeout(() => showToast(`Imported "${created.name}"`), 300);
        }
      }
    })();

    updateMuteBtn();
    fitConfetti();
    renderPicker();
    renderList();
    drawWheel();
  </script>
</BaseLayout>
