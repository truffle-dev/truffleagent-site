    function exportAllWheels() {
      const payload = {
        format: "spinwheel",
        version: 2,
        exportedAt: new Date().toISOString(),
        wheels: wheels.map((w) => ({
          name: w.name,
          entries: w.entries.map((e) => {
            const heavyWeight = (e.weight || 1) > 1;
            const hasWins = (e.wins || 0) > 0;
            if (!e.color && !heavyWeight && !hasWins) return e.label;
            const obj: { label: string; color?: string; weight?: number; wins?: number } = { label: e.label };
            if (e.color) obj.color = e.color;
            if (heavyWeight) obj.weight = e.weight;
            if (hasWins) obj.wins = e.wins;
            return obj;
          }),
        })),
      };
      const blob = new Blob([JSON.stringify(payload, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      const stamp = new Date().toISOString().slice(0, 10);
      a.href = url;
      a.download = `spinwheel-export-${stamp}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 1500);
      showToast(`Exported ${wheels.length} wheel${wheels.length === 1 ? "" : "s"}`);
    }

    function importFromJson(text: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      let parsed: unknown;
      try {
        parsed = JSON.parse(text);
      } catch {
        showToast("Not valid JSON");
        return;
      }
      // Accept either the full export shape or a single wheel
      type ImportEntry = { label: string; color?: string; weight?: number; wins?: number };
      const incoming: { name: string; entries: ImportEntry[] }[] = [];
      const p = parsed as { wheels?: unknown; name?: unknown; entries?: unknown };
      const normalizeEntries = (raw: unknown[]): ImportEntry[] => {
        const out: ImportEntry[] = [];
        for (const e of raw) {
          let label: string | null = null;
          let color: string | undefined;
          let weight: number | undefined;
          let wins: number | undefined;
          if (typeof e === "string") {
            label = e;
          } else if (e && typeof e === "object") {
            const obj = e as { label?: unknown; color?: unknown; weight?: unknown; wins?: unknown };
            if (typeof obj.label === "string") label = obj.label;
            if (typeof obj.color === "string" && /^#[0-9a-fA-F]{6}$/.test(obj.color)) {
              color = obj.color.toLowerCase();
            }
            if (typeof obj.weight === "number" && Number.isFinite(obj.weight)) {
              const wv = Math.max(1, Math.min(10, Math.round(obj.weight)));
              if (wv > 1) weight = wv;
            }
            if (typeof obj.wins === "number" && Number.isFinite(obj.wins) && obj.wins > 0) {
              wins = Math.max(0, Math.min(9999, Math.floor(obj.wins)));
            }
          }
          if (label === null) continue;
          const trimmed = label.trim();
          if (trimmed.length === 0 || trimmed.length > 80) continue;
          const entry: ImportEntry = { label: trimmed };
          if (color) entry.color = color;
          if (weight) entry.weight = weight;
          if (wins) entry.wins = wins;
          out.push(entry);
          if (out.length >= 200) break;
        }
        return out;
      };
      if (Array.isArray(p?.wheels)) {
        for (const raw of p.wheels) {
          const w = raw as { name?: unknown; entries?: unknown };
          if (!Array.isArray(w?.entries)) continue;
          const items = normalizeEntries(w.entries as unknown[]);
          if (items.length === 0) continue;
          const name = typeof w.name === "string" ? w.name.slice(0, MAX_WHEEL_NAME) : "Imported";
          incoming.push({ name: name || "Imported", entries: items });
        }
      } else if (Array.isArray(p?.entries)) {
        const items = normalizeEntries(p.entries as unknown[]);
        if (items.length > 0) {
          const name = typeof p.name === "string" ? p.name.slice(0, MAX_WHEEL_NAME) : "Imported";
          incoming.push({ name: name || "Imported", entries: items });
        }
      }
      if (incoming.length === 0) {
        showToast("No wheels found in file");
        return;
      }
      const slots = MAX_WHEELS - wheels.length;
      const toAdd = incoming.slice(0, Math.max(0, slots));
      if (toAdd.length === 0) {
        showToast(`Max ${MAX_WHEELS} wheels — make room first`);
        return;
      }
      // Persist active wheel's edits before appending
      currentWheel().entries = entries;
      const existing = new Set(wheels.map((w) => w.name));
      let last: Wheel | null = null;
      for (const w of toAdd) {
        let name = w.name;
        let n = 2;
        while (existing.has(name)) name = `${w.name} (${n++})`;
        existing.add(name);
        const wheel: Wheel = {
          id: newId(),
          name,
          entries: w.entries.map((it) => {
            const e: Entry = { id: newId(), label: it.label };
            if (it.color) e.color = it.color;
            if (it.weight) e.weight = it.weight;
            if (it.wins) e.wins = it.wins;
            return e;
          }),
        };
        wheels.push(wheel);
        last = wheel;
      }
      if (last) {
        currentId = last.id;
        entries = last.entries;
        rotation = 0;
        lastWinnerIdx = null;
      }
      save();
      renderPicker();
      renderList();
      drawWheel();
      const skipped = incoming.length - toAdd.length;
      showToast(
        skipped > 0
          ? `Imported ${toAdd.length} wheel${toAdd.length === 1 ? "" : "s"} (${skipped} skipped: max reached)`
          : `Imported ${toAdd.length} wheel${toAdd.length === 1 ? "" : "s"}`,
      );
    }

    // === Init: handle ?w= shared wheel + apply settings ===
    (function initFromUrl() {
      const shared = tryDecodeShareParam();
      if (IS_EMBED) {
        // Embed mode: never persist; use shared state in memory if present,
        // otherwise the seeded default wheel. Don't strip ?w= — preserves
        // identity if a visitor copies the URL.
        if (shared && shared.entries.length > 0) {
          const w: Wheel = { id: "embed", name: shared.name, entries: shared.entries };
          wheels = [w];
          currentId = w.id;
          entries = w.entries;
        }
        return;
      }
      if (shared && shared.entries.length > 0) {
        // Import as a NEW wheel so existing wheels are never clobbered
        const created = createWheel(shared.name, shared.entries);
        // Strip ?w= to keep the URL clean for further sharing. Use
        // window.history because a local `history` array shadows the
        // DOM global inside this script scope.
        try {
          const url = new URL(location.href);
          url.searchParams.delete("w");
          window.history.replaceState({}, "", url.toString());
        } catch {
          // ignore
        }
        if (created) {
          // Mark + persist so the picker shows a "shared" pill until the
          // user edits. Auto-clears on label edit, add/remove/move, bulk
          // paste, reset, or rename via clearImportFlag().
          created.importedFromShare = true;
          save();
          renderPicker();
          setTimeout(() => showToast(`Imported "${created.name}"`), 300);
        }
      } else if (hasShareParam()) {
        // ?w= present but decoding failed (truncated link, mangled base64,
        // missing entries). Strip it so the URL stops carrying broken state
        // and tell the recipient instead of silently dropping to the default.
        try {
          const url = new URL(location.href);
          url.searchParams.delete("w");
          window.history.replaceState({}, "", url.toString());
        } catch {
          // ignore
        }
        setTimeout(() => showToast("Couldn't read shared wheel link"), 300);
      }
    })();

    if (IS_EMBED) {
      document.querySelector(".spin-page")?.classList.add("spin-is-embed");
    }

    updateMuteBtn();
    updateEliminateBtn();
    updateAccumulateBtn();
    updatePickerResetCounts();
    fitConfetti();
    renderPicker();
    renderList();
    renderHistory();
    drawWheel();
    if (teamsBtn) setTeamCount(getTeamCount());
    applyPointer();
    applyLabelRotation();
    renderPaletteChips();
    applyWheelSize();

    if (historyClear) {
      historyClear.addEventListener("click", () => {
        if (history.length === 0) return;
        history = [];
        saveHistory();
        renderHistory();
        showToast("History cleared");
      });
    }

    // === Feature-request wiring ===
    const suggestForm = document.getElementById("spin-suggest-form") as HTMLFormElement | null;
    const suggestText = document.getElementById("spin-suggest-text") as HTMLTextAreaElement | null;
    const suggestEmail = document.getElementById("spin-suggest-email") as HTMLInputElement | null;
    const suggestStatus = document.getElementById("spin-suggest-status");
    const suggestCopy = document.getElementById("spin-suggest-copy");
    const SUGGEST_ADDR = "truffle@truffleagent.com";

    function setSuggestStatus(message: string, tone: "ok" | "warn" | "" = "") {
      if (!suggestStatus) return;
      suggestStatus.textContent = message;
      if (tone) suggestStatus.setAttribute("data-tone", tone);
      else suggestStatus.removeAttribute("data-tone");
    }

    function copyToClipboard(text: string): Promise<boolean> {
      if (navigator.clipboard && window.isSecureContext) {
        return navigator.clipboard
          .writeText(text)
          .then(() => true)
          .catch(() => fallbackCopy(text));
      }
      return Promise.resolve(fallbackCopy(text));
    }
    function fallbackCopy(text: string): boolean {
      try {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        const ok = document.execCommand("copy");
        document.body.removeChild(ta);
        return ok;
      } catch {
        return false;
      }
    }

    if (suggestForm) {
      suggestForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const body = (suggestText?.value || "").trim();
        if (!body) {
          setSuggestStatus("Type an idea first.", "warn");
          suggestText?.focus();
          return;
        }
        const reply = (suggestEmail?.value || "").trim();
        const wheel = currentWheel();
        const wheelName = wheel?.name || "unnamed";
        const subject = `[/spin/] feature request — ${wheelName}`;
        const lines = [
          body,
          "",
          "---",
          `Wheel: ${wheelName}`,
          `Entries: ${entries.length}`,
          reply ? `Reply to: ${reply}` : "Reply to: (not provided)",
        ];
        const mailto =
          `mailto:${SUGGEST_ADDR}` +
          `?subject=${encodeURIComponent(subject)}` +
          `&body=${encodeURIComponent(lines.join("\n"))}`;
        window.location.href = mailto;
        setSuggestStatus(
          "Opened your mail app. If nothing happened, use Copy email instead.",
          "ok",
        );
      });
    }
    if (suggestCopy) {
      suggestCopy.addEventListener("click", () => {
        copyToClipboard(SUGGEST_ADDR).then((ok) => {
          setSuggestStatus(
            ok ? `Copied ${SUGGEST_ADDR}.` : `Email me at ${SUGGEST_ADDR}.`,
            ok ? "ok" : "warn",
          );
        });
      });
    }
  </script>
</BaseLayout>
