    // Screen angle (radians) where the pointer apex meets the wheel edge.
    // Top pointer is at -PI/2 (12 o'clock); right pointer is at 0 (3 o'clock).
    function pointerScreenAngle(): number {
      return pointerCfg.pos === "right" ? 0 : -Math.PI / 2;
    }

    const POINTER_COLOR_VAR: Record<PointerColor, string> = {
      ink: "var(--content)",
