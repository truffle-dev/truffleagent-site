    // === Confetti ===
    type Particle = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      rot: number;
      vr: number;
      size: number;
      color: string;
      life: number;
      shape: number;
    };
    let particles: Particle[] = [];
    let confettiActive = false;
    let confettiDpr = 1;

    function fitConfetti() {
      if (!confetti) return;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      confettiDpr = dpr;
      const w = window.innerWidth;
      const h = window.innerHeight;
      confetti.width = Math.floor(w * dpr);
      confetti.height = Math.floor(h * dpr);
      confetti.style.width = w + "px";
      confetti.style.height = h + "px";
    }

    function burstConfetti(originX?: number, originY?: number) {
      if (!confetti || !confettiCtx) return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      fitConfetti();
      const cx = originX ?? window.innerWidth / 2;
      const cy = originY ?? window.innerHeight / 2;
      const count = 140;
      const pal = activePalette();
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = 6 + Math.random() * 11;
        particles.push({
          x: cx,
          y: cy,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed - 5,
          rot: Math.random() * Math.PI * 2,
          vr: (Math.random() - 0.5) * 0.5,
          size: 5 + Math.random() * 9,
          color: pal[Math.floor(Math.random() * pal.length)],
          life: 1,
          shape: Math.random() < 0.55 ? 0 : 1,
        });
      }
      if (!confettiActive) {
        confettiActive = true;
        requestAnimationFrame(confettiFrame);
      }
    }

    function confettiFrame() {
      if (!confetti || !confettiCtx) {
        confettiActive = false;
        return;
      }
      const w = window.innerWidth;
      const h = window.innerHeight;
      confettiCtx.setTransform(confettiDpr, 0, 0, confettiDpr, 0, 0);
      confettiCtx.clearRect(0, 0, w, h);
      const gravity = 0.27;
      const drag = 0.992;
      let alive: Particle[] = [];
      for (const p of particles) {
        p.vy += gravity;
        p.vx *= drag;
        p.x += p.vx;
        p.y += p.vy;
        p.rot += p.vr;
        p.life -= 1 / 220;
        if (p.life <= 0 || p.y > h + 40) continue;
        alive.push(p);
        confettiCtx.save();
        confettiCtx.globalAlpha = Math.min(1, p.life * 1.6);
        confettiCtx.translate(p.x, p.y);
        confettiCtx.rotate(p.rot);
        confettiCtx.fillStyle = p.color;
        if (p.shape === 0) {
          confettiCtx.fillRect(-p.size / 2, -p.size / 3, p.size, p.size / 1.6);
        } else {
          confettiCtx.beginPath();
          confettiCtx.arc(0, 0, p.size / 2.4, 0, Math.PI * 2);
          confettiCtx.fill();
        }
        confettiCtx.restore();
      }
      particles = alive;
      if (alive.length > 0) {
        requestAnimationFrame(confettiFrame);
      } else {
        confettiActive = false;
        confettiCtx.clearRect(0, 0, w, h);
      }
    }

    // === Share link ===
    function buildShareUrl(): string {
      const cw = currentWheel();
      const limited = entries.slice(0, 200);
      const payload: { n: string; e: string[]; c?: (string | null)[]; w?: number[] } = {
        n: cw.name.slice(0, MAX_WHEEL_NAME),
        e: limited.map((x) => x.label),
      };
      if (limited.some((x) => x.color)) {
        payload.c = limited.map((x) => x.color || null);
      }
      if (limited.some((x) => (x.weight || 1) > 1)) {
        payload.w = limited.map((x) => x.weight || 1);
      }
      const json = JSON.stringify(payload);
      const b64 = btoa(unescape(encodeURIComponent(json)))
        .replace(/\+/g, "-")
        .replace(/\//g, "_")
        .replace(/=+$/, "");
      // Emit the share-route form so OG crawlers (Twitter, Discord,
      // Slack, iMessage) get a per-wheel preview card. The
      // /spin/share/<payload>/ Function returns HTML whose og:image
      // points at /spin/og?w=<payload> and then redirects humans to
      // /spin/?w=<payload>. Old /spin/?w=<payload> links still work
      // because tryDecodeShareParam still reads ?w= from search.
      return `${location.origin}/spin/share/${b64}/`;
    }

    function hasShareParam(): boolean {
      try {
        const v = new URLSearchParams(location.search).get("w");
        return v !== null && v.length > 0;
      } catch {
        return false;
      }
    }

    function tryDecodeShareParam(): { name: string; entries: Entry[] } | null {
      try {
        const params = new URLSearchParams(location.search);
        const w = params.get("w");
        if (!w) return null;
        let b64 = w.replace(/-/g, "+").replace(/_/g, "/");
        while (b64.length % 4 !== 0) b64 += "=";
        const json = decodeURIComponent(escape(atob(b64)));
        const parsed = JSON.parse(json);
        if (!parsed || !Array.isArray(parsed.e)) return null;
        const rawColors: unknown[] = Array.isArray(parsed.c) ? parsed.c : [];
        const rawWeights: unknown[] = Array.isArray(parsed.w) ? parsed.w : [];
        const out: Entry[] = [];
        for (let i = 0; i < Math.min(parsed.e.length, 200); i++) {
          const raw = parsed.e[i];
          if (typeof raw !== "string") continue;
          const label = raw.trim();
          if (label.length === 0 || label.length > 80) continue;
          const e: Entry = { id: newId(), label };
          const rc = rawColors[i];
          if (typeof rc === "string" && /^#[0-9a-fA-F]{6}$/.test(rc)) {
            e.color = rc.toLowerCase();
          }
          const rw = rawWeights[i];
          if (typeof rw === "number" && Number.isFinite(rw)) {
            const wv = Math.max(1, Math.min(10, Math.round(rw)));
            if (wv > 1) e.weight = wv;
          }
          out.push(e);
        }
        if (out.length === 0) return null;
        const rawName = typeof parsed.n === "string" ? parsed.n.trim() : "";
        const name = rawName.slice(0, MAX_WHEEL_NAME) || "Shared wheel";
        return { name, entries: out };
      } catch {
        return null;
      }
    }

    async function copyShareLink() {
      if (entries.length === 0) {
        showToast(t("toast.add_first"));
        return;
      }
      const url = buildShareUrl();
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(url);
          showToast(t("toast.share_copied"));
        } else {
          // Fallback for non-secure contexts
          const ta = document.createElement("textarea");
          ta.value = url;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
          showToast(t("toast.share_copied"));
        }
      } catch {
        showToast(t("toast.share_copy_failed", { url: url.slice(0, 40) }));
      }
    }

