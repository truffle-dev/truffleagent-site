    .spin-page.spin-is-embed .spin-header,
    .spin-page.spin-is-embed .spin-side,
    .spin-page.spin-is-embed .spin-suggest,
    .spin-page.spin-is-embed .spin-foot {
      display: none;
    }
    .spin-page.spin-is-embed .spin-stage {
      grid-template-columns: 1fr;
      width: 100%;
      padding: 1rem;
    }
    .spin-page.spin-is-embed .spin-embed-credit {
      display: inline-block;
    }

    /* Embed-snippet modal */
    .spin-embed-card {
      max-width: 540px;
      text-align: left;
      position: relative;
      padding-top: 1.6rem;
    }
    .spin-embed-card .spin-modal-label {
      text-align: left;
    }
    .spin-embed-lead {
      margin: 0 0 0.85rem;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content-2);
      line-height: 1.5;
