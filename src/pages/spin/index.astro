    function applyPointer() {
      if (!pointerEl) return;
      pointerEl.classList.toggle("spin-pointer-top", pointerCfg.pos === "top");
      pointerEl.classList.toggle("spin-pointer-right", pointerCfg.pos === "right");
      pointerEl.style.setProperty("--pointer-fill", POINTER_COLOR_VAR[pointerCfg.color]);
      if (pointerPosTop) pointerPosTop.setAttribute("aria-pressed", String(pointerCfg.pos === "top"));
      if (pointerPosRight) pointerPosRight.setAttribute("aria-pressed", String(pointerCfg.pos === "right"));
      pointerSwatches.forEach((s) => {
        s.setAttribute("aria-pressed", String(s.dataset.color === pointerCfg.color));
      });
    }

    function setPointerPos(pos: PointerPos) {
      if (pointerCfg.pos === pos) return;
      pointerCfg = { ...pointerCfg, pos };
      applyPointer();
      save();
