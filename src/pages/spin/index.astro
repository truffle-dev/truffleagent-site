  </style>

  <script>
    type Entry = { id: string; label: string; color?: string; weight?: number; wins?: number; lastPickedAt?: number };
    type Wheel = { id: string; name: string; entries: Entry[]; eliminate?: boolean; accumulate?: boolean; rotation?: boolean; rosterSnapshot?: string[]; teamCount?: number; importedFromShare?: boolean };
    type PointerPos = "top" | "right";
    type PointerColor = "ink" | "accent" | "amber";
    type PointerCfg = { pos: PointerPos; color: PointerColor };
    type LabelRotation = "auto" | "tangent" | "radial";
    type Palette = "paper" | "vibrant" | "pastel" | "mono";
    type WheelSize = "s" | "m" | "l" | "full";
    type SoundPack = "classic" | "soft" | "arcade" | "sparkle";
    type Scene = "none" | "paper" | "ink" | "ocean" | "sunset" | "noir";
    type PersistV1 = { entries: Entry[]; version: 1; muted?: boolean };
    type PersistV2 = { version: 2; wheels: Wheel[]; currentId: string; muted?: boolean; pointer?: PointerCfg; labelRotation?: LabelRotation; palette?: Palette; wheelSize?: WheelSize; soundPack?: SoundPack; scene?: Scene };
    type AnyPersist = PersistV1 | PersistV2;

    const STORAGE_KEY = "spinwheel:v1";
    const HISTORY_KEY = "spinwheel:history:v1";
    const IS_EMBED = (() => {
      try { return new URLSearchParams(location.search).get("embed") === "1"; }
      catch { return false; }
    })();
    const HISTORY_CAP = 20;
    const MAX_WHEELS = 20;
    const MAX_WHEEL_NAME = 40;

    type HistoryEntry = { ts: number; wheelName: string; winner: string };
    const DEFAULT_ENTRIES: Entry[] = [
      { id: "1", label: "Pizza" },
      { id: "2", label: "Tacos" },
      { id: "3", label: "Sushi" },
      { id: "4", label: "Ramen" },
      { id: "5", label: "Burger" },
      { id: "6", label: "Salad" },
    ];

    // === i18n: English source-of-truth. Replace this object to localize. ===
    // Placeholders use `{name}` syntax. Plural-aware strings take a `{s}` arg.
    const STRINGS: Record<string, string> = {
      "toast.wait_for_spin": "Wait for the spin to finish",
      "toast.switched_to": "Switched to {name}",
      "toast.max_wheels": "Max {n} wheels",
      "toast.max_wheels_room": "Max {n} wheels — make room first",
      "toast.duplicated_to": "Duplicated to {name}",
      "toast.cannot_delete_only": "Cannot delete the only wheel",
      "toast.deleted": "Deleted {name}",
      "toast.entry_deleted": "Deleted “{name}”",
      "toast.undo": "Undo",
      "empty.title": "Your wheel is empty.",
      "empty.cta": "Add your first entry",
      "toast.need_4_teams": "Need at least 4 entries to split teams",
      "toast.champion": "Champion: {name}",
      "toast.all_eliminated": "All entries eliminated",
      "toast.need_2": "Need at least 2 entries",
      "toast.add_first": "Add an entry first",
      "toast.share_copied": "Share link copied",
      "toast.share_copy_failed": "Could not copy. URL: {url}…",
      "toast.embed_copied": "Embed code copied",
      "toast.copy_manual": "Select the code and copy manually",
      "toast.image_build_failed": "Could not build image",
      "toast.image_copied": "Image copied to clipboard",
      "toast.image_downloaded": "Image downloaded",
      "toast.image_save_failed": "Could not save image",
      "toast.image_shared": "Shared",
      "toast.sound_on": "Sound on",
      "toast.sound_off": "Sound off",
      "toast.eliminate_on": "Eliminate mode on",
      "toast.eliminate_off": "Eliminate mode off",
      "toast.accumulate_on": "Accumulate mode on",
      "toast.accumulate_off": "Accumulate mode off",
      "toast.rotation_on": "Rotation mode on — roster saved",
      "toast.rotation_off": "Rotation mode off",
      "toast.rotation_cycle_complete": "Cycle complete — start a new one",
      "toast.rotation_rehydrated": "New cycle — {n} on the roster",
      "toast.rotation_roster_empty": "Add at least one entry first",
      "toast.mode_single": "Single-winner mode",
      "toast.reset_wins": "Reset {n} win count{s}",
      "toast.cleared_remaining": "Cleared {n} remaining",
      "toast.cleared_entries": "Cleared {n} entries",
      "toast.created": "Created {name}",
      "toast.renamed": "Renamed",
      "toast.file_read_failed": "Could not read file",
      "toast.exported": "Exported {n} wheel{s}",
      "toast.bad_json": "Not valid JSON",
      "toast.no_wheels": "No wheels found in file",
      "toast.imported": 'Imported "{name}"',
      "toast.imported_n": "Imported {n} wheel{s}",
      "toast.imported_n_skipped": "Imported {n} wheel{s} ({skipped} skipped: max reached)",
      "toast.share_decode_failed": "Couldn't read shared wheel link",
      "toast.history_cleared": "History cleared",
      "toast.sound_pack_changed": "Sound: {name}",
      "toast.scene_changed": "Scene: {name}",
      "toast.look_reset": "Look reset to defaults",
    };

    function t(key: string, vars?: Record<string, string | number>): string {
      let s = STRINGS[key] ?? key;
      if (vars) {
        for (const k in vars) {
          s = s.split(`{${k}}`).join(String(vars[k]));
        }
      }
      return s;
    }

    const PALETTES: Record<Palette, string[]> = {
      paper: [
        "#4850c4", // truffle indigo
        "#6a7d3b", // moss
        "#b07d2a", // amber
        "#a14a2a", // rust
        "#3b3527", // ink-2
        "#84785a", // paper-500
        "#5d68d0", // truffle-400
        "#3b41a3", // truffle-600
      ],
      vibrant: [
        "#e63946", // crimson
        "#f48c06", // orange
        "#ffba08", // gold
        "#5cb85c", // green
        "#0aa6b7", // teal
        "#4361ee", // blue
        "#8338ec", // violet
        "#ef476f", // rose
      ],
      pastel: [
        "#e0a3a3", // dusty rose
        "#e8b58b", // peach
        "#dfc97b", // butter
        "#a8c98a", // sage
        "#90c0cc", // sky
        "#a3a8d8", // lavender
        "#bea2cf", // lilac
        "#d8a3b3", // blush
      ],
      mono: [
        "#2e2519", // ink-1
        "#3b3527", // ink-2
        "#4e4633", // ink-3
        "#665b44", // ink-4
        "#84785a", // paper-500
        "#a39682", // paper-400
        "#b8ad9a", // paper-300
        "#cec2af", // paper-200
      ],
    };
    const DEFAULT_PALETTE: Palette = "paper";
    function validPalette(v: unknown): Palette {
      return v === "paper" || v === "vibrant" || v === "pastel" || v === "mono" ? v : DEFAULT_PALETTE;
    }

    const DEFAULT_POINTER: PointerCfg = { pos: "top", color: "ink" };
    function validPointer(p: unknown): PointerCfg {
      const out: PointerCfg = { pos: "top", color: "ink" };
      if (p && typeof p === "object") {
        const o = p as { pos?: unknown; color?: unknown };
        if (o.pos === "top" || o.pos === "right") out.pos = o.pos;
        if (o.color === "ink" || o.color === "accent" || o.color === "amber") out.color = o.color;
      }
      return out;
    }

    const DEFAULT_LABEL_ROTATION: LabelRotation = "auto";
    function validLabelRotation(v: unknown): LabelRotation {
      return v === "tangent" || v === "radial" || v === "auto" ? v : DEFAULT_LABEL_ROTATION;
    }
    const AUTO_TANGENT_MIN = 7;
    const AUTO_TANGENT_MAX = 16;

    const DEFAULT_WHEEL_SIZE: WheelSize = "l";
    function validWheelSize(v: unknown): WheelSize {
      return v === "s" || v === "m" || v === "l" || v === "full" ? v : DEFAULT_WHEEL_SIZE;
    }

    type SoundOps = {
      tick: (c: AudioContext) => void;
      fanfare: (c: AudioContext) => void;
    };
    // Each pack is a self-contained procedural sound — zero asset weight.
    // `classic` mirrors the original tick + 4-note ascent verbatim so a user
    // who never opens the sound panel hears exactly what they did before.
    const SOUND_PACKS: Record<SoundPack, SoundOps> = {
      classic: {
        tick(c) {
          const t = c.currentTime;
          const osc = c.createOscillator();
          const gain = c.createGain();
          osc.type = "triangle";
          osc.frequency.value = 720 + Math.random() * 220;
          gain.gain.setValueAtTime(0, t);
          gain.gain.linearRampToValueAtTime(0.045, t + 0.004);
          gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.065);
          osc.connect(gain).connect(c.destination);
          osc.start(t);
          osc.stop(t + 0.08);
        },
        fanfare(c) {
          const notes = [523.25, 659.25, 783.99, 1046.5];
          const t0 = c.currentTime;
          notes.forEach((freq, i) => {
            const t = t0 + i * 0.08;
            const osc = c.createOscillator();
            const gain = c.createGain();
            osc.type = "sine";
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.11, t + 0.02);
            gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.45);
            osc.connect(gain).connect(c.destination);
            osc.start(t);
            osc.stop(t + 0.5);
          });
        },
      },
      soft: {
        // Wooden-mallet pings — sine fundamentals, slow taper, quieter peak.
        tick(c) {
          const t = c.currentTime;
          const osc = c.createOscillator();
          const gain = c.createGain();
          osc.type = "sine";
          osc.frequency.value = 420 + Math.random() * 80;
          gain.gain.setValueAtTime(0, t);
          gain.gain.linearRampToValueAtTime(0.028, t + 0.006);
          gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.12);
          osc.connect(gain).connect(c.destination);
          osc.start(t);
          osc.stop(t + 0.13);
        },
        fanfare(c) {
          // Major 9 chord laid out as a soft pad: C5, E5, G5, D6
          const notes = [523.25, 659.25, 783.99, 1174.66];
          const t0 = c.currentTime;
          notes.forEach((freq, i) => {
            const t = t0 + i * 0.12;
            const osc = c.createOscillator();
            const gain = c.createGain();
            osc.type = "sine";
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.075, t + 0.06);
            gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.9);
            osc.connect(gain).connect(c.destination);
            osc.start(t);
            osc.stop(t + 0.95);
          });
        },
      },
      arcade: {
        // 8-bit square-wave blips with sharp attack and percussive decay.
        tick(c) {
          const t = c.currentTime;
          const osc = c.createOscillator();
          const gain = c.createGain();
          osc.type = "square";
          osc.frequency.setValueAtTime(880 + Math.random() * 200, t);
          osc.frequency.exponentialRampToValueAtTime(560, t + 0.05);
          gain.gain.setValueAtTime(0, t);
          gain.gain.linearRampToValueAtTime(0.04, t + 0.002);
          gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.05);
          osc.connect(gain).connect(c.destination);
          osc.start(t);
          osc.stop(t + 0.06);
        },
        fanfare(c) {
          // Power-up: ascending square arpeggio — C5, G5, C6, E6, G6
          const notes = [523.25, 783.99, 1046.5, 1318.51, 1567.98];
          const t0 = c.currentTime;
          notes.forEach((freq, i) => {
            const t = t0 + i * 0.06;
            const osc = c.createOscillator();
            const gain = c.createGain();
            osc.type = "square";
            osc.frequency.value = freq;
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.07, t + 0.01);
            gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.22);
            osc.connect(gain).connect(c.destination);
            osc.start(t);
            osc.stop(t + 0.25);
          });
        },
      },
      sparkle: {
        // Glass-chime ticks — high overtones, very short decay.
        tick(c) {
          const t = c.currentTime;
          const osc = c.createOscillator();
          const gain = c.createGain();
          osc.type = "sine";
          osc.frequency.value = 1320 + Math.random() * 400;
          gain.gain.setValueAtTime(0, t);
          gain.gain.linearRampToValueAtTime(0.03, t + 0.003);
          gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.09);
          osc.connect(gain).connect(c.destination);
          osc.start(t);
          osc.stop(t + 0.1);
        },
        fanfare(c) {
          // Two-octave bell — fundamental + octave + perfect fifth, sparkle on top
          const notes = [
            { f: 523.25, d: 0.0 },
            { f: 1046.5, d: 0.08 },
            { f: 1567.98, d: 0.16 },
            { f: 2093.0, d: 0.24 },
            { f: 2637.02, d: 0.32 },
          ];
          const t0 = c.currentTime;
          notes.forEach(({ f, d }) => {
            const t = t0 + d;
            const osc = c.createOscillator();
            const gain = c.createGain();
            osc.type = "sine";
            osc.frequency.value = f;
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.06, t + 0.015);
            gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.6);
            osc.connect(gain).connect(c.destination);
            osc.start(t);
            osc.stop(t + 0.65);
          });
        },
      },
    };
    const DEFAULT_SOUND_PACK: SoundPack = "classic";
    function validSoundPack(v: unknown): SoundPack {
      return v === "classic" || v === "soft" || v === "arcade" || v === "sparkle" ? v : DEFAULT_SOUND_PACK;
    }
    const SOUND_PACK_LABELS: Record<SoundPack, string> = {
      classic: "Classic",
      soft: "Soft",
      arcade: "Arcade",
      sparkle: "Sparkle",
    };

    const SCENES: Scene[] = ["none", "paper", "ink", "ocean", "sunset", "noir"];
    const SCENE_LABELS: Record<Scene, string> = {
      none: "None",
      paper: "Paper",
      ink: "Ink",
      ocean: "Ocean",
      sunset: "Sunset",
      noir: "Noir",
    };
    // Single representative color per scene — used to render a preview dot
    // on each scene chip. Picked from the radial-gradient anchor color.
    const SCENE_SWATCH: Record<Scene, string> = {
      none: "transparent",
      paper: "#f3edde",
      ink: "#2a2f5c",
      ocean: "#1a708a",
      sunset: "#e07a4a",
      noir: "#161618",
    };
    const DEFAULT_SCENE: Scene = "none";
    function validScene(v: unknown): Scene {
      return v === "none" || v === "paper" || v === "ink" || v === "ocean" || v === "sunset" || v === "noir" ? v : DEFAULT_SCENE;
    }

    const canvas = document.getElementById("spin-canvas") as HTMLCanvasElement | null;
    const centerBtn = document.getElementById("spin-center") as HTMLButtonElement | null;
