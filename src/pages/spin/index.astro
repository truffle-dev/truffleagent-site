        else openPaletteConfig();
      });
    }
    if (paletteCancel) paletteCancel.addEventListener("click", closePaletteConfig);

    if (sizeBtn) {
      sizeBtn.addEventListener("click", () => {
        if (sizeConfig && !sizeConfig.hidden) closeSizeConfig();
        else openSizeConfig();
      });
    }
    if (sizeCancel) sizeCancel.addEventListener("click", closeSizeConfig);
    sizeChips.forEach((c) => {
      c.addEventListener("click", () => {
        const s = c.dataset.size;
        if (s === "s" || s === "m" || s === "l" || s === "full") setWheelSize(s);
      });
    });

    if (soundBtn) {
      soundBtn.addEventListener("click", () => {
        if (soundConfig && !soundConfig.hidden) closeSoundConfig();
        else openSoundConfig();
      });
    }
    if (soundCancel) soundCancel.addEventListener("click", closeSoundConfig);
    if (soundPreview) {
      soundPreview.addEventListener("click", () => {
        // Audible regardless of mute toggle, since the user explicitly asked.
        const c = getAudio();
        if (!c) return;
        SOUND_PACKS[soundPack].tick(c);
        const ms = soundPack === "arcade" ? 90 : 140;
        setTimeout(() => {
          const c2 = getAudio();
