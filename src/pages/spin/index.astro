    /* === Background scenes — full-viewport via body :has() ===
       The .spin-page container is max-width:1280px and centered, so any
       background scoped to it only paints behind a narrow strip. Apply
       the gradient to body so it covers the whole viewport (nav + page
       + footer + side gutters) and use background-attachment:fixed so
       it stays painted while scrolling. */
    html:has(.spin-page[data-scene]),
    body:has(.spin-page[data-scene]) {
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center top;
      background-attachment: fixed;
      transition: background-color 320ms ease;
    }
    html:has(.spin-page[data-scene="paper"]) {
      background-color: var(--surface);
    }
    body:has(.spin-page[data-scene="paper"]) {
      background-color: transparent;
      background-image:
        radial-gradient(80% 60% at 50% 20%, color-mix(in oklab, var(--accent) 9%, transparent), transparent 75%),
        linear-gradient(180deg, color-mix(in oklab, var(--accent) 4%, var(--surface)) 0%, var(--surface) 60%);
    }
    html:has(.spin-page[data-scene="ink"]) { background-color: #0d1024; }
    body:has(.spin-page[data-scene="ink"]) {
      background-color: #0d1024;
      background-image:
        radial-gradient(60% 50% at 50% 0%, #2e3673 0%, transparent 70%),
        linear-gradient(180deg, #1a1f4c 0%, #0d1024 70%);
    }
    html:has(.spin-page[data-scene="ocean"]) { background-color: #051a2a; }
    body:has(.spin-page[data-scene="ocean"]) {
      background-color: #051a2a;
      background-image:
        radial-gradient(70% 55% at 50% 0%, #1c7a92 0%, transparent 65%),
        linear-gradient(180deg, #0f4e6b 0%, #082035 55%, #051a2a 100%);
    }
    html:has(.spin-page[data-scene="sunset"]) { background-color: #3a1a3e; }
    body:has(.spin-page[data-scene="sunset"]) {
      background-color: #3a1a3e;
      background-image:
        radial-gradient(70% 55% at 50% 0%, #ffb56a 0%, transparent 60%),
        linear-gradient(180deg, #e07a4a 0%, #6b2a48 65%, #3a1a3e 100%);
    }
    html:has(.spin-page[data-scene="noir"]) { background-color: #06060a; }
    body:has(.spin-page[data-scene="noir"]) {
      background-color: #06060a;
      background-image:
        radial-gradient(60% 50% at 50% 0%, #303036 0%, transparent 70%),
        linear-gradient(180deg, #161618 0%, #06060a 75%);
    }

    /* Tinted-scene text + chrome adjustments */
    .spin-page[data-scene="ink"],
    .spin-page[data-scene="ocean"],
    .spin-page[data-scene="sunset"],
    .spin-page[data-scene="noir"] {
      --content: #f7f1e6;
      --content-2: color-mix(in oklab, #f7f1e6 85%, transparent);
      --content-3: color-mix(in oklab, #f7f1e6 65%, transparent);
      --content-4: color-mix(in oklab, #f7f1e6 50%, transparent);
      --surface: color-mix(in oklab, #f7f1e6 8%, transparent);
      --surface-2: color-mix(in oklab, #f7f1e6 12%, transparent);
      --surface-3: color-mix(in oklab, #f7f1e6 16%, transparent);
      --border: color-mix(in oklab, #f7f1e6 18%, transparent);
    }
    html:has(.spin-page[data-scene="ink"]),
    html:has(.spin-page[data-scene="ocean"]),
    html:has(.spin-page[data-scene="sunset"]),
    html:has(.spin-page[data-scene="noir"]),
    body:has(.spin-page[data-scene="ink"]),
    body:has(.spin-page[data-scene="ocean"]),
    body:has(.spin-page[data-scene="sunset"]),
    body:has(.spin-page[data-scene="noir"]) {
      --content: #f7f1e6;
      --content-2: color-mix(in oklab, #f7f1e6 85%, transparent);
      --content-3: color-mix(in oklab, #f7f1e6 65%, transparent);
      --content-4: color-mix(in oklab, #f7f1e6 50%, transparent);
      --surface: color-mix(in oklab, #f7f1e6 8%, transparent);
      --surface-2: color-mix(in oklab, #f7f1e6 12%, transparent);
      --surface-3: color-mix(in oklab, #f7f1e6 16%, transparent);
      --border: color-mix(in oklab, #f7f1e6 18%, transparent);
      color: #f7f1e6;
    }
    body:has(.spin-page[data-scene="ink"]) .site-header,
    body:has(.spin-page[data-scene="ocean"]) .site-header,
    body:has(.spin-page[data-scene="sunset"]) .site-header,
    body:has(.spin-page[data-scene="noir"]) .site-header {
      background: color-mix(in oklab, #f7f1e6 6%, transparent);
      backdrop-filter: saturate(140%) blur(14px);
      -webkit-backdrop-filter: saturate(140%) blur(14px);
      border-bottom: 1px solid color-mix(in oklab, #f7f1e6 14%, transparent);
    }
    body:has(.spin-page[data-scene="ink"]) .site-footer,
    body:has(.spin-page[data-scene="ocean"]) .site-footer,
    body:has(.spin-page[data-scene="sunset"]) .site-footer,
    body:has(.spin-page[data-scene="noir"]) .site-footer {
      border-top: 1px solid color-mix(in oklab, #f7f1e6 14%, transparent);
      background: linear-gradient(to bottom, transparent, color-mix(in oklab, #f7f1e6 6%, transparent));
    }
    .spin-page[data-scene="ink"] .spin-wheel-frame,
    .spin-page[data-scene="ocean"] .spin-wheel-frame,
    .spin-page[data-scene="sunset"] .spin-wheel-frame,
    .spin-page[data-scene="noir"] .spin-wheel-frame {
      filter: drop-shadow(0 18px 40px rgba(0, 0, 0, 0.55));
    }
    .spin-page[data-scene="ink"] #spin-canvas,
    .spin-page[data-scene="ocean"] #spin-canvas,
    .spin-page[data-scene="sunset"] #spin-canvas,
    .spin-page[data-scene="noir"] #spin-canvas {
      filter: drop-shadow(0 18px 40px rgba(0, 0, 0, 0.55));
    }
    .spin-page[data-scene="ink"] .spin-side,
    .spin-page[data-scene="ocean"] .spin-side,
    .spin-page[data-scene="sunset"] .spin-side,
    .spin-page[data-scene="noir"] .spin-side {
      backdrop-filter: blur(14px) saturate(120%);
      -webkit-backdrop-filter: blur(14px) saturate(120%);
      background: color-mix(in oklab, #f7f1e6 8%, transparent);
      box-shadow: 0 1px 0 color-mix(in oklab, #f7f1e6 14%, transparent) inset,
                  0 16px 48px -24px rgba(0, 0, 0, 0.45);
    }
    @media (prefers-reduced-motion: reduce) {
      body:has(.spin-page[data-scene]) { transition: none; }
    }

    .spin-about {
      margin: 3rem auto 0;
      max-width: 760px;
      padding: 0 0.25rem;
    }
    .spin-about-h {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(1.5rem, 2.4vw, 2rem);
      line-height: 1.2;
      margin: 0 0 0.85rem;
      color: var(--content);
    }
    .spin-about-h em {
      color: var(--accent);
      font-style: italic;
    }
    .spin-about-lead {
      margin: 0 0 1.25rem;
      font-family: var(--font-sans);
      font-size: 15px;
      line-height: 1.6;
      color: var(--content-2);
    }
    .spin-about-features {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem 1.5rem;
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.5;
      color: var(--content-2);
    }
    .spin-about-features li {
      position: relative;
      padding-left: 1.1rem;
    }
    .spin-about-features li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: color-mix(in oklab, var(--accent) 80%, transparent);
    }
    .spin-about-features strong {
      color: var(--content);
      font-weight: 600;
    }
    @media (max-width: 640px) {
      .spin-about-features { grid-template-columns: 1fr; }
    }

    .spin-faq {
      margin: 2.5rem auto 0;
      max-width: 760px;
      padding: 0 0.25rem;
    }
    .spin-faq-h {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(1.35rem, 2vw, 1.65rem);
      line-height: 1.2;
      margin: 0 0 1rem;
      color: var(--content);
    }
    .spin-faq-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .spin-faq-item {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface-2);
      padding: 0.85rem 1rem;
    }
    .spin-faq-item summary {
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 600;
      color: var(--content);
      cursor: pointer;
      list-style: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .spin-faq-item summary::-webkit-details-marker { display: none; }
    .spin-faq-item summary::before {
      content: "+";
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 18px;
      height: 18px;
      border-radius: 4px;
      color: var(--content-3);
      font-size: 16px;
      line-height: 1;
      flex-shrink: 0;
    }
    .spin-faq-item[open] summary::before { content: "–"; color: var(--accent); }
    .spin-faq-item p {
      margin: 0.65rem 0 0 1.65rem;
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.6;
      color: var(--content-2);
    }
    .spin-page.spin-is-embed .spin-about,
    .spin-page.spin-is-embed .spin-faq,
    .spin-page.spin-is-embed .spin-presets { display: none; }

    .spin-presets {
      margin: 2.5rem auto 0;
      max-width: 760px;
      padding: 0 0.25rem;
    }
    .spin-presets-h {
      font-family: var(--font-serif);
      font-weight: 400;
      font-size: clamp(1.35rem, 2vw, 1.65rem);
      line-height: 1.2;
      margin: 0 0 0.6rem;
      color: var(--content);
    }
    .spin-presets-h em {
      color: var(--accent);
      font-style: italic;
    }
    .spin-presets-lead {
      margin: 0 0 1rem;
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.55;
      color: var(--content-2);
    }
    .spin-presets-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.5rem;
    }
    .spin-preset-card { margin: 0; }
    .spin-preset-link {
      display: grid;
      grid-template-columns: 1fr auto;
      grid-template-areas: "title arrow" "blurb arrow";
      align-items: center;
      gap: 0 0.5rem;
      padding: 0.75rem 0.85rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface-2);
      color: var(--content);
      text-decoration: none;
      transition: border-color 150ms ease, transform 150ms ease;
    }
    .spin-preset-link:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }
    .spin-preset-link:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .spin-preset-title {
      grid-area: title;
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--content);
    }
    .spin-preset-blurb {
      grid-area: blurb;
      font-family: var(--font-sans);
      font-size: 12.5px;
      line-height: 1.4;
      color: var(--content-2);
    }
    .spin-preset-arrow {
      grid-area: arrow;
      font-family: var(--font-sans);
      font-size: 16px;
      color: var(--content-3);
      transition: color 150ms ease, transform 150ms ease;
    }
    .spin-preset-link:hover .spin-preset-arrow {
      color: var(--accent);
      transform: translateX(2px);
    }

    .spin-foot {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 13px;
      color: var(--content-3);
    }
    .spin-foot a {
      color: var(--accent);
      text-decoration: none;
    }
    .spin-foot a:hover {
      text-decoration: underline;
    }

    .spin-modal {
      position: fixed;
      inset: 0;
      background: color-mix(in oklab, var(--surface) 70%, black);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      z-index: 50;
      animation: spin-fade-in 0.2s var(--ease-out);
    }
    .spin-modal[hidden] {
      display: none;
    }
    @keyframes spin-fade-in {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    .spin-modal-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 2rem;
      max-width: 420px;
      width: 100%;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
      animation: spin-pop 0.3s var(--ease-out);
    }
    @keyframes spin-pop {
      from { transform: scale(0.92); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .spin-modal-label {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 0 0 0.5rem;
    }
    .spin-modal-name {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--content);
      margin: 0 0 1.5rem;
      word-break: break-word;
    }
    .spin-order-list {
      list-style: none;
      padding: 0;
      margin: 0 0 1.25rem;
      max-height: 50vh;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 6px;
      text-align: left;
    }
    .spin-order-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 9px 14px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 14px;
      color: var(--content);
    }
    .spin-order-item:first-child {
      border-color: color-mix(in oklab, var(--accent) 40%, transparent);
      background: color-mix(in oklab, var(--accent) 7%, var(--surface-2));
    }
    .spin-order-num {
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums;
      font-size: 13px;
      color: var(--content-3);
      min-width: 24px;
      text-align: right;
      flex-shrink: 0;
    }
    .spin-order-item:first-child .spin-order-num {
      color: var(--accent);
      font-weight: 600;
    }
    .spin-order-label {
      flex: 1;
      word-break: break-word;
    }
    .spin-teams-list {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
      margin: 0 0 1.25rem;
      max-height: 55vh;
      overflow-y: auto;
      text-align: left;
    }
    .spin-team {
      padding: 0.55rem 0.75rem;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    .spin-team:first-child {
      border-color: color-mix(in oklab, var(--accent) 40%, transparent);
      background: color-mix(in oklab, var(--accent) 6%, var(--surface-2));
    }
    .spin-team-name {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem;
      font-family: var(--font-mono);
      font-size: 11.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--content-3);
      margin: 0 0 0.4rem;
      font-weight: 500;
    }
    .spin-team:first-child .spin-team-name { color: var(--accent); }
    .spin-team-size {
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums;
      color: var(--content-4);
      font-size: 11px;
      letter-spacing: 0;
      text-transform: none;
    }
    .spin-team-members {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
      font-size: 14px;
      color: var(--content);
    }
    .spin-team-members li { word-break: break-word; }
    .spin-modal-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
    }
    .spin-btn {
      padding: 0.6rem 1.1rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .spin-btn:hover {
      background: var(--surface-3);
    }
    .spin-btn-primary {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }
    .spin-btn-primary:hover {
      background: var(--accent-2);
      border-color: var(--accent-2);
    }
    .spin-btn-ghost {
      padding: 0.6rem 1.1rem;
      border-radius: 8px;
      border: 0;
      background: transparent;
      color: var(--content-3);
      font-family: var(--font-sans);
      font-size: 14px;
      cursor: pointer;
    }
    .spin-btn-ghost:hover {
      color: var(--content);
    }

    /* Help / cheatsheet */
    .spin-help-card {
      max-width: 460px;
      text-align: left;
      padding-top: 1.6rem;
      position: relative;
    }
    .spin-help-card .spin-modal-label {
      text-align: left;
    }
    .spin-help-title {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.6rem, 3.5vw, 2rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--content);
      margin: 0 0 1.25rem;
    }
    .spin-help-x {
      position: absolute;
      top: 0.55rem;
      right: 0.65rem;
      width: 30px;
      height: 30px;
      border: 0;
      background: transparent;
      color: var(--content-3);
      font-size: 20px;
      line-height: 1;
      cursor: pointer;
      border-radius: 6px;
    }
    .spin-help-x:hover { color: var(--content); background: var(--surface-2); }
    .spin-help-x:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .spin-help-list {
      margin: 0 0 1rem;
      padding: 0;
      display: grid;
      grid-template-columns: max-content 1fr;
      column-gap: 0.85rem;
      row-gap: 0.55rem;
    }
    .spin-help-row {
      display: contents;
    }
    .spin-help-row dt {
      margin: 0;
      align-self: center;
    }
    .spin-help-row dd {
      margin: 0;
      align-self: center;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content-2);
    }
    .spin-kbd {
      display: inline-block;
      min-width: 2.1em;
      padding: 3px 8px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      text-align: center;
      color: var(--content);
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-bottom-width: 2px;
      border-radius: 6px;
      line-height: 1.2;
    }
    .spin-help-foot {
      margin: 0;
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--content-4);
    }

    /* Embed credit footer (only visible in embed mode) */
    .spin-embed-credit {
      display: none;
      position: fixed;
      bottom: 8px;
      right: 12px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--content-3);
      text-decoration: none;
      padding: 4px 8px;
      border-radius: 6px;
      background: color-mix(in oklab, var(--surface) 80%, transparent);
      z-index: 10;
    }
    .spin-embed-credit:hover {
      color: var(--content);
      background: var(--surface-2);
    }
    .spin-embed-credit:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* Embed mode — strip the page to wheel only */
    html[data-embed="1"] .site-header,
    html[data-embed="1"] .site-footer {
      display: none !important;
    }
    html[data-embed="1"] body {
      background: transparent;
    }
    html[data-embed="1"] #main {
      padding: 0;
      margin: 0;
      min-height: 100vh;
    }
    .spin-page.spin-is-embed {
      padding: 0;
      max-width: none;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .spin-page.spin-is-embed .spin-header,
    .spin-page.spin-is-embed .spin-side,
    .spin-page.spin-is-embed .spin-suggest,
    .spin-page.spin-is-embed .spin-foot {
      display: none;
    }
    .spin-page.spin-is-embed .spin-stage {
      grid-template-columns: 1fr;
      width: 100%;
      padding: 1rem;
    }
    .spin-page.spin-is-embed .spin-embed-credit {
      display: inline-block;
    }

    /* Embed-snippet modal */
    .spin-embed-card {
      max-width: 540px;
      text-align: left;
      position: relative;
      padding-top: 1.6rem;
    }
    .spin-embed-card .spin-modal-label {
      text-align: left;
    }
    .spin-embed-lead {
      margin: 0 0 0.85rem;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content-2);
      line-height: 1.5;
    }
    .spin-embed-textarea {
      width: 100%;
      box-sizing: border-box;
      padding: 0.7rem 0.85rem;
      font-family: var(--font-mono);
      font-size: 12px;
      line-height: 1.5;
      color: var(--content);
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
      resize: vertical;
      margin: 0 0 1rem;
    }
    .spin-embed-textarea:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 1px;
      border-color: var(--accent);
    }

    /* Confetti overlay */
    .spin-confetti {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 60;
    }

    /* Mute toggle icon swap */
    .spin-mute-off { display: none; }
    #spin-mute[aria-pressed="true"] .spin-mute-on { display: none; }
    #spin-mute[aria-pressed="true"] .spin-mute-off { display: inline; }
    #spin-mute[aria-pressed="true"] {
      color: var(--content-4);
    }

    /* Mode-toggle pressed state — eliminate */
    .spin-icon-mode[aria-pressed="true"] {
      color: var(--accent);
      background: color-mix(in oklab, var(--accent) 12%, transparent);
      border-color: color-mix(in oklab, var(--accent) 30%, transparent);
    }

    /* Rotation roster bar */
    .spin-rotation-bar {
      margin: 0 0 0.65rem;
      padding: 0.65rem 0.85rem;
      border-radius: 12px;
      background: color-mix(in oklab, var(--accent) 7%, var(--surface));
      border: 1px solid color-mix(in oklab, var(--accent) 22%, transparent);
      font-family: var(--font-sans);
      font-size: 13px;
    }
    .spin-rotation-bar-line {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .spin-rotation-status {
      color: var(--content);
      font-weight: 500;
    }
    .spin-rotation-status em {
      font-style: normal;
      color: var(--accent);
      font-weight: 600;
    }
    .spin-rotation-rehydrate {
      appearance: none;
      border: 1px solid color-mix(in oklab, var(--accent) 40%, transparent);
      background: var(--accent);
      color: white;
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      font: inherit;
      font-weight: 600;
      cursor: pointer;
      transition: filter var(--motion-fast, 100ms);
    }
    .spin-rotation-rehydrate:hover { filter: brightness(1.08); }
    .spin-rotation-rehydrate:focus-visible {
      outline: 3px solid color-mix(in oklab, var(--accent) 40%, transparent);
      outline-offset: 2px;
    }
    .spin-rotation-hint {
      margin: 0.4rem 0 0;
      color: var(--content-3);
      font-size: 12px;
      line-height: 1.4;
    }

    /* Toast */
    .spin-toast {
      position: fixed;
      bottom: clamp(1rem, 3vw, 2rem);
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--content);
      color: var(--surface);
      padding: 0.6rem 0.85rem 0.6rem 1.1rem;
      border-radius: 999px;
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: -0.005em;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transition: opacity 0.2s var(--ease-out), transform 0.2s var(--ease-out);
      z-index: 80;
      pointer-events: none;
      max-width: 90vw;
      display: inline-flex;
      align-items: center;
      gap: 0.65rem;
      text-align: left;
    }
    .spin-toast.is-visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .spin-toast-msg {
      flex: 0 1 auto;
      min-width: 0;
    }
    .spin-toast-action {
      pointer-events: auto;
      background: transparent;
      border: 0;
      color: color-mix(in oklab, var(--surface) 88%, var(--accent));
      font: inherit;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-size: 11px;
      cursor: pointer;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      transition: background-color 0.12s var(--ease-out), color 0.12s var(--ease-out);
    }
    .spin-toast-action:hover {
      background: color-mix(in oklab, var(--surface) 14%, transparent);
      color: var(--surface);
    }
    .spin-toast-action:focus-visible {
      outline: 2px solid color-mix(in oklab, var(--surface) 80%, var(--accent));
      outline-offset: 2px;
    }
    .spin-toast-action[hidden] {
      display: none;
    }

    /* Reduce motion */
    @media (prefers-reduced-motion: reduce) {
      .spin-modal,
      .spin-modal-card {
        animation: none;
      }
      .spin-confetti {
        display: none;
      }
    }

    /* Print: emit a clean entry list with the wheel name as the title.
       Hide every interactive surface, every scene background, the canvas
       itself, and all marketing chrome. Inputs are flattened to flowing
       text so each entry prints as "1. Label" with optional weight. */
    @media print {
