    if (!canvas || !centerBtn || !list || !addForm || !addInput || !modal) {
      console.error("[spin] missing required DOM nodes");
    }

    const ctx = canvas!.getContext("2d")!;
    const confettiCtx = confetti ? confetti.getContext("2d") : null;

    const initialState = loadState();
    let wheels: Wheel[] = initialState.wheels;
    let currentId: string = initialState.currentId;
    let muted: boolean = initialState.muted;
    let pointerCfg: PointerCfg = initialState.pointer;
    let labelRotation: LabelRotation = initialState.labelRotation;
    let palette: Palette = initialState.palette;
    let wheelSize: WheelSize = initialState.wheelSize;
    let soundPack: SoundPack = initialState.soundPack;
    let scene: Scene = initialState.scene;
    function activePalette(): string[] { return PALETTES[palette]; }

    function currentWheel(): Wheel {
      return wheels.find((w) => w.id === currentId) ?? wheels[0];
    }
    function currentEntries(): Entry[] {
      return currentWheel().entries;
    }

    // Called from entry-mutation paths after a shared-link import so the
    // "shared" pill clears as soon as the user takes ownership of the wheel.
    function clearImportFlag(w?: Wheel) {
      const target = w ?? currentWheel();
      if (target && target.importedFromShare) {
        delete target.importedFromShare;
        save();
        renderPicker();
      }
    }

    // entries alias targets the active wheel
    let entries: Entry[] = currentEntries();
    let rotation = 0;
    let spinning = false;
    // True between showWinner and hideWinner when eliminate mode is active
    // and the displayed winner is not the implicit champion.
    let pendingEliminate = false;
    let lastWinnerIdx: number | null = null;
    // One-shot flag set by the "Spin for order" button. When true, the next
    // showWinner reveals the full ordering instead of a single winner.
    let orderSpinPending = false;
    // Same pattern for team-split: the next showWinner reveals K teams.
    let teamSpinPending = false;

    let history: HistoryEntry[] = loadHistory();

    function loadHistory(): HistoryEntry[] {
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (!raw) return [];
        const arr = JSON.parse(raw);
        if (!Array.isArray(arr)) return [];
        return arr
          .filter(
            (e: any) =>
              e &&
              typeof e.ts === "number" &&
              Number.isFinite(e.ts) &&
              typeof e.wheelName === "string" &&
              typeof e.winner === "string"
          )
          .slice(0, HISTORY_CAP)
          .map((e: any) => ({
            ts: e.ts,
            wheelName: e.wheelName.slice(0, MAX_WHEEL_NAME),
            winner: e.winner.slice(0, 80),
          }));
      } catch {
        return [];
      }
    }

    function saveHistory() {
      if (IS_EMBED) return;
      try {
        localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, HISTORY_CAP)));
      } catch {}
    }

    function pushHistory(entry: Entry) {
      history.unshift({
        ts: Date.now(),
        wheelName: currentWheel().name,
        winner: entry.label,
      });
      if (history.length > HISTORY_CAP) history.length = HISTORY_CAP;
      saveHistory();
      renderHistory();
    }

    function relativeTime(ts: number, now: number): string {
      const diff = Math.max(0, now - ts);
      const m = Math.floor(diff / 60000);
      if (m < 1) return "just now";
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      const d = Math.floor(h / 24);
      if (d < 7) return `${d}d ago`;
      const date = new Date(ts);
      const month = date.getMonth() + 1;
      const day = date.getDate();
      return `${month}/${day}`;
    }

    function loadState(): { wheels: Wheel[]; currentId: string; muted: boolean; pointer: PointerCfg; labelRotation: LabelRotation; palette: Palette; wheelSize: WheelSize; soundPack: SoundPack; scene: Scene } {
      const defaultWheel = (): Wheel => ({
        id: newId(),
        name: "My wheel",
        entries: [...DEFAULT_ENTRIES],
      });
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) {
          const w = defaultWheel();
          return { wheels: [w], currentId: w.id, muted: false, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE, soundPack: DEFAULT_SOUND_PACK, scene: DEFAULT_SCENE };
        }
        const parsed = JSON.parse(raw) as AnyPersist;
        if (parsed && (parsed as PersistV2).version === 2 && Array.isArray((parsed as PersistV2).wheels)) {
          const p = parsed as PersistV2;
          const cleaned: Wheel[] = p.wheels
            .filter((w) => w && typeof w.id === "string" && typeof w.name === "string" && Array.isArray(w.entries))
            .map((w) => {
              const entries = w.entries
                .filter((e) => e && typeof e.label === "string")
                .slice(0, 200)
                .map((e) => {
                  if (typeof e.wins === "number" && Number.isFinite(e.wins) && e.wins > 0) {
                    e.wins = Math.max(0, Math.min(9999, Math.floor(e.wins)));
                  } else if ("wins" in e) {
                    delete e.wins;
                  }
                  return e;
                });
              const out: Wheel = {
                id: w.id,
                name: w.name.slice(0, MAX_WHEEL_NAME) || "Untitled",
                entries,
              };
              if (w.eliminate === true) out.eliminate = true;
              if (w.accumulate === true) out.accumulate = true;
              if (w.rotation === true) out.rotation = true;
              if (Array.isArray(w.rosterSnapshot)) {
                out.rosterSnapshot = w.rosterSnapshot
                  .filter((s) => typeof s === "string")
                  .map((s) => s.slice(0, 80))
                  .slice(0, 200);
              }
              if (typeof w.teamCount === "number" && Number.isFinite(w.teamCount)) {
                const tc = Math.floor(w.teamCount);
                if (tc >= 2 && tc <= 10) out.teamCount = tc;
              }
              if (w.importedFromShare === true) out.importedFromShare = true;
              return out;
            })
            .slice(0, MAX_WHEELS);
          if (cleaned.length === 0) {
            const w = defaultWheel();
            return { wheels: [w], currentId: w.id, muted: !!p.muted, pointer: validPointer(p.pointer), labelRotation: validLabelRotation(p.labelRotation), palette: validPalette(p.palette), wheelSize: validWheelSize(p.wheelSize), soundPack: validSoundPack(p.soundPack), scene: validScene(p.scene) };
          }
          const cid = cleaned.find((w) => w.id === p.currentId)?.id ?? cleaned[0].id;
          return { wheels: cleaned, currentId: cid, muted: !!p.muted, pointer: validPointer(p.pointer), labelRotation: validLabelRotation(p.labelRotation), palette: validPalette(p.palette), wheelSize: validWheelSize(p.wheelSize), soundPack: validSoundPack(p.soundPack), scene: validScene(p.scene) };
        }
        // v1 migration
        if (parsed && (parsed as PersistV1).version === 1 && Array.isArray((parsed as PersistV1).entries)) {
          const p = parsed as PersistV1;
          const w: Wheel = {
            id: newId(),
            name: "My wheel",
            entries: p.entries.filter((e) => e && typeof e.label === "string").slice(0, 200),
          };
          return { wheels: [w], currentId: w.id, muted: !!p.muted, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE, soundPack: DEFAULT_SOUND_PACK, scene: DEFAULT_SCENE };
        }
      } catch {
        // fall through
      }
      const w = defaultWheel();
      return { wheels: [w], currentId: w.id, muted: false, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE, soundPack: DEFAULT_SOUND_PACK, scene: DEFAULT_SCENE };
    }

    function save() {
      const cw = currentWheel();
      if (cw) cw.entries = entries;
      if (IS_EMBED) return;
      try {
        const data: PersistV2 = { version: 2, wheels, currentId, muted, pointer: pointerCfg, labelRotation, palette, wheelSize, soundPack, scene };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      } catch {
        // ignore quota
      }
    }

    // Debounced wrapper for hot paths (per-keystroke label edits).
    // The in-memory entries are mutated immediately by the caller; only
    // the serialize+localStorage.setItem is deferred. flushPendingSave()
    // forces an immediate write on blur / pagehide to avoid losing the
    // last keystroke.
    let saveDebounceTimer: number | null = null;
    function saveDebounced() {
      if (saveDebounceTimer) window.clearTimeout(saveDebounceTimer);
      saveDebounceTimer = window.setTimeout(() => {
        saveDebounceTimer = null;
        save();
      }, 200);
    }
    function flushPendingSave() {
      if (saveDebounceTimer === null) return;
      window.clearTimeout(saveDebounceTimer);
      saveDebounceTimer = null;
      save();
    }

    function switchWheel(id: string) {
      if (spinning) {
        showToast(t("toast.wait_for_spin"));
        return;
      }
      const w = wheels.find((x) => x.id === id);
      if (!w || w.id === currentId) {
        closePicker();
        return;
      }
      // Persist current wheel's edits before switching
      currentWheel().entries = entries;
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      closePicker();
      showToast(t("toast.switched_to", { name: w.name }));
    }

    function createWheel(name?: string, withEntries?: Entry[]): Wheel | null {
      if (spinning) {
        showToast(t("toast.wait_for_spin"));
        return null;
      }
      if (wheels.length >= MAX_WHEELS) {
        showToast(t("toast.max_wheels", { n: MAX_WHEELS }));
        return null;
      }
      const finalName = (name ?? "").trim().slice(0, MAX_WHEEL_NAME) || `Wheel ${wheels.length + 1}`;
      const w: Wheel = {
        id: newId(),
        name: finalName,
        entries: withEntries ?? [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))],
      };
      // Persist active wheel's current entries
      currentWheel().entries = entries;
      wheels.push(w);
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      return w;
    }

    function renameWheel(id: string, newName: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      const trimmed = newName.trim().slice(0, MAX_WHEEL_NAME);
      if (!trimmed) return;
      w.name = trimmed;
      if (w.importedFromShare) delete w.importedFromShare;
      save();
      renderPicker();
    }

    function duplicateWheel(id: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      if (wheels.length >= MAX_WHEELS) {
        showToast(t("toast.max_wheels", { n: MAX_WHEELS }));
        return;
      }
      const copy: Wheel = {
        id: newId(),
        name: `${w.name} copy`.slice(0, MAX_WHEEL_NAME),
        entries: w.entries.map((e) => ({ ...e, id: newId() })),
      };
      // Persist active wheel's entries before insert
      currentWheel().entries = entries;
      wheels.push(copy);
      currentId = copy.id;
      entries = copy.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(t("toast.duplicated_to", { name: copy.name }));
    }

    function deleteWheel(id: string) {
      if (spinning) {
        showToast(t("toast.wait_for_spin"));
        return;
      }
      if (wheels.length <= 1) {
        showToast(t("toast.cannot_delete_only"));
        return;
      }
      const idx = wheels.findIndex((x) => x.id === id);
      if (idx < 0) return;
      const wasCurrent = wheels[idx].id === currentId;
      const removedName = wheels[idx].name;
      wheels.splice(idx, 1);
      if (wasCurrent) {
        const nextIdx = Math.min(idx, wheels.length - 1);
        currentId = wheels[nextIdx].id;
        entries = wheels[nextIdx].entries;
        rotation = 0;
        lastWinnerIdx = null;
      }
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(t("toast.deleted", { name: removedName }));
    }

    function renderPicker() {
      if (!pickerListEl || !pickerName) return;
      const cw = currentWheel();
      pickerName.textContent = cw.name;
      if (importNotice) importNotice.hidden = !cw.importedFromShare;
      pickerListEl.innerHTML = "";
      for (const w of wheels) {
        const li = document.createElement("li");
        li.setAttribute("role", "none");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "spin-picker-item";
        btn.setAttribute("role", "menuitem");
        if (w.id === currentId) btn.setAttribute("aria-current", "true");
        btn.innerHTML = `
          <svg class="spin-picker-item-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="spin-picker-item-name"></span>
          <span class="spin-picker-item-shared spin-shared-pill" hidden>shared</span>
          <span class="spin-picker-item-count"></span>
        `;
        (btn.querySelector(".spin-picker-item-name") as HTMLElement).textContent = w.name;
        (btn.querySelector(".spin-picker-item-count") as HTMLElement).textContent = String(w.entries.length);
        const sharedEl = btn.querySelector(".spin-picker-item-shared") as HTMLElement;
        if (sharedEl) sharedEl.hidden = !w.importedFromShare;
        btn.addEventListener("click", () => switchWheel(w.id));
        li.appendChild(btn);
        pickerListEl.appendChild(li);
      }
      if (pickerDelete) pickerDelete.disabled = wheels.length <= 1;
      updateEliminateBtn();
      updateAccumulateBtn();
      updateRotationBtn();
      updateModeSingleBtn();
      updateRotationBar();
      updatePickerResetCounts();
      updatePickerClearEntries();
    }

    function openPicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = false;
      pickerBtn.setAttribute("aria-expanded", "true");
      renderPicker();
    }
    function closePicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = true;
      pickerBtn.setAttribute("aria-expanded", "false");
    }
    function togglePicker() {
      if (!pickerPanel) return;
      if (pickerPanel.hidden) openPicker();
      else closePicker();
    }

    function newId(): string {
      return Math.random().toString(36).slice(2, 10);
    }

    function fitCanvas(): number {
      const rect = canvas!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const size = Math.floor(rect.width * dpr);
      if (canvas!.width !== size || canvas!.height !== size) {
        canvas!.width = size;
        canvas!.height = size;
      }
      return dpr;
    }

    function drawWheel() {
      const dpr = fitCanvas();
      const w = canvas!.width;
      const h = canvas!.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(cx, cy) - 2;
      const cssR = r / dpr;

      ctx.clearRect(0, 0, w, h);

      if (entries.length === 0) {
        ctx.fillStyle = "rgba(132, 120, 90, 0.14)";
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fill();
        return;
      }

      const n = entries.length;
      const bounds = sliceBounds();

      // Slices
      for (let i = 0; i < n; i++) {
        const start = rotation + bounds[i] - Math.PI / 2;
        const end = rotation + bounds[i + 1] - Math.PI / 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, start, end);
        ctx.closePath();
        const pal = activePalette();
        ctx.fillStyle = entries[i].color || pal[i % pal.length];
        ctx.fill();
      }

      // Outer ring
      ctx.strokeStyle = "rgba(20, 17, 11, 0.18)";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.stroke();

      // Labels
      const effectiveRotation: "tangent" | "radial" =
        labelRotation === "auto"
          ? n >= AUTO_TANGENT_MIN && n <= AUTO_TANGENT_MAX
            ? "tangent"
            : "radial"
          : labelRotation;

      const tangentLabelR = r * 0.62;
      const radialInnerR = r * 0.28;
      const radialOuterR = r * 0.92;
      const radialLabelR = (radialInnerR + radialOuterR) / 2;
      const labelR = effectiveRotation === "tangent" ? tangentLabelR : radialLabelR;

      // Font sizing is computed in CSS pixels, then scaled by dpr for the
      // canvas-internal font value. This keeps labels crisp on retina and
      // readable on phones, where the canvas is twice the CSS resolution.
      const cssArcAtLabel = (2 * Math.PI * (labelR / dpr)) / n;
      const cssBaseMax = Math.min(26, Math.round(cssR * 0.135));
      const cssArcCap = Math.max(8, Math.floor(cssArcAtLabel * 0.7));
      const cssFontSize = Math.max(8, Math.min(cssBaseMax, cssArcCap));
      const fontSize = Math.round(cssFontSize * dpr);
      ctx.font = `600 ${fontSize}px Inter, system-ui, sans-serif`;
      ctx.textBaseline = "middle";
      ctx.fillStyle = "#fff";
      ctx.shadowColor = "rgba(0, 0, 0, 0.45)";
      ctx.shadowBlur = Math.max(2, fontSize * 0.12);

      for (let i = 0; i < n; i++) {
        const midAngle = (bounds[i] + bounds[i + 1]) / 2;
        const sliceSpan = bounds[i + 1] - bounds[i];
        const mid = rotation + midAngle - Math.PI / 2;
        const text = entries[i].label || "—";
        ctx.save();
        if (effectiveRotation === "tangent") {
          ctx.translate(cx + Math.cos(mid) * tangentLabelR, cy + Math.sin(mid) * tangentLabelR);
          ctx.rotate(mid + Math.PI / 2);
          ctx.textAlign = "center";
          // Tangent maxW = chord of the slice at the label radius minus padding.
          // Floor of r * 0.14 protects very thin slices from collapsing to "…".
          const chord = 2 * tangentLabelR * Math.sin(sliceSpan / 2);
          const maxW = Math.max(r * 0.14, chord * 0.92);
          const displayed = clipText(ctx, text, maxW);
          ctx.fillText(displayed, 0, 0);
        } else {
          ctx.translate(cx + Math.cos(mid) * radialLabelR, cy + Math.sin(mid) * radialLabelR);
          ctx.rotate(mid);
          ctx.textAlign = "center";
          const maxW = radialOuterR - radialInnerR;
          const displayed = clipText(ctx, text, maxW);
          ctx.fillText(displayed, 0, 0);
        }
        ctx.restore();
      }

      ctx.shadowBlur = 0;
    }

    function sliceBounds(): number[] {
      const n = entries.length;
      const bounds = new Array<number>(n + 1);
      bounds[0] = 0;
      let total = 0;
      for (let i = 0; i < n; i++) total += entries[i].weight || 1;
      let cum = 0;
      for (let i = 0; i < n; i++) {
        cum += entries[i].weight || 1;
        bounds[i + 1] = (cum / total) * Math.PI * 2;
      }
      return bounds;
    }

    function indexAt(angle: number, bounds: number[]): number {
      // angle in [0, 2π)
      // binary search bounds[i] <= angle < bounds[i+1]
      let lo = 0;
      let hi = bounds.length - 1;
      while (lo < hi - 1) {
        const mid = (lo + hi) >> 1;
        if (bounds[mid] <= angle) lo = mid;
        else hi = mid;
      }
      return lo;
    }

    function clipText(ctx: CanvasRenderingContext2D, text: string, maxW: number): string {
      if (ctx.measureText(text).width <= maxW) return text;
      let lo = 0, hi = text.length;
      while (lo < hi) {
        const mid = (lo + hi + 1) >>> 1;
        if (ctx.measureText(text.slice(0, mid) + "…").width <= maxW) lo = mid;
        else hi = mid - 1;
      }
      return text.slice(0, lo) + "…";
    }

    let colorPickerTarget: Entry | null = null;
    function openColorPicker(entry: Entry, current: string) {
      if (!colorPicker) return;
      colorPickerTarget = entry;
      // <input type="color"> expects #rrggbb
      colorPicker.value = toColorHex(current);
      colorPicker.click();
    }
    function toColorHex(c: string): string {
      const v = (c || "").trim().toLowerCase();
      if (/^#[0-9a-f]{6}$/.test(v)) return v;
      if (/^#[0-9a-f]{3}$/.test(v)) {
        return (
          "#" + v[1] + v[1] + v[2] + v[2] + v[3] + v[3]
        );
      }
      return "#4850c4";
    }
    if (colorPicker) {
      colorPicker.addEventListener("input", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        drawWheel();
      });
      colorPicker.addEventListener("change", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        clearImportFlag();
        renderList();
        drawWheel();
        save();
        colorPickerTarget = null;
      });
    }

    function updateDuplicateBadges() {
      if (!list) return;
      const counts = new Map<string, number>();
      for (const e of entries) {
        const k = e.label.trim().toLowerCase();
        if (!k) continue;
        counts.set(k, (counts.get(k) || 0) + 1);
      }
      list
        .querySelectorAll<HTMLLIElement>(".spin-list-item")
        .forEach((li, i) => {
          const k = entries[i]?.label.trim().toLowerCase() ?? "";
          const dup = !!k && (counts.get(k) || 0) > 1;
          const input =
            li.querySelector<HTMLInputElement>(".spin-list-input");
          if (input) {
            if (dup) input.setAttribute("aria-invalid", "true");
            else input.removeAttribute("aria-invalid");
          }
          const badge = li.querySelector<HTMLElement>(".spin-list-dup");
          if (badge) badge.hidden = !dup;
        });
    }

    function deleteEntry(id: string, opts?: { offerUndo?: boolean }) {
      const idx = entries.findIndex((e) => e.id === id);
      if (idx < 0) return;
      const removed = entries[idx];
      const cwBefore = currentWheel();
      const wheelIdAtDelete = cwBefore?.id;
      const rosterDropIdx =
        cwBefore?.rotation && cwBefore.rosterSnapshot
          ? cwBefore.rosterSnapshot.indexOf(removed.label.trim())
          : -1;
      entries.splice(idx, 1);
      if (rosterDropIdx >= 0 && cwBefore?.rosterSnapshot) {
        cwBefore.rosterSnapshot.splice(rosterDropIdx, 1);
      }
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      updateRotationBar();
      const inputs = list?.querySelectorAll<HTMLInputElement>(
        ".spin-list-input",
      );
      if (inputs && inputs.length > 0) {
        const targetIdx = Math.min(idx, inputs.length - 1);
        const target = inputs[targetIdx];
        if (target) {
          target.focus();
          try {
            target.setSelectionRange(target.value.length, target.value.length);
          } catch {}
        }
      } else {
        addInput?.focus();
      }
      if (opts?.offerUndo && removed.label.trim()) {
        const snapshot = { ...removed };
        const restoreIdx = idx;
        const restoreWheelId = wheelIdAtDelete;
        const restoreRosterIdx = rosterDropIdx;
        const restoreRosterLabel = removed.label.trim();
        showToast(t("toast.entry_deleted", { name: removed.label }), {
          durationMs: 5000,
          action: {
            label: t("toast.undo"),
            onClick: () => {
              const cwNow = currentWheel();
              if (!cwNow || cwNow.id !== restoreWheelId) return;
              if (entries.some((e) => e.id === snapshot.id)) return;
              const insertAt = Math.min(restoreIdx, entries.length);
              entries.splice(insertAt, 0, snapshot);
              if (
                restoreRosterIdx >= 0 &&
                cwNow.rotation &&
                Array.isArray(cwNow.rosterSnapshot) &&
                !cwNow.rosterSnapshot.includes(restoreRosterLabel)
              ) {
                const rosterAt = Math.min(
                  restoreRosterIdx,
                  cwNow.rosterSnapshot.length,
                );
                cwNow.rosterSnapshot.splice(rosterAt, 0, restoreRosterLabel);
              }
              clearImportFlag();
              renderList();
              drawWheel();
              save();
              updateRotationBar();
              const restored = list?.querySelector<HTMLInputElement>(
                `.spin-list-input[data-id="${CSS.escape(snapshot.id)}"]`,
              );
              if (restored) {
                restored.focus();
                try {
                  restored.setSelectionRange(
                    restored.value.length,
                    restored.value.length,
                  );
                } catch {}
              }
            },
          },
        });
      }
    }

    function moveEntry(id: string, dir: -1 | 1) {
      const idx = entries.findIndex((e) => e.id === id);
      if (idx < 0) return;
      const next = idx + dir;
      if (next < 0 || next >= entries.length) return;
      const focused = document.activeElement as HTMLInputElement | null;
      const wasLabel =
        focused?.tagName === "INPUT" &&
        focused.classList.contains("spin-list-input") &&
        focused.dataset.id === id;
      const selStart = wasLabel ? focused!.selectionStart : null;
      const selEnd = wasLabel ? focused!.selectionEnd : null;
      const [item] = entries.splice(idx, 1);
      entries.splice(next, 0, item);
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      const after = list?.querySelector<HTMLInputElement>(
        `.spin-list-input[data-id="${CSS.escape(id)}"]`,
      );
      if (after) {
        after.focus();
        if (selStart !== null && selEnd !== null) {
          try {
            after.setSelectionRange(selStart, selEnd);
          } catch {}
        }
      }
    }

    type DragState = {
      pointerId: number;
      draggedId: string;
      draggedLi: HTMLLIElement;
      startY: number;
      dropTargetId: string | null;
      dropBefore: boolean;
    };
    let dragState: DragState | null = null;

    function clearDropMarkers() {
      list?.querySelectorAll<HTMLLIElement>(
        ".spin-list-item-drop-before, .spin-list-item-drop-after",
      ).forEach((r) => {
        r.classList.remove(
          "spin-list-item-drop-before",
          "spin-list-item-drop-after",
        );
      });
    }

    function onGripMove(e: PointerEvent) {
      if (!dragState || e.pointerId !== dragState.pointerId) return;
      const dy = e.clientY - dragState.startY;
      dragState.draggedLi.style.transform = `translateY(${dy}px)`;
      const rows = list!.querySelectorAll<HTMLLIElement>(".spin-list-item");
      let closest: HTMLLIElement | null = null;
      let closestDist = Infinity;
      let dropBefore = false;
      rows.forEach((r) => {
        if (r === dragState!.draggedLi) return;
        const rect = r.getBoundingClientRect();
        const mid = rect.top + rect.height / 2;
        const dist = Math.abs(e.clientY - mid);
        if (dist < closestDist) {
          closestDist = dist;
          closest = r;
          dropBefore = e.clientY < mid;
        }
      });
      clearDropMarkers();
      if (closest) {
        (closest as HTMLLIElement).classList.add(
          dropBefore
            ? "spin-list-item-drop-before"
            : "spin-list-item-drop-after",
        );
        const input = (closest as HTMLLIElement).querySelector<HTMLInputElement>(
          ".spin-list-input",
        );
        dragState.dropTargetId = input?.dataset.id || null;
        dragState.dropBefore = dropBefore;
      } else {
        dragState.dropTargetId = null;
      }
    }

    function onGripEnd(e: PointerEvent) {
      if (!dragState || e.pointerId !== dragState.pointerId) return;
      const grip = e.currentTarget as HTMLButtonElement;
      grip.removeEventListener("pointermove", onGripMove);
      grip.removeEventListener("pointerup", onGripEnd);
      grip.removeEventListener("pointercancel", onGripEnd);
      if (grip.hasPointerCapture(e.pointerId)) {
        grip.releasePointerCapture(e.pointerId);
      }
      const { draggedId, draggedLi, dropTargetId, dropBefore } = dragState;
      draggedLi.style.transform = "";
      draggedLi.classList.remove("spin-list-item-dragging");
      clearDropMarkers();
      dragState = null;
      if (!dropTargetId || dropTargetId === draggedId) return;
      const fromIdx = entries.findIndex((x) => x.id === draggedId);
      const targetIdx = entries.findIndex((x) => x.id === dropTargetId);
      if (fromIdx < 0 || targetIdx < 0) return;
      let toIdx = dropBefore ? targetIdx : targetIdx + 1;
      if (fromIdx < toIdx) toIdx -= 1;
      if (toIdx === fromIdx) return;
      const [item] = entries.splice(fromIdx, 1);
      entries.splice(toIdx, 0, item);
      clearImportFlag();
      renderList();
      drawWheel();
      save();
    }

    function startGripDrag(
      e: PointerEvent,
      entryId: string,
      li: HTMLLIElement,
      grip: HTMLButtonElement,
    ) {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      if (dragState) return;
      e.preventDefault();
      try {
        grip.setPointerCapture(e.pointerId);
      } catch {}
      dragState = {
        pointerId: e.pointerId,
        draggedId: entryId,
        draggedLi: li,
        startY: e.clientY,
        dropTargetId: null,
        dropBefore: false,
      };
      li.classList.add("spin-list-item-dragging");
      grip.addEventListener("pointermove", onGripMove);
      grip.addEventListener("pointerup", onGripEnd);
      grip.addEventListener("pointercancel", onGripEnd);
    }

    function renderList() {
      list!.innerHTML = "";
      countEl!.textContent = String(entries.length);
      if (teamsBtn) setTeamCount(getTeamCount());
      if (emptyOverlay) emptyOverlay.hidden = entries.length > 0;
      entries.forEach((entry, i) => {
        const li = document.createElement("li");
        li.className = "spin-list-item";

        const grip = document.createElement("button");
        grip.type = "button";
        grip.className = "spin-list-grip";
        grip.tabIndex = -1;
        grip.setAttribute("aria-hidden", "true");
        grip.title = "Drag to reorder";
        grip.innerHTML =
          '<svg viewBox="0 0 8 14" width="8" height="14" aria-hidden="true">' +
          '<circle cx="2" cy="3" r="1.1" fill="currentColor"/>' +
          '<circle cx="6" cy="3" r="1.1" fill="currentColor"/>' +
          '<circle cx="2" cy="7" r="1.1" fill="currentColor"/>' +
          '<circle cx="6" cy="7" r="1.1" fill="currentColor"/>' +
          '<circle cx="2" cy="11" r="1.1" fill="currentColor"/>' +
          '<circle cx="6" cy="11" r="1.1" fill="currentColor"/>' +
          "</svg>";
        grip.addEventListener("pointerdown", (e) => {
          startGripDrag(e, entry.id, li, grip);
        });
        li.appendChild(grip);

        const color = document.createElement("button");
        color.type = "button";
        color.className = "spin-list-color";
        const pal = activePalette();
        const auto = pal[i % pal.length];
        const effective = entry.color || auto;
        color.style.background = effective;
        color.style.color = effective;
        if (entry.color) color.dataset.custom = "true";
        color.title = entry.color
          ? "Click to change color · shift-click to reset"
          : "Click to choose a color";
        color.setAttribute(
          "aria-label",
          entry.color
            ? `Color for ${entry.label || "entry"}: custom. Shift-click to reset to auto.`
            : `Color for ${entry.label || "entry"}: auto. Click to choose.`,
        );
        color.addEventListener("click", (e) => {
          if ((e as MouseEvent).shiftKey) {
            if (entry.color) {
              entry.color = undefined;
              renderList();
              drawWheel();
              save();
            }
            return;
          }
          openColorPicker(entry, effective);
        });
        color.addEventListener("contextmenu", (e) => {
          if (!entry.color) return;
          e.preventDefault();
          entry.color = undefined;
          renderList();
          drawWheel();
          save();
        });
        li.appendChild(color);

        const input = document.createElement("input");
        input.type = "text";
        input.className = "spin-list-input";
        input.value = entry.label;
        input.maxLength = 80;
        input.dataset.id = entry.id;
        input.dataset.priorLabel = entry.label;
        input.setAttribute("aria-label", `Entry ${i + 1}`);
        input.addEventListener("input", (e) => {
          const target = e.target as HTMLInputElement;
          const newLabel = target.value;
          const oldLabel = target.dataset.priorLabel ?? "";
          entry.label = newLabel;
          const cw = currentWheel();
          if (cw?.rotation && Array.isArray(cw.rosterSnapshot) && oldLabel) {
            const idx = cw.rosterSnapshot.indexOf(oldLabel);
            if (idx >= 0) cw.rosterSnapshot[idx] = newLabel.slice(0, 80);
          }
          target.dataset.priorLabel = newLabel;
          clearImportFlag();
          drawWheel();
          saveDebounced();
          updateDuplicateBadges();
        });
        input.addEventListener("blur", flushPendingSave);
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            addInput!.focus();
            return;
          }
          if (e.altKey && (e.key === "ArrowUp" || e.key === "ArrowDown")) {
            e.preventDefault();
            moveEntry(entry.id, e.key === "ArrowUp" ? -1 : 1);
            return;
          }
          if (
            e.key === "Backspace" &&
            input.value === "" &&
            !e.ctrlKey &&
            !e.metaKey
          ) {
            e.preventDefault();
            deleteEntry(entry.id);
          }
        });
        li.appendChild(input);

        const dupBadge = document.createElement("span");
        dupBadge.className = "spin-list-dup";
        dupBadge.textContent = "dup";
        dupBadge.setAttribute("aria-label", "Duplicate entry");
        dupBadge.title = "Another entry has the same label";
        dupBadge.hidden = true;
        li.appendChild(dupBadge);

        const weight = document.createElement("input");
        weight.type = "number";
        weight.className = "spin-list-weight";
        weight.min = "1";
        weight.max = "10";
        weight.step = "1";
        weight.inputMode = "numeric";
        const wv = entry.weight && entry.weight > 1 ? entry.weight : 1;
        weight.value = String(wv);
        if (wv > 1) weight.dataset.custom = "true";
        weight.title = "Weight (1-10): higher = larger slice + more likely";
        weight.setAttribute(
          "aria-label",
          `Weight for ${entry.label || "entry"} (1-10), currently ${wv}`,
        );
        const commitWeight = () => {
          let v = parseInt(weight.value, 10);
          if (!Number.isFinite(v)) v = 1;
          v = Math.max(1, Math.min(10, Math.round(v)));
          weight.value = String(v);
          clearImportFlag();
          if (v > 1) {
            entry.weight = v;
            weight.dataset.custom = "true";
          } else {
            delete entry.weight;
            delete weight.dataset.custom;
          }
          drawWheel();
          save();
        };
        weight.addEventListener("input", commitWeight);
        weight.addEventListener("change", commitWeight);

        li.appendChild(weight);

        if (currentWheel().accumulate) {
          const wins = document.createElement("span");
          const n = entry.wins || 0;
          wins.className = n > 0 ? "spin-list-wins" : "spin-list-wins spin-list-wins-zero";
          wins.textContent = `× ${n}`;
          wins.setAttribute("aria-label", `${n} ${n === 1 ? "win" : "wins"}`);
          wins.title = "Win count";
          li.appendChild(wins);
        }

        const rm = document.createElement("button");
        rm.type = "button";
        rm.className = "spin-list-remove";
        rm.setAttribute("aria-label", `Remove ${entry.label}`);
        rm.innerHTML =
          '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        rm.addEventListener("click", () =>
          deleteEntry(entry.id, { offerUndo: true }),
        );
        li.appendChild(rm);

        list!.appendChild(li);
      });
      updateDuplicateBadges();
    }

    function addEntry(label: string) {
      const clean = label.trim();
      if (!clean) return;
      entries.push({ id: newId(), label: clean });
      clearImportFlag();
      syncRotationRoster();
      renderList();
      drawWheel();
      save();
      updateRotationBar();
    }

    addForm!.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = addInput!.value;
      addEntry(v);
      addInput!.value = "";
      addInput!.focus();
    });

    bulkApply!.addEventListener("click", () => {
      const raw = bulkInput!.value || "";
      const parts = raw
        .split(/[\n,]/)
        .map((s) => s.trim())
        .filter(Boolean)
        .slice(0, 200);
      if (parts.length === 0) return;
      entries = parts.map((label) => ({ id: newId(), label }));
      const cw = currentWheel();
      if (cw.rotation) cw.rosterSnapshot = parts.slice();
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      updateRotationBar();
      bulkInput!.value = "";
    });

    shuffleBtn!.addEventListener("click", () => {
      for (let i = entries.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [entries[i], entries[j]] = [entries[j], entries[i]];
      }
      clearImportFlag();
      renderList();
      drawWheel();
      save();
    });

    resetBtn!.addEventListener("click", () => {
      if (!confirm("Reset to the default entries?")) return;
      entries = [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))];
      const cw = currentWheel();
      if (cw.rotation) cw.rosterSnapshot = entries.map((e) => e.label);
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      updateRotationBar();
    });

    function easeOutCubicBezier(t: number): number {
      // Approximation of cubic-bezier(0.16, 1, 0.3, 1)
      const c = 1 - t;
      return 1 - c * c * c;
    }

    function spin() {
      if (spinning) return;
      if (entries.length === 0) {
        hintEl!.textContent = "Add at least one entry to spin.";
        return;
      }
      spinning = true;
      centerBtn!.disabled = true;

      // Prime / resume audio context on user gesture (mobile autoplay policy)
      if (!muted) {
        const c = getAudio();
        if (c && c.state === "suspended") {
          c.resume().catch(() => {});
        }
      }

      const n = entries.length;
      const bounds = sliceBounds();

      // Weighted winner pick: probability proportional to slice angular span.
      // Equivalent to picking r uniformly in [0, 2π) and locating containing slice.
      const r = Math.random() * Math.PI * 2;
      const winnerIdx = indexAt(r, bounds);
      const sliceStart = bounds[winnerIdx];
      const sliceEnd = bounds[winnerIdx + 1];
      const sliceSpan = sliceEnd - sliceStart;
      const sliceMid = (sliceStart + sliceEnd) / 2;
      // Wheel slice θ is drawn at screen angle (rotation + θ - PI/2).
      // We want the winning slice's midpoint to land under the pointer,
      // whose screen angle depends on its position (top = -PI/2, right = 0).
      //   rotation + sliceMid - PI/2 ≡ pointerScreenAngle (mod 2π)
      //   rotation ≡ pointerScreenAngle + PI/2 - sliceMid (mod 2π)
      const pa = pointerScreenAngle();
      const targetMod = ((pa + Math.PI / 2 - sliceMid) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
      const turns = 5 + Math.floor(Math.random() * 3); // 5, 6, or 7 full turns
      const currentMod = ((rotation % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
      let deltaToTarget = targetMod - currentMod;
      if (deltaToTarget <= 0) deltaToTarget += Math.PI * 2;
      const totalDelta = turns * Math.PI * 2 + deltaToTarget;
      // Jitter within slice, capped so the pointer never falls outside the
      // winning wedge — vital for narrow (low-weight) slices.
      const jitter = (Math.random() - 0.5) * sliceSpan * 0.7;
      const totalDeltaJittered = totalDelta + jitter;

      const startRotation = rotation;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const duration = reduceMotion ? 420 : 5200 + Math.random() * 800; // 5.2 - 6s; 420ms reduced
      const startTs = performance.now();

      hintEl!.textContent = "Spinning…";

      let lastSliceIdx = -1;
      const twoPi = Math.PI * 2;

      function frame(now: number) {
        const t = Math.min(1, (now - startTs) / duration);
        const eased = easeOutCubicBezier(t);
        rotation = startRotation + totalDeltaJittered * eased;
        drawWheel();

        // Tick whenever the pointer crosses a slice boundary.
        // Solve for wheel-local θ currently at screen angle pa:
        //   rotation + θ - PI/2 ≡ pa  →  θ ≡ pa + PI/2 - rotation
        const norm = ((pa + Math.PI / 2 - rotation) % twoPi + twoPi) % twoPi;
        const curSlice = indexAt(norm, bounds);
        if (curSlice !== lastSliceIdx) {
          lastSliceIdx = curSlice;
          // Skip the very first frame so we don't double-tick at t=0
          if (now - startTs > 30) tick();
        }

        if (t < 1) {
          requestAnimationFrame(frame);
        } else {
          spinning = false;
          centerBtn!.disabled = false;
          lastWinnerIdx = winnerIdx;
          fanfare();
          // Burst from the canvas center on screen for a wheel-anchored feel
          let originX: number | undefined;
          let originY: number | undefined;
          if (canvas) {
            const r = canvas.getBoundingClientRect();
            originX = r.left + r.width / 2;
            originY = r.top + r.height / 2;
          }
          burstConfetti(originX, originY);
          showWinner(entries[winnerIdx]);
        }
      }
      requestAnimationFrame(frame);
    }

    function buildOrder(winnerIdx: number): Entry[] {
      const winner = entries[winnerIdx];
      const rest = entries.filter((_, i) => i !== winnerIdx).slice();
      for (let i = rest.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [rest[i], rest[j]] = [rest[j], rest[i]];
      }
      return [winner, ...rest];
    }

    function maxTeamCount(): number {
      return Math.min(10, Math.max(2, entries.length));
    }

    function getTeamCount(): number {
      const k = currentWheel().teamCount;
      const max = maxTeamCount();
      const start = typeof k === "number" && Number.isFinite(k) ? Math.floor(k) : 3;
      return Math.max(2, Math.min(max, start));
    }

    function setTeamCount(n: number) {
      const clamped = Math.max(2, Math.min(maxTeamCount(), Math.floor(n)));
      const cw = currentWheel();
      const prior = cw.teamCount;
      cw.teamCount = clamped;
      if (prior !== clamped) save();
      if (teamsCountEl) teamsCountEl.textContent = String(clamped);
      if (teamsDec) teamsDec.disabled = clamped <= 2;
      if (teamsInc) teamsInc.disabled = clamped >= maxTeamCount();
      if (teamsBtn) {
        teamsBtn.title = `Split into ${clamped} teams`;
        teamsBtn.setAttribute("aria-label", `Split into ${clamped} teams`);
      }
    }

    function openTeamsConfig() {
      if (entries.length < 4) {
        showToast(t("toast.need_4_teams"));
        return;
      }
      if (!teamsConfig) return;
      closePointerConfig();
      closeLabelrotConfig();
      closePaletteConfig();
      closeSizeConfig();
      closeSoundConfig();
      closeSceneConfig();
      teamsConfig.hidden = false;
      if (teamsBtn) teamsBtn.setAttribute("aria-expanded", "true");
      setTeamCount(getTeamCount());
      (teamsGo as HTMLButtonElement | null)?.focus();
    }

    function closeTeamsConfig() {
