    .spin-embed-textarea {
      width: 100%;
      box-sizing: border-box;
      padding: 0.7rem 0.85rem;
      font-family: var(--font-mono);
      font-size: 12px;
      line-height: 1.5;
      color: var(--content);
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
      resize: vertical;
      margin: 0 0 1rem;
    }
    .spin-embed-textarea:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 1px;
      border-color: var(--accent);
    }

    /* Confetti overlay */
    .spin-confetti {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 60;
    }

    /* Mute toggle icon swap */
    .spin-mute-off { display: none; }
    #spin-mute[aria-pressed="true"] .spin-mute-on { display: none; }
    #spin-mute[aria-pressed="true"] .spin-mute-off { display: inline; }
    #spin-mute[aria-pressed="true"] {
      color: var(--content-4);
    }

    /* Mode-toggle pressed state — eliminate */
    .spin-icon-mode[aria-pressed="true"] {
      color: var(--accent);
      background: color-mix(in oklab, var(--accent) 12%, transparent);
      border-color: color-mix(in oklab, var(--accent) 30%, transparent);
    }

    /* Toast */
    .spin-toast {
      position: fixed;
      bottom: clamp(1rem, 3vw, 2rem);
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      background: var(--content);
      color: var(--surface);
      padding: 0.6rem 1.1rem;
      border-radius: 999px;
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: -0.005em;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
      opacity: 0;
      transition: opacity 0.2s var(--ease-out), transform 0.2s var(--ease-out);
      z-index: 80;
      pointer-events: none;
      max-width: 90vw;
      text-align: center;
    }
    .spin-toast.is-visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    .spin-toast[hidden] {
      display: none;
    }

    /* Reduce motion */
    @media (prefers-reduced-motion: reduce) {
      .spin-modal,
      .spin-modal-card {
        animation: none;
      }
      .spin-confetti {
        display: none;
      }
    }
  </style>

  <script>
    type Entry = { id: string; label: string; color?: string; weight?: number; wins?: number };
    type Wheel = { id: string; name: string; entries: Entry[]; eliminate?: boolean; accumulate?: boolean; teamCount?: number; importedFromShare?: boolean };
    type PointerPos = "top" | "right";
    type PointerColor = "ink" | "accent" | "amber";
    type PointerCfg = { pos: PointerPos; color: PointerColor };
    type LabelRotation = "auto" | "tangent" | "radial";
    type Palette = "paper" | "vibrant" | "pastel" | "mono";
    type WheelSize = "s" | "m" | "l" | "full";
    type PersistV1 = { entries: Entry[]; version: 1; muted?: boolean };
    type PersistV2 = { version: 2; wheels: Wheel[]; currentId: string; muted?: boolean; pointer?: PointerCfg; labelRotation?: LabelRotation; palette?: Palette; wheelSize?: WheelSize };
    type AnyPersist = PersistV1 | PersistV2;

    const STORAGE_KEY = "spinwheel:v1";
    const HISTORY_KEY = "spinwheel:history:v1";
    const IS_EMBED = (() => {
      try { return new URLSearchParams(location.search).get("embed") === "1"; }
      catch { return false; }
    })();
    const HISTORY_CAP = 20;
    const MAX_WHEELS = 20;
    const MAX_WHEEL_NAME = 40;

    type HistoryEntry = { ts: number; wheelName: string; winner: string };
    const DEFAULT_ENTRIES: Entry[] = [
      { id: "1", label: "Pizza" },
      { id: "2", label: "Tacos" },
      { id: "3", label: "Sushi" },
      { id: "4", label: "Ramen" },
      { id: "5", label: "Burger" },
      { id: "6", label: "Salad" },
    ];
    const PALETTES: Record<Palette, string[]> = {
      paper: [
        "#4850c4", // truffle indigo
        "#6a7d3b", // moss
        "#b07d2a", // amber
        "#a14a2a", // rust
        "#3b3527", // ink-2
        "#84785a", // paper-500
        "#5d68d0", // truffle-400
        "#3b41a3", // truffle-600
      ],
      vibrant: [
        "#e63946", // crimson
        "#f48c06", // orange
        "#ffba08", // gold
        "#5cb85c", // green
        "#0aa6b7", // teal
        "#4361ee", // blue
        "#8338ec", // violet
        "#ef476f", // rose
      ],
      pastel: [
        "#e0a3a3", // dusty rose
        "#e8b58b", // peach
        "#dfc97b", // butter
        "#a8c98a", // sage
        "#90c0cc", // sky
        "#a3a8d8", // lavender
        "#bea2cf", // lilac
        "#d8a3b3", // blush
      ],
      mono: [
        "#2e2519", // ink-1
        "#3b3527", // ink-2
        "#4e4633", // ink-3
        "#665b44", // ink-4
        "#84785a", // paper-500
        "#a39682", // paper-400
        "#b8ad9a", // paper-300
        "#cec2af", // paper-200
      ],
    };
    const DEFAULT_PALETTE: Palette = "paper";
    function validPalette(v: unknown): Palette {
      return v === "paper" || v === "vibrant" || v === "pastel" || v === "mono" ? v : DEFAULT_PALETTE;
    }

    const DEFAULT_POINTER: PointerCfg = { pos: "top", color: "ink" };
    function validPointer(p: unknown): PointerCfg {
      const out: PointerCfg = { pos: "top", color: "ink" };
      if (p && typeof p === "object") {
        const o = p as { pos?: unknown; color?: unknown };
        if (o.pos === "top" || o.pos === "right") out.pos = o.pos;
        if (o.color === "ink" || o.color === "accent" || o.color === "amber") out.color = o.color;
      }
      return out;
    }

    const DEFAULT_LABEL_ROTATION: LabelRotation = "auto";
    function validLabelRotation(v: unknown): LabelRotation {
      return v === "tangent" || v === "radial" || v === "auto" ? v : DEFAULT_LABEL_ROTATION;
    }
    const AUTO_TANGENT_MIN = 7;
    const AUTO_TANGENT_MAX = 16;

    const DEFAULT_WHEEL_SIZE: WheelSize = "l";
    function validWheelSize(v: unknown): WheelSize {
      return v === "s" || v === "m" || v === "l" || v === "full" ? v : DEFAULT_WHEEL_SIZE;
    }

    const canvas = document.getElementById("spin-canvas") as HTMLCanvasElement | null;
    const centerBtn = document.getElementById("spin-center") as HTMLButtonElement | null;
    const list = document.getElementById("spin-list") as HTMLUListElement | null;
    const countEl = document.getElementById("spin-count");
    const addForm = document.getElementById("spin-add-form") as HTMLFormElement | null;
    const addInput = document.getElementById("spin-add-input") as HTMLInputElement | null;
    const bulkInput = document.getElementById("spin-bulk-input") as HTMLTextAreaElement | null;
    const bulkApply = document.getElementById("spin-bulk-apply");
    const shuffleBtn = document.getElementById("spin-shuffle");
    const resetBtn = document.getElementById("spin-reset");
    const shareBtn = document.getElementById("spin-share");
    const muteBtn = document.getElementById("spin-mute");
    const eliminateBtn = document.getElementById("spin-eliminate");
    const accumulateBtn = document.getElementById("spin-accumulate");
    const orderBtn = document.getElementById("spin-order");
    const orderList = document.getElementById("spin-order-list") as HTMLOListElement | null;
    const teamsBtn = document.getElementById("spin-teams") as HTMLButtonElement | null;
    const teamsConfig = document.getElementById("spin-teams-config") as HTMLDivElement | null;
    const teamsCountEl = document.getElementById("spin-teams-count") as HTMLSpanElement | null;
    const teamsDec = document.getElementById("spin-teams-dec") as HTMLButtonElement | null;
    const teamsInc = document.getElementById("spin-teams-inc") as HTMLButtonElement | null;
    const teamsGo = document.getElementById("spin-teams-go") as HTMLButtonElement | null;
    const teamsCancel = document.getElementById("spin-teams-cancel") as HTMLButtonElement | null;
    const teamsList = document.getElementById("spin-teams-list") as HTMLDivElement | null;
    const pointerEl = document.querySelector(".spin-pointer") as HTMLDivElement | null;
    const pointerBtn = document.getElementById("spin-pointer-btn") as HTMLButtonElement | null;
    const pointerConfig = document.getElementById("spin-pointer-config") as HTMLDivElement | null;
    const pointerPosTop = document.getElementById("spin-pointer-pos-top") as HTMLButtonElement | null;
    const pointerPosRight = document.getElementById("spin-pointer-pos-right") as HTMLButtonElement | null;
    const pointerCancel = document.getElementById("spin-pointer-cancel") as HTMLButtonElement | null;
    const pointerSwatches = document.querySelectorAll<HTMLButtonElement>(".spin-pointer-swatch");
    const labelrotBtn = document.getElementById("spin-labelrot-btn") as HTMLButtonElement | null;
    const labelrotConfig = document.getElementById("spin-labelrot-config") as HTMLDivElement | null;
    const labelrotCancel = document.getElementById("spin-labelrot-cancel") as HTMLButtonElement | null;
    const labelrotChips = document.querySelectorAll<HTMLButtonElement>(".spin-labelrot-chip");
    const paletteBtn = document.getElementById("spin-palette-btn") as HTMLButtonElement | null;
    const paletteConfig = document.getElementById("spin-palette-config") as HTMLDivElement | null;
    const paletteChipsHost = document.getElementById("spin-palette-chips") as HTMLDivElement | null;
    const paletteCancel = document.getElementById("spin-palette-cancel") as HTMLButtonElement | null;
    const sizeBtn = document.getElementById("spin-size-btn") as HTMLButtonElement | null;
    const sizeConfig = document.getElementById("spin-size-config") as HTMLDivElement | null;
    const sizeCancel = document.getElementById("spin-size-cancel") as HTMLButtonElement | null;
    const sizeChips = document.querySelectorAll<HTMLButtonElement>(".spin-size-chip");
    const wheelFrame = document.querySelector(".spin-wheel-frame") as HTMLDivElement | null;
    const historyList = document.getElementById("spin-history-list") as HTMLUListElement | null;
    const historyCount = document.getElementById("spin-history-count") as HTMLSpanElement | null;
    const helpModal = document.getElementById("spin-help") as HTMLDivElement | null;
    const helpCloseX = document.getElementById("spin-help-close-x") as HTMLButtonElement | null;
    const historyClear = document.getElementById("spin-history-clear") as HTMLButtonElement | null;
    const pickerResetCounts = document.getElementById("spin-picker-reset-counts") as HTMLButtonElement | null;
    const modalLabelEl = document.getElementById("spin-modal-label");
    const hintEl = document.getElementById("spin-hint");
    const modal = document.getElementById("spin-winner") as HTMLDivElement | null;
    const winnerName = document.getElementById("spin-winner-name");
    const removeBtn = document.getElementById("spin-winner-remove");
    const againBtn = document.getElementById("spin-winner-again");
    const closeBtn = document.getElementById("spin-winner-close");
    const shareImgBtn = document.getElementById("spin-winner-share") as HTMLButtonElement | null;
    const confetti = document.getElementById("spin-confetti") as HTMLCanvasElement | null;
    const toast = document.getElementById("spin-toast") as HTMLDivElement | null;
    const pickerBtn = document.getElementById("spin-picker-btn") as HTMLButtonElement | null;
    const pickerName = document.getElementById("spin-picker-name");
    const importNotice = document.getElementById("spin-import-notice");
    const pickerPanel = document.getElementById("spin-picker-panel") as HTMLDivElement | null;
    const pickerListEl = document.getElementById("spin-picker-list") as HTMLUListElement | null;
    const pickerNew = document.getElementById("spin-picker-new");
    const pickerRename = document.getElementById("spin-picker-rename");
    const pickerDupe = document.getElementById("spin-picker-dupe");
    const pickerDelete = document.getElementById("spin-picker-delete") as HTMLButtonElement | null;
    const pickerExport = document.getElementById("spin-picker-export");
    const pickerImport = document.getElementById("spin-picker-import");
    const pickerEmbed = document.getElementById("spin-picker-embed");
    const embedModal = document.getElementById("spin-embed-modal") as HTMLDivElement | null;
    const embedCode = document.getElementById("spin-embed-code") as HTMLTextAreaElement | null;
    const embedX = document.getElementById("spin-embed-x") as HTMLButtonElement | null;
    const embedCopy = document.getElementById("spin-embed-copy") as HTMLButtonElement | null;
    const embedCloseBtn = document.getElementById("spin-embed-close") as HTMLButtonElement | null;
    const importFileInput = document.getElementById("spin-import-file") as HTMLInputElement | null;
    const colorPicker = document.getElementById("spin-color-picker") as HTMLInputElement | null;

    if (!canvas || !centerBtn || !list || !addForm || !addInput || !modal) {
      console.error("[spin] missing required DOM nodes");
    }

    const ctx = canvas!.getContext("2d")!;
    const confettiCtx = confetti ? confetti.getContext("2d") : null;

    const initialState = loadState();
    let wheels: Wheel[] = initialState.wheels;
    let currentId: string = initialState.currentId;
    let muted: boolean = initialState.muted;
    let pointerCfg: PointerCfg = initialState.pointer;
    let labelRotation: LabelRotation = initialState.labelRotation;
    let palette: Palette = initialState.palette;
    let wheelSize: WheelSize = initialState.wheelSize;
    function activePalette(): string[] { return PALETTES[palette]; }

    function currentWheel(): Wheel {
      return wheels.find((w) => w.id === currentId) ?? wheels[0];
    }
    function currentEntries(): Entry[] {
      return currentWheel().entries;
    }

    // Called from entry-mutation paths after a shared-link import so the
    // "shared" pill clears as soon as the user takes ownership of the wheel.
    function clearImportFlag(w?: Wheel) {
      const target = w ?? currentWheel();
      if (target && target.importedFromShare) {
        delete target.importedFromShare;
        save();
        renderPicker();
      }
    }

    // entries alias targets the active wheel
    let entries: Entry[] = currentEntries();
    let rotation = 0;
    let spinning = false;
    // True between showWinner and hideWinner when eliminate mode is active
    // and the displayed winner is not the implicit champion.
    let pendingEliminate = false;
    let lastWinnerIdx: number | null = null;
    // One-shot flag set by the "Spin for order" button. When true, the next
    // showWinner reveals the full ordering instead of a single winner.
    let orderSpinPending = false;
    // Same pattern for team-split: the next showWinner reveals K teams.
    let teamSpinPending = false;

    let history: HistoryEntry[] = loadHistory();

    function loadHistory(): HistoryEntry[] {
      try {
        const raw = localStorage.getItem(HISTORY_KEY);
        if (!raw) return [];
        const arr = JSON.parse(raw);
        if (!Array.isArray(arr)) return [];
        return arr
          .filter(
            (e: any) =>
              e &&
              typeof e.ts === "number" &&
              Number.isFinite(e.ts) &&
              typeof e.wheelName === "string" &&
              typeof e.winner === "string"
          )
          .slice(0, HISTORY_CAP)
          .map((e: any) => ({
            ts: e.ts,
            wheelName: e.wheelName.slice(0, MAX_WHEEL_NAME),
            winner: e.winner.slice(0, 80),
          }));
      } catch {
        return [];
      }
    }

    function saveHistory() {
      if (IS_EMBED) return;
      try {
        localStorage.setItem(HISTORY_KEY, JSON.stringify(history.slice(0, HISTORY_CAP)));
      } catch {}
    }

    function pushHistory(entry: Entry) {
      history.unshift({
        ts: Date.now(),
        wheelName: currentWheel().name,
        winner: entry.label,
      });
      if (history.length > HISTORY_CAP) history.length = HISTORY_CAP;
      saveHistory();
      renderHistory();
    }

    function relativeTime(ts: number, now: number): string {
      const diff = Math.max(0, now - ts);
      const m = Math.floor(diff / 60000);
      if (m < 1) return "just now";
      if (m < 60) return `${m}m ago`;
      const h = Math.floor(m / 60);
      if (h < 24) return `${h}h ago`;
      const d = Math.floor(h / 24);
      if (d < 7) return `${d}d ago`;
      const date = new Date(ts);
      const month = date.getMonth() + 1;
      const day = date.getDate();
      return `${month}/${day}`;
    }

    function loadState(): { wheels: Wheel[]; currentId: string; muted: boolean; pointer: PointerCfg; labelRotation: LabelRotation; palette: Palette; wheelSize: WheelSize } {
      const defaultWheel = (): Wheel => ({
        id: newId(),
        name: "My wheel",
        entries: [...DEFAULT_ENTRIES],
      });
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) {
          const w = defaultWheel();
          return { wheels: [w], currentId: w.id, muted: false, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE };
        }
        const parsed = JSON.parse(raw) as AnyPersist;
        if (parsed && (parsed as PersistV2).version === 2 && Array.isArray((parsed as PersistV2).wheels)) {
          const p = parsed as PersistV2;
          const cleaned: Wheel[] = p.wheels
            .filter((w) => w && typeof w.id === "string" && typeof w.name === "string" && Array.isArray(w.entries))
            .map((w) => {
              const entries = w.entries
                .filter((e) => e && typeof e.label === "string")
                .slice(0, 200)
                .map((e) => {
                  if (typeof e.wins === "number" && Number.isFinite(e.wins) && e.wins > 0) {
                    e.wins = Math.max(0, Math.min(9999, Math.floor(e.wins)));
                  } else if ("wins" in e) {
                    delete e.wins;
                  }
                  return e;
                });
              const out: Wheel = {
                id: w.id,
                name: w.name.slice(0, MAX_WHEEL_NAME) || "Untitled",
                entries,
              };
              if (w.eliminate === true) out.eliminate = true;
              if (w.accumulate === true) out.accumulate = true;
              if (typeof w.teamCount === "number" && Number.isFinite(w.teamCount)) {
                const tc = Math.floor(w.teamCount);
                if (tc >= 2 && tc <= 10) out.teamCount = tc;
              }
              if (w.importedFromShare === true) out.importedFromShare = true;
              return out;
            })
            .slice(0, MAX_WHEELS);
          if (cleaned.length === 0) {
            const w = defaultWheel();
            return { wheels: [w], currentId: w.id, muted: !!p.muted, pointer: validPointer(p.pointer), labelRotation: validLabelRotation(p.labelRotation), palette: validPalette(p.palette), wheelSize: validWheelSize(p.wheelSize) };
          }
          const cid = cleaned.find((w) => w.id === p.currentId)?.id ?? cleaned[0].id;
          return { wheels: cleaned, currentId: cid, muted: !!p.muted, pointer: validPointer(p.pointer), labelRotation: validLabelRotation(p.labelRotation), palette: validPalette(p.palette), wheelSize: validWheelSize(p.wheelSize) };
        }
        // v1 migration
        if (parsed && (parsed as PersistV1).version === 1 && Array.isArray((parsed as PersistV1).entries)) {
          const p = parsed as PersistV1;
          const w: Wheel = {
            id: newId(),
            name: "My wheel",
            entries: p.entries.filter((e) => e && typeof e.label === "string").slice(0, 200),
          };
          return { wheels: [w], currentId: w.id, muted: !!p.muted, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE };
        }
      } catch {
        // fall through
      }
      const w = defaultWheel();
      return { wheels: [w], currentId: w.id, muted: false, pointer: { ...DEFAULT_POINTER }, labelRotation: DEFAULT_LABEL_ROTATION, palette: DEFAULT_PALETTE, wheelSize: DEFAULT_WHEEL_SIZE };
    }

    function save() {
      const cw = currentWheel();
      if (cw) cw.entries = entries;
      if (IS_EMBED) return;
      try {
        const data: PersistV2 = { version: 2, wheels, currentId, muted, pointer: pointerCfg, labelRotation, palette, wheelSize };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      } catch {
        // ignore quota
      }
    }

    function switchWheel(id: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      const w = wheels.find((x) => x.id === id);
      if (!w || w.id === currentId) {
        closePicker();
        return;
      }
      // Persist current wheel's edits before switching
      currentWheel().entries = entries;
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      closePicker();
      showToast(`Switched to ${w.name}`);
    }

    function createWheel(name?: string, withEntries?: Entry[]): Wheel | null {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return null;
      }
      if (wheels.length >= MAX_WHEELS) {
        showToast(`Max ${MAX_WHEELS} wheels`);
        return null;
      }
      const finalName = (name ?? "").trim().slice(0, MAX_WHEEL_NAME) || `Wheel ${wheels.length + 1}`;
      const w: Wheel = {
        id: newId(),
        name: finalName,
        entries: withEntries ?? [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))],
      };
      // Persist active wheel's current entries
      currentWheel().entries = entries;
      wheels.push(w);
      currentId = w.id;
      entries = w.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      return w;
    }

    function renameWheel(id: string, newName: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      const trimmed = newName.trim().slice(0, MAX_WHEEL_NAME);
      if (!trimmed) return;
      w.name = trimmed;
      if (w.importedFromShare) delete w.importedFromShare;
      save();
      renderPicker();
    }

    function duplicateWheel(id: string) {
      const w = wheels.find((x) => x.id === id);
      if (!w) return;
      if (wheels.length >= MAX_WHEELS) {
        showToast(`Max ${MAX_WHEELS} wheels`);
        return;
      }
      const copy: Wheel = {
        id: newId(),
        name: `${w.name} copy`.slice(0, MAX_WHEEL_NAME),
        entries: w.entries.map((e) => ({ ...e, id: newId() })),
      };
      // Persist active wheel's entries before insert
      currentWheel().entries = entries;
      wheels.push(copy);
      currentId = copy.id;
      entries = copy.entries;
      rotation = 0;
      lastWinnerIdx = null;
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(`Duplicated to ${copy.name}`);
    }

    function deleteWheel(id: string) {
      if (spinning) {
        showToast("Wait for the spin to finish");
        return;
      }
      if (wheels.length <= 1) {
        showToast("Cannot delete the only wheel");
        return;
      }
      const idx = wheels.findIndex((x) => x.id === id);
      if (idx < 0) return;
      const wasCurrent = wheels[idx].id === currentId;
      const removedName = wheels[idx].name;
      wheels.splice(idx, 1);
      if (wasCurrent) {
        const nextIdx = Math.min(idx, wheels.length - 1);
        currentId = wheels[nextIdx].id;
        entries = wheels[nextIdx].entries;
        rotation = 0;
        lastWinnerIdx = null;
      }
      save();
      renderPicker();
      renderList();
      drawWheel();
      showToast(`Deleted ${removedName}`);
    }

    function renderPicker() {
      if (!pickerListEl || !pickerName) return;
      const cw = currentWheel();
      pickerName.textContent = cw.name;
      if (importNotice) importNotice.hidden = !cw.importedFromShare;
      pickerListEl.innerHTML = "";
      for (const w of wheels) {
        const li = document.createElement("li");
        li.setAttribute("role", "none");
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "spin-picker-item";
        btn.setAttribute("role", "menuitem");
        if (w.id === currentId) btn.setAttribute("aria-current", "true");
        btn.innerHTML = `
          <svg class="spin-picker-item-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          <span class="spin-picker-item-name"></span>
          <span class="spin-picker-item-shared spin-shared-pill" hidden>shared</span>
          <span class="spin-picker-item-count"></span>
        `;
        (btn.querySelector(".spin-picker-item-name") as HTMLElement).textContent = w.name;
        (btn.querySelector(".spin-picker-item-count") as HTMLElement).textContent = String(w.entries.length);
        const sharedEl = btn.querySelector(".spin-picker-item-shared") as HTMLElement;
        if (sharedEl) sharedEl.hidden = !w.importedFromShare;
        btn.addEventListener("click", () => switchWheel(w.id));
        li.appendChild(btn);
        pickerListEl.appendChild(li);
      }
      if (pickerDelete) pickerDelete.disabled = wheels.length <= 1;
      updateEliminateBtn();
      updateAccumulateBtn();
      updatePickerResetCounts();
    }

    function openPicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = false;
      pickerBtn.setAttribute("aria-expanded", "true");
      renderPicker();
    }
    function closePicker() {
      if (!pickerPanel || !pickerBtn) return;
      pickerPanel.hidden = true;
      pickerBtn.setAttribute("aria-expanded", "false");
    }
    function togglePicker() {
      if (!pickerPanel) return;
      if (pickerPanel.hidden) openPicker();
      else closePicker();
    }

    function newId(): string {
      return Math.random().toString(36).slice(2, 10);
    }

    function fitCanvas(): number {
      const rect = canvas!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      const size = Math.floor(rect.width * dpr);
      if (canvas!.width !== size || canvas!.height !== size) {
        canvas!.width = size;
        canvas!.height = size;
      }
      return dpr;
    }

    function drawWheel() {
      const dpr = fitCanvas();
      const w = canvas!.width;
      const h = canvas!.height;
      const cx = w / 2;
      const cy = h / 2;
      const r = Math.min(cx, cy) - 2;
      const cssR = r / dpr;

      ctx.clearRect(0, 0, w, h);

      if (entries.length === 0) {
        ctx.fillStyle = "rgba(132, 120, 90, 0.18)";
        ctx.beginPath();
        ctx.arc(cx, cy, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = "rgba(132, 120, 90, 0.6)";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.font = `italic ${Math.round(cssR * 0.12 * dpr)}px Fraunces, Georgia, serif`;
        ctx.fillText("Add an entry to begin", cx, cy);
        return;
      }

      const n = entries.length;
      const bounds = sliceBounds();

      // Slices
      for (let i = 0; i < n; i++) {
        const start = rotation + bounds[i] - Math.PI / 2;
        const end = rotation + bounds[i + 1] - Math.PI / 2;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, start, end);
        ctx.closePath();
        const pal = activePalette();
        ctx.fillStyle = entries[i].color || pal[i % pal.length];
        ctx.fill();
      }

      // Outer ring
      ctx.strokeStyle = "rgba(20, 17, 11, 0.18)";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, Math.PI * 2);
      ctx.stroke();

      // Labels
      const effectiveRotation: "tangent" | "radial" =
        labelRotation === "auto"
          ? n >= AUTO_TANGENT_MIN && n <= AUTO_TANGENT_MAX
            ? "tangent"
            : "radial"
          : labelRotation;

      const tangentLabelR = r * 0.62;
      const radialInnerR = r * 0.28;
      const radialOuterR = r * 0.92;
      const radialLabelR = (radialInnerR + radialOuterR) / 2;
      const labelR = effectiveRotation === "tangent" ? tangentLabelR : radialLabelR;

      // Font sizing is computed in CSS pixels, then scaled by dpr for the
      // canvas-internal font value. This keeps labels crisp on retina and
      // readable on phones, where the canvas is twice the CSS resolution.
      const cssArcAtLabel = (2 * Math.PI * (labelR / dpr)) / n;
      const cssBaseMax = Math.min(26, Math.round(cssR * 0.135));
      const cssArcCap = Math.max(8, Math.floor(cssArcAtLabel * 0.7));
      const cssFontSize = Math.max(8, Math.min(cssBaseMax, cssArcCap));
      const fontSize = Math.round(cssFontSize * dpr);
      ctx.font = `600 ${fontSize}px Inter, system-ui, sans-serif`;
      ctx.textBaseline = "middle";
      ctx.fillStyle = "#fff";
      ctx.shadowColor = "rgba(0, 0, 0, 0.45)";
      ctx.shadowBlur = Math.max(2, fontSize * 0.12);

      for (let i = 0; i < n; i++) {
        const midAngle = (bounds[i] + bounds[i + 1]) / 2;
        const sliceSpan = bounds[i + 1] - bounds[i];
        const mid = rotation + midAngle - Math.PI / 2;
        const text = entries[i].label || "—";
        ctx.save();
        if (effectiveRotation === "tangent") {
          ctx.translate(cx + Math.cos(mid) * tangentLabelR, cy + Math.sin(mid) * tangentLabelR);
          ctx.rotate(mid + Math.PI / 2);
          ctx.textAlign = "center";
          // Tangent maxW = chord of the slice at the label radius minus padding.
          // Floor of r * 0.14 protects very thin slices from collapsing to "…".
          const chord = 2 * tangentLabelR * Math.sin(sliceSpan / 2);
          const maxW = Math.max(r * 0.14, chord * 0.92);
          const displayed = clipText(ctx, text, maxW);
          ctx.fillText(displayed, 0, 0);
        } else {
          ctx.translate(cx + Math.cos(mid) * radialLabelR, cy + Math.sin(mid) * radialLabelR);
          ctx.rotate(mid);
          ctx.textAlign = "center";
          const maxW = radialOuterR - radialInnerR;
          const displayed = clipText(ctx, text, maxW);
          ctx.fillText(displayed, 0, 0);
        }
        ctx.restore();
      }

      ctx.shadowBlur = 0;
    }

    function sliceBounds(): number[] {
      const n = entries.length;
      const bounds = new Array<number>(n + 1);
      bounds[0] = 0;
      let total = 0;
      for (let i = 0; i < n; i++) total += entries[i].weight || 1;
      let cum = 0;
      for (let i = 0; i < n; i++) {
        cum += entries[i].weight || 1;
        bounds[i + 1] = (cum / total) * Math.PI * 2;
      }
      return bounds;
    }

    function indexAt(angle: number, bounds: number[]): number {
      // angle in [0, 2π)
      // binary search bounds[i] <= angle < bounds[i+1]
      let lo = 0;
      let hi = bounds.length - 1;
      while (lo < hi - 1) {
        const mid = (lo + hi) >> 1;
        if (bounds[mid] <= angle) lo = mid;
        else hi = mid;
      }
      return lo;
    }

    function clipText(ctx: CanvasRenderingContext2D, text: string, maxW: number): string {
      if (ctx.measureText(text).width <= maxW) return text;
      let lo = 0, hi = text.length;
      while (lo < hi) {
        const mid = (lo + hi + 1) >>> 1;
        if (ctx.measureText(text.slice(0, mid) + "…").width <= maxW) lo = mid;
        else hi = mid - 1;
      }
      return text.slice(0, lo) + "…";
    }

    let colorPickerTarget: Entry | null = null;
    function openColorPicker(entry: Entry, current: string) {
      if (!colorPicker) return;
      colorPickerTarget = entry;
      // <input type="color"> expects #rrggbb
      colorPicker.value = toColorHex(current);
      colorPicker.click();
    }
    function toColorHex(c: string): string {
      const v = (c || "").trim().toLowerCase();
      if (/^#[0-9a-f]{6}$/.test(v)) return v;
      if (/^#[0-9a-f]{3}$/.test(v)) {
        return (
          "#" + v[1] + v[1] + v[2] + v[2] + v[3] + v[3]
        );
      }
      return "#4850c4";
    }
    if (colorPicker) {
      colorPicker.addEventListener("input", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        drawWheel();
      });
      colorPicker.addEventListener("change", () => {
        if (!colorPickerTarget) return;
        colorPickerTarget.color = colorPicker.value;
        clearImportFlag();
        renderList();
        drawWheel();
        save();
        colorPickerTarget = null;
      });
    }

    function updateDuplicateBadges() {
      if (!list) return;
      const counts = new Map<string, number>();
      for (const e of entries) {
        const k = e.label.trim().toLowerCase();
        if (!k) continue;
        counts.set(k, (counts.get(k) || 0) + 1);
      }
      list
        .querySelectorAll<HTMLLIElement>(".spin-list-item")
        .forEach((li, i) => {
          const k = entries[i]?.label.trim().toLowerCase() ?? "";
          const dup = !!k && (counts.get(k) || 0) > 1;
          const input =
            li.querySelector<HTMLInputElement>(".spin-list-input");
          if (input) {
            if (dup) input.setAttribute("aria-invalid", "true");
            else input.removeAttribute("aria-invalid");
          }
          const badge = li.querySelector<HTMLElement>(".spin-list-dup");
          if (badge) badge.hidden = !dup;
        });
    }

    function deleteEntry(id: string) {
      const idx = entries.findIndex((e) => e.id === id);
      if (idx < 0) return;
      entries.splice(idx, 1);
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      const inputs = list?.querySelectorAll<HTMLInputElement>(
        ".spin-list-input",
      );
      if (inputs && inputs.length > 0) {
        const targetIdx = Math.min(idx, inputs.length - 1);
        const target = inputs[targetIdx];
        if (target) {
          target.focus();
          try {
            target.setSelectionRange(target.value.length, target.value.length);
          } catch {}
        }
      } else {
        addInput?.focus();
      }
    }

    function moveEntry(id: string, dir: -1 | 1) {
      const idx = entries.findIndex((e) => e.id === id);
      if (idx < 0) return;
      const next = idx + dir;
      if (next < 0 || next >= entries.length) return;
      const focused = document.activeElement as HTMLInputElement | null;
      const wasLabel =
        focused?.tagName === "INPUT" &&
        focused.classList.contains("spin-list-input") &&
        focused.dataset.id === id;
      const selStart = wasLabel ? focused!.selectionStart : null;
      const selEnd = wasLabel ? focused!.selectionEnd : null;
      const [item] = entries.splice(idx, 1);
      entries.splice(next, 0, item);
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      const after = list?.querySelector<HTMLInputElement>(
        `.spin-list-input[data-id="${CSS.escape(id)}"]`,
      );
      if (after) {
        after.focus();
        if (selStart !== null && selEnd !== null) {
          try {
            after.setSelectionRange(selStart, selEnd);
          } catch {}
        }
      }
    }

    function renderList() {
      list!.innerHTML = "";
      countEl!.textContent = String(entries.length);
      if (teamsBtn) setTeamCount(getTeamCount());
      entries.forEach((entry, i) => {
        const li = document.createElement("li");
        li.className = "spin-list-item";

        const color = document.createElement("button");
        color.type = "button";
        color.className = "spin-list-color";
        const pal = activePalette();
        const auto = pal[i % pal.length];
        const effective = entry.color || auto;
        color.style.background = effective;
        color.style.color = effective;
        if (entry.color) color.dataset.custom = "true";
        color.title = entry.color
          ? "Click to change color · shift-click to reset"
          : "Click to choose a color";
        color.setAttribute(
          "aria-label",
          entry.color
            ? `Color for ${entry.label || "entry"}: custom. Shift-click to reset to auto.`
            : `Color for ${entry.label || "entry"}: auto. Click to choose.`,
        );
        color.addEventListener("click", (e) => {
          if ((e as MouseEvent).shiftKey) {
            if (entry.color) {
              entry.color = undefined;
              renderList();
              drawWheel();
              save();
            }
            return;
          }
          openColorPicker(entry, effective);
        });
        color.addEventListener("contextmenu", (e) => {
          if (!entry.color) return;
          e.preventDefault();
          entry.color = undefined;
          renderList();
          drawWheel();
          save();
        });
        li.appendChild(color);

        const input = document.createElement("input");
        input.type = "text";
        input.className = "spin-list-input";
        input.value = entry.label;
        input.maxLength = 80;
        input.dataset.id = entry.id;
        input.setAttribute("aria-label", `Entry ${i + 1}`);
        input.addEventListener("input", (e) => {
          entry.label = (e.target as HTMLInputElement).value;
          clearImportFlag();
          drawWheel();
          save();
          updateDuplicateBadges();
        });
        input.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            e.preventDefault();
            addInput!.focus();
            return;
          }
          if (e.altKey && (e.key === "ArrowUp" || e.key === "ArrowDown")) {
            e.preventDefault();
            moveEntry(entry.id, e.key === "ArrowUp" ? -1 : 1);
            return;
          }
          if (
            e.key === "Backspace" &&
            input.value === "" &&
            !e.ctrlKey &&
            !e.metaKey
          ) {
            e.preventDefault();
            deleteEntry(entry.id);
          }
        });
        li.appendChild(input);

        const dupBadge = document.createElement("span");
        dupBadge.className = "spin-list-dup";
        dupBadge.textContent = "dup";
        dupBadge.setAttribute("aria-label", "Duplicate entry");
        dupBadge.title = "Another entry has the same label";
        dupBadge.hidden = true;
        li.appendChild(dupBadge);

        const weight = document.createElement("input");
        weight.type = "number";
        weight.className = "spin-list-weight";
        weight.min = "1";
        weight.max = "10";
        weight.step = "1";
        weight.inputMode = "numeric";
        const wv = entry.weight && entry.weight > 1 ? entry.weight : 1;
        weight.value = String(wv);
        if (wv > 1) weight.dataset.custom = "true";
        weight.title = "Weight (1-10): higher = larger slice + more likely";
        weight.setAttribute(
          "aria-label",
          `Weight for ${entry.label || "entry"} (1-10), currently ${wv}`,
        );
        const commitWeight = () => {
          let v = parseInt(weight.value, 10);
          if (!Number.isFinite(v)) v = 1;
          v = Math.max(1, Math.min(10, Math.round(v)));
          weight.value = String(v);
          clearImportFlag();
          if (v > 1) {
            entry.weight = v;
            weight.dataset.custom = "true";
          } else {
            delete entry.weight;
            delete weight.dataset.custom;
          }
          drawWheel();
          save();
        };
        weight.addEventListener("input", commitWeight);
        weight.addEventListener("change", commitWeight);

        li.appendChild(weight);

        if (currentWheel().accumulate) {
          const wins = document.createElement("span");
          const n = entry.wins || 0;
          wins.className = n > 0 ? "spin-list-wins" : "spin-list-wins spin-list-wins-zero";
          wins.textContent = `× ${n}`;
          wins.setAttribute("aria-label", `${n} ${n === 1 ? "win" : "wins"}`);
          wins.title = "Win count";
          li.appendChild(wins);
        }

        const rm = document.createElement("button");
        rm.type = "button";
        rm.className = "spin-list-remove";
        rm.setAttribute("aria-label", `Remove ${entry.label}`);
        rm.innerHTML =
          '<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        rm.addEventListener("click", () => deleteEntry(entry.id));
        li.appendChild(rm);

        list!.appendChild(li);
      });
      updateDuplicateBadges();
    }

    function addEntry(label: string) {
      const clean = label.trim();
      if (!clean) return;
      entries.push({ id: newId(), label: clean });
      clearImportFlag();
      renderList();
      drawWheel();
      save();
    }

    addForm!.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = addInput!.value;
      addEntry(v);
      addInput!.value = "";
      addInput!.focus();
    });

    bulkApply!.addEventListener("click", () => {
      const raw = bulkInput!.value || "";
      const parts = raw
        .split(/[\n,]/)
        .map((s) => s.trim())
        .filter(Boolean)
        .slice(0, 200);
      if (parts.length === 0) return;
      entries = parts.map((label) => ({ id: newId(), label }));
      clearImportFlag();
      renderList();
      drawWheel();
      save();
      bulkInput!.value = "";
    });

    shuffleBtn!.addEventListener("click", () => {
      for (let i = entries.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [entries[i], entries[j]] = [entries[j], entries[i]];
      }
      clearImportFlag();
      renderList();
      drawWheel();
      save();
    });

    resetBtn!.addEventListener("click", () => {
      if (!confirm("Reset to the default entries?")) return;
      entries = [...DEFAULT_ENTRIES.map((e) => ({ ...e, id: newId() }))];
      clearImportFlag();
      renderList();
      drawWheel();
      save();
    });

    function easeOutCubicBezier(t: number): number {
      // Approximation of cubic-bezier(0.16, 1, 0.3, 1)
      const c = 1 - t;
      return 1 - c * c * c;
    }

    function spin() {
      if (spinning) return;
      if (entries.length === 0) {
        hintEl!.textContent = "Add at least one entry to spin.";
        return;
      }
      spinning = true;
      centerBtn!.disabled = true;

      // Prime / resume audio context on user gesture (mobile autoplay policy)
      if (!muted) {
        const c = getAudio();
        if (c && c.state === "suspended") {
          c.resume().catch(() => {});
        }
      }

      const n = entries.length;
      const bounds = sliceBounds();

      // Weighted winner pick: probability proportional to slice angular span.
      // Equivalent to picking r uniformly in [0, 2π) and locating containing slice.
      const r = Math.random() * Math.PI * 2;
      const winnerIdx = indexAt(r, bounds);
      const sliceStart = bounds[winnerIdx];
      const sliceEnd = bounds[winnerIdx + 1];
      const sliceSpan = sliceEnd - sliceStart;
      const sliceMid = (sliceStart + sliceEnd) / 2;
      // Wheel slice θ is drawn at screen angle (rotation + θ - PI/2).
      // We want the winning slice's midpoint to land under the pointer,
      // whose screen angle depends on its position (top = -PI/2, right = 0).
      //   rotation + sliceMid - PI/2 ≡ pointerScreenAngle (mod 2π)
      //   rotation ≡ pointerScreenAngle + PI/2 - sliceMid (mod 2π)
      const pa = pointerScreenAngle();
      const targetMod = ((pa + Math.PI / 2 - sliceMid) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2);
      const turns = 5 + Math.floor(Math.random() * 3); // 5, 6, or 7 full turns
      const currentMod = ((rotation % (Math.PI * 2)) + Math.PI * 2) % (Math.PI * 2);
      let deltaToTarget = targetMod - currentMod;
      if (deltaToTarget <= 0) deltaToTarget += Math.PI * 2;
      const totalDelta = turns * Math.PI * 2 + deltaToTarget;
      // Jitter within slice, capped so the pointer never falls outside the
      // winning wedge — vital for narrow (low-weight) slices.
      const jitter = (Math.random() - 0.5) * sliceSpan * 0.7;
      const totalDeltaJittered = totalDelta + jitter;

      const startRotation = rotation;
      const duration = 5200 + Math.random() * 800; // 5.2 - 6s
      const startTs = performance.now();

      hintEl!.textContent = "Spinning…";

      let lastSliceIdx = -1;
      const twoPi = Math.PI * 2;

      function frame(now: number) {
        const t = Math.min(1, (now - startTs) / duration);
        const eased = easeOutCubicBezier(t);
        rotation = startRotation + totalDeltaJittered * eased;
        drawWheel();

        // Tick whenever the pointer crosses a slice boundary.
        // Solve for wheel-local θ currently at screen angle pa:
        //   rotation + θ - PI/2 ≡ pa  →  θ ≡ pa + PI/2 - rotation
        const norm = ((pa + Math.PI / 2 - rotation) % twoPi + twoPi) % twoPi;
        const curSlice = indexAt(norm, bounds);
        if (curSlice !== lastSliceIdx) {
          lastSliceIdx = curSlice;
          // Skip the very first frame so we don't double-tick at t=0
          if (now - startTs > 30) tick();
        }

        if (t < 1) {
          requestAnimationFrame(frame);
        } else {
          spinning = false;
          centerBtn!.disabled = false;
          lastWinnerIdx = winnerIdx;
          fanfare();
          // Burst from the canvas center on screen for a wheel-anchored feel
          let originX: number | undefined;
          let originY: number | undefined;
          if (canvas) {
            const r = canvas.getBoundingClientRect();
            originX = r.left + r.width / 2;
            originY = r.top + r.height / 2;
          }
          burstConfetti(originX, originY);
          showWinner(entries[winnerIdx]);
        }
      }
      requestAnimationFrame(frame);
    }

    function buildOrder(winnerIdx: number): Entry[] {
      const winner = entries[winnerIdx];
      const rest = entries.filter((_, i) => i !== winnerIdx).slice();
      for (let i = rest.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [rest[i], rest[j]] = [rest[j], rest[i]];
      }
      return [winner, ...rest];
    }

    function maxTeamCount(): number {
      return Math.min(10, Math.max(2, entries.length));
    }

    function getTeamCount(): number {
      const k = currentWheel().teamCount;
      const max = maxTeamCount();
      const start = typeof k === "number" && Number.isFinite(k) ? Math.floor(k) : 3;
      return Math.max(2, Math.min(max, start));
    }

    function setTeamCount(n: number) {
      const clamped = Math.max(2, Math.min(maxTeamCount(), Math.floor(n)));
      const cw = currentWheel();
      const prior = cw.teamCount;
      cw.teamCount = clamped;
      if (prior !== clamped) save();
      if (teamsCountEl) teamsCountEl.textContent = String(clamped);
      if (teamsDec) teamsDec.disabled = clamped <= 2;
      if (teamsInc) teamsInc.disabled = clamped >= maxTeamCount();
      if (teamsBtn) {
        teamsBtn.title = `Split into ${clamped} teams`;
        teamsBtn.setAttribute("aria-label", `Split into ${clamped} teams`);
      }
    }

    function openTeamsConfig() {
      if (entries.length < 4) {
        showToast("Need at least 4 entries to split teams");
        return;
      }
      if (!teamsConfig) return;
      closePointerConfig();
      closeLabelrotConfig();
      closePaletteConfig();
      closeSizeConfig();
      teamsConfig.hidden = false;
      if (teamsBtn) teamsBtn.setAttribute("aria-expanded", "true");
      setTeamCount(getTeamCount());
      (teamsGo as HTMLButtonElement | null)?.focus();
    }

    function closeTeamsConfig() {
      if (!teamsConfig) return;
      teamsConfig.hidden = true;
      if (teamsBtn) teamsBtn.setAttribute("aria-expanded", "false");
    }

    // Screen angle (radians) where the pointer apex meets the wheel edge.
    // Top pointer is at -PI/2 (12 o'clock); right pointer is at 0 (3 o'clock).
    function pointerScreenAngle(): number {
      return pointerCfg.pos === "right" ? 0 : -Math.PI / 2;
    }

    const POINTER_COLOR_VAR: Record<PointerColor, string> = {
      ink: "var(--content)",
      accent: "var(--accent)",
      amber: "#b07d2a",
    };

    function applyPointer() {
      if (!pointerEl) return;
      pointerEl.classList.toggle("spin-pointer-top", pointerCfg.pos === "top");
      pointerEl.classList.toggle("spin-pointer-right", pointerCfg.pos === "right");
      pointerEl.style.setProperty("--pointer-fill", POINTER_COLOR_VAR[pointerCfg.color]);
      if (pointerPosTop) pointerPosTop.setAttribute("aria-pressed", String(pointerCfg.pos === "top"));
      if (pointerPosRight) pointerPosRight.setAttribute("aria-pressed", String(pointerCfg.pos === "right"));
      pointerSwatches.forEach((s) => {
        s.setAttribute("aria-pressed", String(s.dataset.color === pointerCfg.color));
      });
    }

    function setPointerPos(pos: PointerPos) {
      if (pointerCfg.pos === pos) return;
      pointerCfg = { ...pointerCfg, pos };
      applyPointer();
      save();
    }

    function setPointerColor(color: PointerColor) {
      if (pointerCfg.color === color) return;
      pointerCfg = { ...pointerCfg, color };
      applyPointer();
      save();
    }

    function openPointerConfig() {
      if (!pointerConfig) return;
      closeTeamsConfig();
      closeLabelrotConfig();
      closePaletteConfig();
      closeSizeConfig();
      pointerConfig.hidden = false;
      if (pointerBtn) pointerBtn.setAttribute("aria-expanded", "true");
      (pointerPosTop as HTMLButtonElement | null)?.focus();
    }

    function closePointerConfig() {
      if (!pointerConfig) return;
      pointerConfig.hidden = true;
      if (pointerBtn) pointerBtn.setAttribute("aria-expanded", "false");
    }

    function applyLabelRotation() {
      labelrotChips.forEach((c) => {
        c.setAttribute("aria-pressed", String(c.dataset.mode === labelRotation));
      });
    }

    function setLabelRotation(mode: LabelRotation) {
      if (labelRotation === mode) return;
      labelRotation = mode;
      applyLabelRotation();
      save();
      drawWheel();
    }

    function openLabelrotConfig() {
      if (!labelrotConfig) return;
      closeTeamsConfig();
      closePointerConfig();
      closePaletteConfig();
      closeSizeConfig();
      labelrotConfig.hidden = false;
      if (labelrotBtn) labelrotBtn.setAttribute("aria-expanded", "true");
      const pressed = Array.from(labelrotChips).find((c) => c.getAttribute("aria-pressed") === "true");
      (pressed as HTMLButtonElement | undefined)?.focus();
    }

    function closeLabelrotConfig() {
      if (!labelrotConfig) return;
      labelrotConfig.hidden = true;
      if (labelrotBtn) labelrotBtn.setAttribute("aria-expanded", "false");
    }

    const PALETTE_LABELS: Record<Palette, string> = {
      paper: "Paper",
      vibrant: "Vibrant",
      pastel: "Pastel",
      mono: "Mono",
    };

    function renderPaletteChips() {
      if (!paletteChipsHost) return;
      paletteChipsHost.replaceChildren();
      (Object.keys(PALETTES) as Palette[]).forEach((key) => {
        const chip = document.createElement("button");
        chip.type = "button";
        chip.className = "spin-palette-chip";
        chip.dataset.palette = key;
        chip.setAttribute("aria-pressed", String(key === palette));
        const swatches = document.createElement("span");
        swatches.className = "spin-palette-swatches";
        swatches.setAttribute("aria-hidden", "true");
        const previewColors = PALETTES[key].slice(0, 4);
        for (const c of previewColors) {
          const dot = document.createElement("span");
          dot.className = "spin-palette-dot";
          dot.style.background = c;
          swatches.appendChild(dot);
        }
        chip.appendChild(swatches);
        const name = document.createElement("span");
        name.className = "spin-palette-name";
        name.textContent = PALETTE_LABELS[key];
        chip.appendChild(name);
        chip.addEventListener("click", () => setPalette(key));
        paletteChipsHost.appendChild(chip);
      });
    }

    function applyPalette() {
      if (!paletteChipsHost) return;
      paletteChipsHost.querySelectorAll<HTMLButtonElement>(".spin-palette-chip").forEach((c) => {
        c.setAttribute("aria-pressed", String(c.dataset.palette === palette));
      });
    }

    function setPalette(next: Palette) {
      if (palette === next) return;
      palette = next;
      applyPalette();
      save();
      drawWheel();
      renderList();
    }

    function openPaletteConfig() {
      if (!paletteConfig) return;
      closeTeamsConfig();
      closePointerConfig();
      closeLabelrotConfig();
      closeSizeConfig();
      paletteConfig.hidden = false;
      if (paletteBtn) paletteBtn.setAttribute("aria-expanded", "true");
      const pressed = paletteConfig.querySelector<HTMLButtonElement>(".spin-palette-chip[aria-pressed='true']");
      pressed?.focus();
    }

    function closePaletteConfig() {
      if (!paletteConfig) return;
      paletteConfig.hidden = true;
      if (paletteBtn) paletteBtn.setAttribute("aria-expanded", "false");
    }

    function applyWheelSize() {
      if (wheelFrame) wheelFrame.dataset.size = wheelSize;
      sizeChips.forEach((c) => {
        c.setAttribute("aria-pressed", String(c.dataset.size === wheelSize));
      });
    }

    function setWheelSize(next: WheelSize) {
      if (wheelSize === next) return;
      wheelSize = next;
      applyWheelSize();
      save();
      drawWheel();
      fitConfetti();
      requestAnimationFrame(() => {
        drawWheel();
        fitConfetti();
      });
    }

    if (wheelFrame) {
      wheelFrame.addEventListener("transitionend", (e) => {
        if ((e as TransitionEvent).propertyName === "max-width") {
          drawWheel();
          fitConfetti();
        }
      });
    }

    function openSizeConfig() {
      if (!sizeConfig) return;
      closeTeamsConfig();
      closePointerConfig();
      closeLabelrotConfig();
      closePaletteConfig();
      sizeConfig.hidden = false;
      if (sizeBtn) sizeBtn.setAttribute("aria-expanded", "true");
      const pressed = Array.from(sizeChips).find((c) => c.getAttribute("aria-pressed") === "true");
      (pressed as HTMLButtonElement | undefined)?.focus();
    }

    function closeSizeConfig() {
      if (!sizeConfig) return;
      sizeConfig.hidden = true;
      if (sizeBtn) sizeBtn.setAttribute("aria-expanded", "false");
    }

    // Snake-draft partition: ensures team sizes stay within 1 of each other and
    // adjacent rounds reverse direction, so the first team isn't always the
    // largest. Returns one section per team with header + member list.
    function buildTeams(): { name: string; members: Entry[] }[] {
      const k = getTeamCount();
      const shuffled = entries.slice();
      for (let i = shuffled.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
      }
      const teams = Array.from({ length: k }, (_, i) => ({
        name: `Team ${String.fromCharCode(65 + i)}`,
        members: [] as Entry[],
      }));
      shuffled.forEach((e, i) => {
        const round = Math.floor(i / k);
        const slot = round % 2 === 0 ? i % k : k - 1 - (i % k);
        teams[slot].members.push(e);
      });
      return teams;
    }

    function renderHistory() {
      if (!historyList) return;
      historyList.innerHTML = "";
      if (history.length === 0) {
        const empty = document.createElement("li");
        empty.className = "spin-history-empty";
        empty.textContent = "No spins yet.";
        historyList.appendChild(empty);
        if (historyCount) historyCount.hidden = true;
        if (historyClear) historyClear.hidden = true;
        return;
      }
      const now = Date.now();
      for (const h of history) {
        const li = document.createElement("li");
        li.className = "spin-history-item";
        const time = document.createElement("span");
        time.className = "spin-history-time";
        time.textContent = relativeTime(h.ts, now);
        try { time.title = new Date(h.ts).toLocaleString(); } catch {}
        const wheel = document.createElement("span");
        wheel.className = "spin-history-wheel";
        wheel.textContent = h.wheelName;
        wheel.title = h.wheelName;
        const winner = document.createElement("span");
        winner.className = "spin-history-winner";
        winner.textContent = h.winner;
        winner.title = h.winner;
        li.appendChild(time);
        li.appendChild(wheel);
        li.appendChild(winner);
        historyList.appendChild(li);
      }
      if (historyCount) {
        historyCount.hidden = false;
        historyCount.textContent = `${history.length}`;
      }
      if (historyClear) historyClear.hidden = false;
    }

    function showOrderReveal(winnerIdx: number) {
      if (!orderList) return;
      const order = buildOrder(winnerIdx);
      orderList.innerHTML = "";
      order.forEach((e, i) => {
        const li = document.createElement("li");
        li.className = "spin-order-item";
        const num = document.createElement("span");
        num.className = "spin-order-num";
        num.textContent = `${i + 1}.`;
        const label = document.createElement("span");
        label.className = "spin-order-label";
        label.textContent = e.label;
        li.appendChild(num);
        li.appendChild(label);
        orderList!.appendChild(li);
      });
      if (winnerName) (winnerName as HTMLElement).hidden = true;
      orderList.hidden = false;
      if (modalLabelEl) modalLabelEl.textContent = "Spin order";
      if (removeBtn) (removeBtn as HTMLButtonElement).hidden = true;
      if (againBtn) {
        (againBtn as HTMLButtonElement).hidden = false;
        (againBtn as HTMLButtonElement).textContent = "Spin again";
      }
      if (shareImgBtn) shareImgBtn.hidden = true;
      modal!.hidden = false;
      modal!.setAttribute("aria-hidden", "false");
      hintEl!.textContent = `Order: ${order.map((e) => e.label).join(", ")}`;
      (closeBtn as HTMLButtonElement).focus();
    }

    function showTeamReveal() {
      if (!teamsList) return;
      const teams = buildTeams();
      teamsList.innerHTML = "";
      teams.forEach((t) => {
        const sec = document.createElement("section");
        sec.className = "spin-team";
        const head = document.createElement("h3");
        head.className = "spin-team-name";
        const name = document.createElement("span");
        name.textContent = t.name;
        const size = document.createElement("span");
        size.className = "spin-team-size";
        size.textContent = `${t.members.length}`;
        head.appendChild(name);
        head.appendChild(size);
        const ul = document.createElement("ul");
        ul.className = "spin-team-members";
        t.members.forEach((m) => {
          const li = document.createElement("li");
          li.textContent = m.label;
          ul.appendChild(li);
        });
        sec.appendChild(head);
        sec.appendChild(ul);
        teamsList!.appendChild(sec);
      });
      if (winnerName) (winnerName as HTMLElement).hidden = true;
      if (orderList) orderList.hidden = true;
      teamsList.hidden = false;
      if (modalLabelEl) modalLabelEl.textContent = `Split into ${teams.length} teams`;
      if (removeBtn) (removeBtn as HTMLButtonElement).hidden = true;
      if (againBtn) {
        (againBtn as HTMLButtonElement).hidden = false;
        (againBtn as HTMLButtonElement).textContent = "Re-split";
      }
      if (shareImgBtn) shareImgBtn.hidden = true;
      modal!.hidden = false;
      modal!.setAttribute("aria-hidden", "false");
      hintEl!.textContent = `Teams: ${teams.map((t) => `${t.name} (${t.members.map((m) => m.label).join(", ")})`).join(" · ")}`;
      (closeBtn as HTMLButtonElement).focus();
    }

    function showWinner(entry: Entry) {
      const cw = currentWheel();
      if (teamSpinPending) {
        teamSpinPending = false;
        showTeamReveal();
        return;
      }
      if (orderSpinPending) {
        orderSpinPending = false;
        const idx = entries.indexOf(entry);
        if (idx >= 0) {
          showOrderReveal(idx);
          return;
        }
      }
      pushHistory(entry);
      const eliminateMode = !!cw.eliminate;
      const accumulateMode = !!cw.accumulate;
      // Increment count BEFORE rendering so the modal can show the new total.
      if (accumulateMode) {
        entry.wins = (entry.wins || 0) + 1;
        save();
        renderList();
        updatePickerResetCounts();
      }
      winnerName!.textContent = accumulateMode
        ? `${entry.label} × ${entry.wins}`
        : entry.label;
      if (winnerName) (winnerName as HTMLElement).hidden = false;
      if (orderList) orderList.hidden = true;
      modal!.hidden = false;
      modal!.setAttribute("aria-hidden", "false");
      // Once we remove this entry the wheel will only contain the champion.
      const isFinal = eliminateMode && entries.length === 1;
      pendingEliminate = eliminateMode && !isFinal;
      if (modalLabelEl) {
        modalLabelEl.textContent = isFinal ? "Champion" : eliminateMode ? "Eliminated" : "Winner";
      }
      // The "Remove + spin" button is redundant in eliminate mode.
      if (removeBtn) (removeBtn as HTMLButtonElement).hidden = eliminateMode;
      if (againBtn) {
        (againBtn as HTMLButtonElement).hidden = isFinal;
        (againBtn as HTMLButtonElement).textContent = "Spin again";
      }
      if (shareImgBtn) shareImgBtn.hidden = false;
      hintEl!.textContent = isFinal
        ? `Champion: ${entry.label}`
        : `Winner: ${entry.label}`;
      // Focus the primary action for keyboard users
      if (isFinal && closeBtn) {
        (closeBtn as HTMLButtonElement).focus();
      } else {
        (againBtn as HTMLButtonElement).focus();
      }
    }

    function hideWinner() {
      if (pendingEliminate && lastWinnerIdx !== null && entries[lastWinnerIdx]) {
        const removedId = entries[lastWinnerIdx].id;
        entries = entries.filter((e) => e.id !== removedId);
        renderList();
        save();
        drawWheel();
        if (entries.length === 1) {
          showToast(`Champion: ${entries[0].label}`);
        } else if (entries.length === 0) {
          showToast("All entries eliminated");
        }
      }
      pendingEliminate = false;
      modal!.hidden = true;
      modal!.setAttribute("aria-hidden", "true");
      // Reset modal back to winner layout so the next spin renders normally.
      if (winnerName) (winnerName as HTMLElement).hidden = false;
      if (orderList) orderList.hidden = true;
      if (teamsList) teamsList.hidden = true;
    }

    centerBtn!.addEventListener("click", spin);

    if (orderBtn) {
      orderBtn.addEventListener("click", () => {
        if (spinning) {
          showToast("Wait for the spin to finish");
          return;
        }
        if (entries.length < 2) {
          showToast("Need at least 2 entries");
          return;
        }
        orderSpinPending = true;
        spin();
      });
    }

    if (teamsBtn) {
      teamsBtn.addEventListener("click", () => {
        if (spinning) {
          showToast("Wait for the spin to finish");
          return;
        }
        if (teamsConfig && !teamsConfig.hidden) closeTeamsConfig();
        else openTeamsConfig();
      });
    }
    if (teamsDec) {
      teamsDec.addEventListener("click", () => setTeamCount(getTeamCount() - 1));
    }
    if (teamsInc) {
      teamsInc.addEventListener("click", () => setTeamCount(getTeamCount() + 1));
    }
    if (teamsCancel) {
      teamsCancel.addEventListener("click", closeTeamsConfig);
    }
    if (teamsGo) {
      teamsGo.addEventListener("click", () => {
        if (spinning) {
          showToast("Wait for the spin to finish");
          return;
        }
        if (entries.length < 4) {
          showToast("Need at least 4 entries to split teams");
          return;
        }
        closeTeamsConfig();
        teamSpinPending = true;
        spin();
      });
    }

    if (pointerBtn) {
      pointerBtn.addEventListener("click", () => {
        if (pointerConfig && !pointerConfig.hidden) closePointerConfig();
        else openPointerConfig();
      });
    }
    if (pointerPosTop) pointerPosTop.addEventListener("click", () => setPointerPos("top"));
    if (pointerPosRight) pointerPosRight.addEventListener("click", () => setPointerPos("right"));
    if (pointerCancel) pointerCancel.addEventListener("click", closePointerConfig);
    pointerSwatches.forEach((s) => {
      s.addEventListener("click", () => {
        const c = s.dataset.color;
        if (c === "ink" || c === "accent" || c === "amber") setPointerColor(c);
      });
    });

    if (labelrotBtn) {
      labelrotBtn.addEventListener("click", () => {
        if (labelrotConfig && !labelrotConfig.hidden) closeLabelrotConfig();
        else openLabelrotConfig();
      });
    }
    if (labelrotCancel) labelrotCancel.addEventListener("click", closeLabelrotConfig);
    labelrotChips.forEach((c) => {
      c.addEventListener("click", () => {
        const m = c.dataset.mode;
        if (m === "auto" || m === "tangent" || m === "radial") setLabelRotation(m);
      });
    });

    if (paletteBtn) {
      paletteBtn.addEventListener("click", () => {
        if (paletteConfig && !paletteConfig.hidden) closePaletteConfig();
        else openPaletteConfig();
      });
    }
    if (paletteCancel) paletteCancel.addEventListener("click", closePaletteConfig);

    if (sizeBtn) {
      sizeBtn.addEventListener("click", () => {
        if (sizeConfig && !sizeConfig.hidden) closeSizeConfig();
        else openSizeConfig();
      });
    }
    if (sizeCancel) sizeCancel.addEventListener("click", closeSizeConfig);
    sizeChips.forEach((c) => {
      c.addEventListener("click", () => {
        const s = c.dataset.size;
        if (s === "s" || s === "m" || s === "l" || s === "full") setWheelSize(s);
      });
    });

    againBtn!.addEventListener("click", () => {
      // If we're closing an order or teams reveal, the next spin should
      // re-arm the same reveal. The hidden state of each panel is the
      // source of truth.
      const wasOrder = !!(orderList && !orderList.hidden);
      const wasTeams = !!(teamsList && !teamsList.hidden);
      hideWinner();
      if (wasTeams) teamSpinPending = true;
      else if (wasOrder) orderSpinPending = true;
      spin();
    });

    removeBtn!.addEventListener("click", () => {
      if (lastWinnerIdx !== null && entries[lastWinnerIdx]) {
        const removedId = entries[lastWinnerIdx].id;
        entries = entries.filter((e) => e.id !== removedId);
        renderList();
        save();
      }
      // Removal already done by hand; don't let hideWinner double-eliminate.
      pendingEliminate = false;
      hideWinner();
      drawWheel();
      if (entries.length > 0) spin();
    });

    closeBtn!.addEventListener("click", hideWinner);

    shareImgBtn?.addEventListener("click", () => {
      void shareWinnerImage();
    });

    modal!.addEventListener("click", (e) => {
      if (e.target === modal) hideWinner();
    });

    function showHelp() {
      if (!helpModal) return;
      helpModal.hidden = false;
      helpModal.setAttribute("aria-hidden", "false");
      helpCloseX?.focus();
    }
    function hideHelp() {
      if (!helpModal) return;
      helpModal.hidden = true;
      helpModal.setAttribute("aria-hidden", "true");
    }
    helpCloseX?.addEventListener("click", hideHelp);
    helpModal?.addEventListener("click", (e) => {
      if (e.target === helpModal) hideHelp();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && embedModal && !embedModal.hidden) {
        closeEmbedModal();
        return;
      }
      if (e.key === "Escape" && helpModal && !helpModal.hidden) {
        hideHelp();
        return;
      }
      if (e.key === "Escape" && !modal!.hidden) {
        hideWinner();
        return;
      }
      if (e.key === " " && !modal!.hidden) return;
      const tag = (document.activeElement?.tagName || "").toLowerCase();
      if (tag === "input" || tag === "textarea") return;
      if (e.key === "?") {
        e.preventDefault();
        if (helpModal && !helpModal.hidden) hideHelp();
        else showHelp();
        return;
      }
      if (helpModal && !helpModal.hidden) return;
      if (e.key === " " || e.code === "Space") {
        e.preventDefault();
        if (!spinning) spin();
      }
    });

    window.addEventListener("resize", () => {
      drawWheel();
      fitConfetti();
    });

    // === Web Audio (lazy) ===
    let audioCtx: AudioContext | null = null;
    function getAudio(): AudioContext | null {
      if (audioCtx) return audioCtx;
      try {
        const AC =
          (window as any).AudioContext || (window as any).webkitAudioContext;
        if (!AC) return null;
        audioCtx = new AC();
      } catch {
        audioCtx = null;
      }
      return audioCtx;
    }

    function tick() {
      if (muted) return;
      const c = getAudio();
      if (!c) return;
      const t = c.currentTime;
      const osc = c.createOscillator();
      const gain = c.createGain();
      osc.type = "triangle";
      osc.frequency.value = 720 + Math.random() * 220;
      gain.gain.setValueAtTime(0, t);
      gain.gain.linearRampToValueAtTime(0.045, t + 0.004);
      gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.065);
      osc.connect(gain).connect(c.destination);
      osc.start(t);
      osc.stop(t + 0.08);
    }

    function fanfare() {
      if (muted) return;
      const c = getAudio();
      if (!c) return;
      // C5, E5, G5, C6 — a small bright ascent
      const notes = [523.25, 659.25, 783.99, 1046.5];
      const t0 = c.currentTime;
      notes.forEach((freq, i) => {
        const t = t0 + i * 0.08;
        const osc = c.createOscillator();
        const gain = c.createGain();
        osc.type = "sine";
        osc.frequency.value = freq;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.11, t + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.45);
        osc.connect(gain).connect(c.destination);
        osc.start(t);
        osc.stop(t + 0.5);
      });
    }

