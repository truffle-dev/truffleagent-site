  <canvas id="spin-confetti" class="spin-confetti" aria-hidden="true"></canvas>
  <div id="spin-toast" class="spin-toast" role="status" aria-live="polite" aria-atomic="true"><span id="spin-toast-msg" class="spin-toast-msg"></span><button id="spin-toast-action" type="button" class="spin-toast-action" hidden></button></div>

  <style is:global>
    .spin-page {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(2rem, 4vw, 3.5rem) clamp(1rem, 3vw, 2rem) 5rem;
      /* mirrors PALETTES.paper[2] amber for non-blocking validation hints */
      --spin-warn: #b07d2a;
    }

    .spin-header {
      text-align: center;
      max-width: 760px;
      margin: 0 auto 3rem;
    }
    .spin-eyebrow {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--content-3);
      margin: 0 0 0.75rem;
    }
    .spin-title {
      font-family: var(--font-serif);
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
      color: var(--content);
    }
    .spin-title em {
      font-style: italic;
      color: var(--accent);
    }
    .spin-lede {
      font-size: 17px;
      line-height: 1.55;
      color: var(--content-2);
      margin: 0;
    }

    .spin-stage {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      align-items: start;
    }
    @media (min-width: 880px) {
      .spin-stage {
        grid-template-columns: minmax(0, 1.55fr) minmax(320px, 1fr);
        gap: clamp(2rem, 3.5vw, 3rem);
      }
    }

    .spin-wheel-pane {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      padding-top: 0.5rem;
    }

    .spin-wheel-frame {
      position: relative;
      width: 100%;
      max-width: 720px;
      aspect-ratio: 1 / 1;
      margin-inline: auto;
      transition: max-width var(--motion-base, 150ms) var(--ease-out, cubic-bezier(0.25, 0.46, 0.45, 0.94));
    }
    .spin-wheel-frame[data-size="s"] { max-width: 400px; }
    .spin-wheel-frame[data-size="m"] { max-width: 560px; }
    .spin-wheel-frame[data-size="l"] { max-width: 720px; }
    .spin-wheel-frame[data-size="full"] { max-width: none; }

    #spin-canvas {
      width: 100%;
      height: 100%;
      display: block;
      filter: drop-shadow(0 14px 40px rgba(20, 17, 11, 0.14));
    }

    .spin-pointer {
      position: absolute;
      width: 0;
      height: 0;
      z-index: 2;
      filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
      --pointer-fill: var(--content);
    }
    .spin-pointer-top {
      top: -6px;
      left: 50%;
      transform: translateX(-50%);
      border-left: 14px solid transparent;
      border-right: 14px solid transparent;
      border-top: 26px solid var(--pointer-fill);
    }
    .spin-pointer-right {
      top: 50%;
      right: -6px;
      transform: translateY(-50%);
      border-top: 14px solid transparent;
      border-bottom: 14px solid transparent;
      border-right: 26px solid var(--pointer-fill);
    }

    .spin-center-btn {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 22%;
      height: 22%;
      min-width: 84px;
      min-height: 84px;
      border-radius: 50%;
      border: 4px solid var(--surface);
      background: var(--accent);
      color: white;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: clamp(1.2rem, 2.5vw, 1.75rem);
      font-weight: 500;
      cursor: pointer;
      transition: transform 0.15s var(--ease-out), box-shadow 0.15s var(--ease-out), background 0.2s;
      box-shadow: 0 6px 18px rgba(72, 80, 196, 0.35);
    }
    .spin-center-btn:hover {
      transform: translate(-50%, -50%) scale(1.04);
      box-shadow: 0 10px 24px rgba(72, 80, 196, 0.45);
    }
    .spin-center-btn:active {
      transform: translate(-50%, -50%) scale(0.97);
    }
    .spin-center-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: translate(-50%, -50%);
    }

    .spin-empty-overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      padding: 14% 8% 14%;
      pointer-events: none;
      text-align: center;
    }
    .spin-empty-overlay[hidden] { display: none; }
    .spin-empty-title {
      font-family: "Fraunces", Georgia, serif;
      font-style: italic;
      font-size: clamp(1rem, 2.6vw, 1.4rem);
      line-height: 1.25;
      color: var(--content-2, var(--content));
      margin: 0;
      max-width: 22ch;
    }
    .spin-empty-cta {
      pointer-events: auto;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--accent);
      color: white;
      border: 0;
      border-radius: 999px;
      padding: 0.55rem 1.1rem;
      font: 600 0.875rem / 1 "Inter", system-ui, sans-serif;
      letter-spacing: 0.01em;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(72, 80, 196, 0.25);
      transition: transform 0.12s var(--ease-out, cubic-bezier(0.25, 0.46, 0.45, 0.94)),
        box-shadow 0.12s var(--ease-out, cubic-bezier(0.25, 0.46, 0.45, 0.94));
    }
    .spin-empty-cta > span:first-child {
      font-size: 1.1em;
      line-height: 1;
      font-weight: 400;
    }
    .spin-empty-cta:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(72, 80, 196, 0.35);
    }
    .spin-empty-cta:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
    }

    .spin-hint {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      margin: 0;
      text-align: center;
    }
    .spin-hint kbd {
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 1px 6px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--surface-2);
      color: var(--content-2);
    }

    .spin-side {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 1.1rem 1.1rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      box-shadow: 0 1px 2px rgba(20, 17, 11, 0.04), 0 4px 14px -10px rgba(20, 17, 11, 0.10);
    }

    .spin-side-head {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
    }
    .spin-head-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      row-gap: 0.5rem;
    }
    .spin-head-row-top {
      justify-content: space-between;
    }
    .spin-head-actions {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
    }

    .spin-side-title {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      margin: 0;
      color: var(--content);
    }

    .spin-count-chip {
      font-family: var(--font-mono);
      font-size: 11px;
      font-variant-numeric: tabular-nums;
      color: var(--content-3);
      background: var(--surface-3);
      border: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
      padding: 2px 8px;
      border-radius: 9999px;
      letter-spacing: 0.02em;
      flex-shrink: 0;
    }

    .spin-toolbar-section {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .spin-toolbar-grouplabel {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--content-4);
      font-weight: 600;
    }

    /* Segmented mode chips */
    .spin-mode-chips {
      display: flex;
      gap: 2px;
      flex-wrap: wrap;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 3px;
    }
    .spin-mode-chip {
      flex: 1 1 auto;
      min-width: 0;
      padding: 6px 8px;
      border-radius: 6px;
      border: 0;
      background: transparent;
      color: var(--content-3);
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: -0.005em;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      transition: background 0.12s, color 0.12s, box-shadow 0.12s;
      white-space: nowrap;
    }
    .spin-mode-chip svg {
      flex-shrink: 0;
      opacity: 0.85;
    }
    .spin-mode-chip:hover {
      color: var(--content);
      background: var(--surface);
    }
    .spin-mode-chip:focus-visible {
      outline: none;
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 50%, transparent);
    }
    .spin-mode-chip[aria-pressed="true"] {
      background: var(--surface);
      color: var(--content);
      box-shadow: 0 1px 2px rgba(20, 17, 11, 0.06), 0 0 0 1px color-mix(in oklab, var(--border) 80%, transparent);
    }
    .spin-mode-chip[aria-pressed="true"] svg {
      color: var(--accent);
      opacity: 1;
    }

    /* Look icon row */
    .spin-style-icons {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 2px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 3px;
    }
    .spin-style-icons .spin-icon-btn {
      width: 100%;
      height: 38px;
      min-width: 0;
      border-radius: 6px;
      flex-direction: column;
      gap: 2px;
      padding: 4px 2px;
      color: var(--content-3);
    }
    .spin-style-icons .spin-icon-btn:hover {
      background: var(--surface);
      color: var(--content);
      border-color: transparent;
    }
    .spin-style-icons .spin-icon-btn[aria-expanded="true"] {
      background: var(--surface);
      color: var(--content);
      box-shadow: 0 1px 2px rgba(20, 17, 11, 0.06), 0 0 0 1px color-mix(in oklab, var(--border) 80%, transparent);
    }
    .spin-icon-label {
      font-family: var(--font-sans);
      font-size: 9.5px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1;
    }

    /* Hidden handle buttons (kept for JS wiring only) */
    .spin-hidden-handle {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      border: 0;
      padding: 0;
      margin: -1px;
      background: transparent;
    }

    /* Share CTA chip */
    .spin-cta-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 11px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 12.5px;
      font-weight: 500;
      letter-spacing: -0.005em;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s;
    }
    .spin-cta-chip:hover {
      background: var(--accent);
      border-color: var(--accent);
      color: white;
    }
    .spin-cta-chip:focus-visible {
      outline: none;
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 28%, transparent);
    }
    .spin-cta-chip svg { flex-shrink: 0; }

    /* Pill-shape variant of icon button (used in head row for mute) */
    .spin-icon-btn-pill {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
    }
    .spin-icon-btn-pill:hover {
      background: var(--surface-3);
    }
    #spin-mute.spin-icon-btn-pill[aria-pressed="true"] {
      color: var(--content-4);
      background: var(--surface-2);
    }

    .spin-wheel-picker {
      position: relative;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      min-width: 0;
      flex: 1 1 auto;
    }
    .spin-picker-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 8px;
      padding: 4px 8px 4px 4px;
      cursor: pointer;
      color: var(--content);
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1.1;
      min-width: 0;
      max-width: 100%;
      transition: background 0.12s, border-color 0.12s;
    }
    .spin-picker-btn:hover {
      background: var(--surface-3);
      border-color: var(--border);
    }
    .spin-picker-btn[aria-expanded="true"] {
      background: var(--surface-3);
      border-color: var(--border);
    }
    .spin-picker-name {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 14ch;
    }
    .spin-shared-pill {
      flex-shrink: 0;
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--accent);
      background: color-mix(in oklab, var(--accent) 12%, transparent);
      border: 1px solid color-mix(in oklab, var(--accent) 30%, transparent);
      padding: 1px 6px;
      border-radius: 9999px;
      line-height: 1.6;
    }
    .spin-import-notice {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 8px 10px;
      margin-top: 6px;
      background: color-mix(in oklab, var(--accent) 8%, transparent);
      border: 1px solid color-mix(in oklab, var(--accent) 22%, transparent);
      border-radius: 8px;
    }
    .spin-import-notice-text {
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--content-2);
      line-height: 1.4;
    }
    .spin-picker-chev {
      color: var(--content-3);
      transition: transform 0.15s var(--ease-out);
      flex-shrink: 0;
    }
    .spin-picker-btn[aria-expanded="true"] .spin-picker-chev {
      transform: rotate(180deg);
    }
    .spin-picker-panel {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      z-index: 20;
      min-width: 220px;
      max-width: 320px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.18), 0 2px 6px -2px rgba(0, 0, 0, 0.08);
      padding: 4px;
      display: flex;
      flex-direction: column;
    }
    .spin-picker-list {
      list-style: none;
      margin: 0;
      padding: 0;
      max-height: 220px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .spin-picker-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 7px 8px;
      border-radius: 6px;
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: 14px;
      color: var(--content);
      background: transparent;
      border: 0;
      width: 100%;
      text-align: left;
      transition: background 0.1s;
    }
    .spin-picker-item:hover {
      background: var(--surface-2);
    }
    .spin-picker-item-check {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
      color: var(--accent);
      opacity: 0;
    }
    .spin-picker-item[aria-current="true"] .spin-picker-item-check {
      opacity: 1;
    }
    .spin-picker-item-name {
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .spin-picker-item-count {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--content-3);
      flex-shrink: 0;
    }
    .spin-picker-divider {
      height: 1px;
      background: var(--border);
      margin: 4px 6px;
    }
    .spin-picker-grouplabel {
      font-family: var(--font-sans);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--content-3);
      padding: 8px 8px 4px;
    }
    .spin-picker-presets {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .spin-picker-actions {
      display: flex;
      flex-direction: column;
      gap: 1px;
    }
    .spin-picker-action {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 7px 8px;
      border-radius: 6px;
      cursor: pointer;
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--content-2);
      background: transparent;
      border: 0;
      text-align: left;
      transition: background 0.1s, color 0.1s;
    }
    .spin-picker-action:hover {
      background: var(--surface-2);
      color: var(--content);
    }
    .spin-picker-action-danger:hover {
      color: var(--color-rust-500);
    }
    .spin-picker-action[disabled] {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .spin-icon-btn {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--content-3);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .spin-icon-btn:hover {
      background: var(--surface-3);
      color: var(--content);
      border-color: var(--border);
    }

    .spin-list {
      list-style: none;
      padding: 0;
      margin: 0;
      max-height: clamp(340px, 52vh, 560px);
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 2px;
      scrollbar-width: thin;
    }
    .spin-list-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 8px 10px;
      border-radius: 9px;
      transition: background 0.12s;
      touch-action: pan-y;
    }
    .spin-list-item:hover {
      background: var(--surface-3);
    }
    .spin-list-item:focus-within {
      background: color-mix(in oklab, var(--accent) 5%, var(--surface-3));
    }
    .spin-list-grip {
      flex-shrink: 0;
      width: 14px;
      height: 24px;
      margin-left: -4px;
      margin-right: -4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: 0;
      padding: 0;
      cursor: grab;
      color: var(--content-4);
      opacity: 0.45;
      touch-action: none;
      border-radius: 4px;
      transition: opacity 0.12s, color 0.12s, background 0.12s;
    }
    .spin-list-item:hover .spin-list-grip,
    .spin-list-item:focus-within .spin-list-grip {
      opacity: 1;
    }
    .spin-list-grip:hover {
      color: var(--content-2);
      background: var(--surface);
    }
    .spin-list-grip:active,
    .spin-list-item-dragging .spin-list-grip {
      cursor: grabbing;
      color: var(--content);
    }
    .spin-list-item-dragging {
      opacity: 0.55;
      background: var(--surface-3);
      z-index: 2;
      position: relative;
    }
    .spin-list-item-drop-before {
      box-shadow: inset 0 2px 0 0 var(--accent);
    }
    .spin-list-item-drop-after {
      box-shadow: inset 0 -2px 0 0 var(--accent);
    }
    .spin-list-color {
      width: 22px;
      height: 22px;
      border-radius: 6px;
      flex-shrink: 0;
      border: 1px solid rgba(20, 17, 11, 0.18);
      padding: 0;
      cursor: pointer;
      position: relative;
      transition: transform 0.12s, box-shadow 0.12s;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    }
    .spin-list-color:hover {
      transform: scale(1.12);
    }
    .spin-list-color:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .spin-list-color[data-custom="true"]::after {
      content: "";
      position: absolute;
      right: -2px;
      bottom: -2px;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--surface);
      border: 1px solid currentColor;
    }
    .spin-list-input {
      flex: 1;
      border: 0;
      background: transparent;
      font-family: var(--font-sans);
      font-size: 14.5px;
      line-height: 1.35;
      color: var(--content);
      padding: 4px 0;
      min-width: 0;
    }
    .spin-list-input::placeholder {
      color: var(--content-4);
    }
    .spin-list-input:focus {
      outline: none;
    }
    .spin-list-input:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .spin-list-weight {
      width: 38px;
      flex-shrink: 0;
      border: 1px solid transparent;
      background: transparent;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 12px;
      font-variant-numeric: tabular-nums;
      color: var(--content-4);
      padding: 3px 6px;
      border-radius: 6px;
      text-align: right;
      -moz-appearance: textfield;
      transition: border-color 0.12s, color 0.12s, background 0.12s;
    }
    .spin-list-weight::-webkit-outer-spin-button,
    .spin-list-weight::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
    .spin-list-weight[data-custom="true"] {
      color: var(--content);
      background: var(--surface-3);
    }
    .spin-list-wins {
      flex-shrink: 0;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 12px;
      font-variant-numeric: tabular-nums;
      color: var(--accent);
      background: color-mix(in oklab, var(--accent) 10%, transparent);
      border: 1px solid color-mix(in oklab, var(--accent) 25%, transparent);
      padding: 2px 7px;
      border-radius: 9999px;
      letter-spacing: 0.01em;
    }
    .spin-list-wins-zero {
      color: var(--content-4);
      background: transparent;
      border-color: transparent;
    }
    .spin-list-dup {
      flex-shrink: 0;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--spin-warn);
      background: color-mix(in oklab, var(--spin-warn) 12%, transparent);
      border: 1px solid color-mix(in oklab, var(--spin-warn) 30%, transparent);
      padding: 2px 7px;
      border-radius: 9999px;
    }
    .spin-list-input[aria-invalid="true"] {
      text-decoration: underline;
      text-decoration-color: color-mix(
        in oklab,
        var(--spin-warn) 65%,
        transparent
      );
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .spin-list-item:hover .spin-list-weight,
    .spin-list-item:focus-within .spin-list-weight {
      border-color: var(--border, rgba(20, 17, 11, 0.12));
    }
    .spin-list-weight:focus-visible {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 35%, transparent);
    }
    .spin-list-remove {
      width: 26px;
      height: 26px;
      border-radius: 7px;
      border: 0;
      background: transparent;
      color: var(--content-4);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.12s, background 0.12s, color 0.12s;
    }
    .spin-list-item:hover .spin-list-remove,
    .spin-list-item:focus-within .spin-list-remove {
      opacity: 1;
    }
    .spin-list-remove:hover {
      background: var(--surface);
      color: var(--color-rust-500);
    }

    .spin-add {
      display: flex;
      gap: 0.5rem;
    }
    .spin-add-input {
      flex: 1;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 14px;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .spin-add-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
    }
    .spin-add-btn {
      padding: 0.55rem 1rem;
      border-radius: 8px;
      border: 0;
      background: var(--accent);
      color: white;
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s;
    }
    .spin-add-btn:hover {
      background: var(--accent-2);
    }

    .spin-bulk {
      border-top: 1px solid var(--border);
      padding-top: 1rem;
    }
    .spin-bulk summary {
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      letter-spacing: 0.05em;
      list-style: none;
      user-select: none;
    }
    .spin-bulk summary::-webkit-details-marker { display: none; }
    .spin-bulk summary::before {
      content: "+";
      display: inline-block;
      width: 1em;
      color: var(--content-4);
    }
    .spin-bulk[open] summary::before { content: "−"; }
    .spin-bulk textarea {
      width: 100%;
      margin-top: 0.5rem;
      padding: 0.55rem 0.75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-mono);
      font-size: 13px;
      resize: vertical;
    }
    .spin-bulk textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
    }
    .spin-bulk-btn {
      margin-top: 0.5rem;
      padding: 0.45rem 0.85rem;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--content);
      font-family: var(--font-sans);
      font-size: 13px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .spin-bulk-btn:hover {
      background: var(--surface-3);
    }

    .spin-history {
      border-top: 1px solid var(--border);
      padding-top: 1rem;
      margin-top: 0.75rem;
    }
    .spin-history summary {
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--content-3);
      letter-spacing: 0.05em;
      list-style: none;
      user-select: none;
    }
    .spin-history summary::-webkit-details-marker { display: none; }
    .spin-history summary::before {
      content: "+";
      display: inline-block;
      width: 1em;
      color: var(--content-4);
    }
    .spin-history[open] summary::before { content: "−"; }
    .spin-history-count {
      font-family: var(--font-mono);
      color: var(--content-4);
      font-size: 11px;
      margin-left: 0.55em;
      font-variant-numeric: tabular-nums;
    }
    .spin-history-list {
      list-style: none;
      padding: 0;
      margin: 0.6rem 0 0;
      max-height: 240px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .spin-history-item {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr) minmax(0, 1.4fr);
      gap: 10px;
      padding: 5px 8px;
      border-radius: 6px;
      font-size: 12.5px;
      align-items: center;
    }
    .spin-history-item:hover {
      background: var(--surface-2);
    }
    .spin-history-time {
      color: var(--content-4);
      font-family: var(--font-mono);
      font-variant-numeric: tabular-nums;
      font-size: 11.5px;
    }
    .spin-history-wheel {
      color: var(--content-3);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .spin-history-winner {
      color: var(--content);
      font-weight: 500;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .spin-history-empty {
