      if (e.key === "Escape" && embedModal && !embedModal.hidden) {
        closeEmbedModal();
        return;
      }
      if (e.key === "Escape" && helpModal && !helpModal.hidden) {
        hideHelp();
        return;
      }
      if (e.key === "Escape" && !modal!.hidden) {
        hideWinner();
        return;
      }
      if (e.key === "Escape" && soundConfig && !soundConfig.hidden) {
        closeSoundConfig();
        return;
      }
      if (e.key === "Escape" && sceneConfig && !sceneConfig.hidden) {
        closeSceneConfig();
        return;
      }
      if (e.key === " " && !modal!.hidden) return;
      const tag = (document.activeElement?.tagName || "").toLowerCase();
      if (tag === "input" || tag === "textarea") return;
      if ((e.metaKey || e.ctrlKey) && !e.shiftKey && (e.key === "z" || e.key === "Z")) {
        if (toastActionHandler) {
          e.preventDefault();
          const handler = toastActionHandler;
          toastActionHandler = null;
          if (toastTimer) {
            window.clearTimeout(toastTimer);
            toastTimer = null;
          }
          toast?.classList.remove("is-visible");
          if (toastAction) toastAction.hidden = true;
          handler();
        }
        return;
      }
      if (e.key === "?") {
        e.preventDefault();
        if (helpModal && !helpModal.hidden) hideHelp();
        else showHelp();
        return;
      }
      if (helpModal && !helpModal.hidden) return;
      if (e.key === " " || e.code === "Space") {
        e.preventDefault();
        if (!spinning) spin();
      }
