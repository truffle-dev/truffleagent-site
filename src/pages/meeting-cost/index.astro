---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Meeting Cost · Live Meeting Cost Ticker";
const description =
  "Watch the dollar cost of a meeting tick up in real time. Pick attendees, hourly rate, currency, and start. No accounts, no servers, works offline.";
const ogImage = "/img/og.jpg";
const canonical = "https://truffleagent.com/meeting-cost/";

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "Meeting Cost",
  alternateName: ["Meeting Cost Calculator", "Meeting Timer", "Time is Money"],
  url: canonical,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Any (Web)",
  browserRequirements: "Requires JavaScript",
  isAccessibleForFree: true,
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description,
  featureList: [
    "Live dollar counter ticking up each second",
    "Pick attendees, hourly rate, currency",
    "Start, pause, reset",
    "Eight currencies (USD, EUR, GBP, CAD, AUD, JPY, INR, BRL)",
    "Share configuration by link",
    "Works offline (PWA)",
    "No ads, no signup, no trackers",
  ],
  author: "Truffle",
};

const faq = [
  {
    q: "How is the cost calculated?",
    a: "Attendees multiplied by hourly rate multiplied by the fraction of an hour that has elapsed. Updated several times per second for a smooth count.",
  },
  {
    q: "Is it free?",
    a: "Yes. No ads, no signup, no paid tier. The full feature set is free forever.",
  },
  {
    q: "What hourly rate should I use?",
    a: "A common shortcut is the fully-loaded rate, roughly the gross salary plus 30% to 50% for benefits, divided by 2000 hours per year. For a senior engineer in the US that lands somewhere between $100 and $200 per hour.",
  },
  {
    q: "Does it work offline?",
    a: "Yes. After your first visit, the page is cached as a Progressive Web App and works without an internet connection.",
  },
  {
    q: "Can I share the meeting cost view?",
    a: "Yes. Tap Share to copy a link that encodes the attendees, rate, and currency. The recipient sees the same starting config.",
  },
  {
    q: "Does it track me or use cookies?",
    a: "No. There are no ads, no analytics, no third-party scripts. Everything runs in your browser.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} canonical={canonical}>
  <Fragment slot="head">
    <link rel="manifest" href="/meeting-cost/manifest.webmanifest" />
    <script type="application/ld+json" set:html={JSON.stringify(webAppJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </Fragment>

  <main class="mc-page">
    <header class="mc-topbar">
      <div class="mc-topbar-inner">
        <div class="mc-brand">
          <span class="mc-brand-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v18" />
              <path d="M16 7H10a2 2 0 100 4h4a2 2 0 110 4H8" />
            </svg>
          </span>
          <span class="mc-brand-name">Meeting Cost</span>
        </div>
        <div class="mc-topbar-actions">
          <button id="share-btn" type="button" class="mc-btn mc-btn-ghost">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8h16v-8" /><path d="M12 3v13" /><path d="M7 8l5-5 5 5" /></svg>
            <span>Share</span>
          </button>
        </div>
      </div>
    </header>

    <section class="mc-stage" aria-live="polite">
      <p class="mc-eyebrow">This meeting has cost</p>
      <div id="cost-display" class="mc-cost">$0.00</div>
      <div class="mc-row">
        <span class="mc-pill" id="elapsed-display">0:00 elapsed</span>
        <span class="mc-pill" id="rate-display">$0 / sec</span>
      </div>
      <div class="mc-controls">
        <button id="start-btn" type="button" class="mc-btn mc-btn-primary mc-btn-lg">Start</button>
        <button id="pause-btn" type="button" class="mc-btn mc-btn-ghost mc-btn-lg" hidden>Pause</button>
        <button id="reset-btn" type="button" class="mc-btn mc-btn-ghost mc-btn-lg">Reset</button>
      </div>
    </section>

    <section class="mc-config">
      <div class="mc-config-row">
        <label class="mc-field">
          <span class="mc-field-label">People</span>
          <input id="people-input" type="number" min="1" max="999" step="1" value="6" />
        </label>
        <label class="mc-field">
          <span class="mc-field-label">Hourly rate per person</span>
          <input id="rate-input" type="number" min="0" max="100000" step="1" value="120" />
        </label>
        <label class="mc-field">
          <span class="mc-field-label">Currency</span>
          <select id="currency-input">
            <option value="USD">USD · $</option>
            <option value="EUR">EUR · €</option>
            <option value="GBP">GBP · £</option>
            <option value="CAD">CAD · C$</option>
            <option value="AUD">AUD · A$</option>
            <option value="JPY">JPY · ¥</option>
            <option value="INR">INR · ₹</option>
            <option value="BRL">BRL · R$</option>
          </select>
        </label>
      </div>
      <div class="mc-presets">
        <span class="mc-presets-label">Quick:</span>
        <button type="button" class="mc-chip" data-preset="standup">Standup (5 × $100)</button>
        <button type="button" class="mc-chip" data-preset="planning">Planning (8 × $130)</button>
        <button type="button" class="mc-chip" data-preset="exec">Exec sync (4 × $250)</button>
        <button type="button" class="mc-chip" data-preset="allhands">All-hands (50 × $110)</button>
      </div>
    </section>

    <section class="mc-why">
      <h2>Why this exists</h2>
      <p>
        Most meetings are short, important, and quiet. A few are not. Putting a price on the room
        is a kind of accountability that fits on a single screen. Start the ticker at the top of
        the call, watch it climb, and let the number argue for shorter agendas.
      </p>
    </section>

    <section class="mc-faq" id="faq">
      <h2>Frequently asked questions</h2>
      <dl>
        {faq.map((f) => (
          <div class="mc-faq-item">
            <dt>{f.q}</dt>
            <dd>{f.a}</dd>
          </div>
        ))}
      </dl>
    </section>
  </main>

  <div id="toast" class="mc-toast" role="status" aria-live="polite" hidden></div>
</BaseLayout>

<style is:global>
  :root {
    --mc-bg: #fbfaf5;
    --mc-fg: #1a1611;
    --mc-muted: #6b6359;
    --mc-line: #e5dfd0;
    --mc-card: #ffffff;
    --mc-accent: #b8632f;
    --mc-accent-soft: #f4e4d4;
  }
  :root[data-theme="dark"] {
    --mc-bg: #0e0c08;
    --mc-fg: #f1ece0;
    --mc-muted: #9c9485;
    --mc-line: #2a2620;
    --mc-card: #16130d;
    --mc-accent: #e89968;
    --mc-accent-soft: #2a1f15;
  }

  body { background: var(--mc-bg); color: var(--mc-fg); }
  .mc-page { max-width: 880px; margin: 0 auto; padding: 0 24px 96px; }

  .mc-topbar { border-bottom: 1px solid var(--mc-line); padding: 18px 0; }
  .mc-topbar-inner { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .mc-brand { display: flex; align-items: center; gap: 10px; }
  .mc-brand-mark { display: inline-flex; padding: 6px; border-radius: 8px; background: var(--mc-accent-soft); color: var(--mc-accent); }
  .mc-brand-name { font-family: "Fraunces", serif; font-weight: 500; font-size: 20px; letter-spacing: -0.01em; }

  .mc-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 16px; border-radius: 999px; border: 1px solid var(--mc-line);
    background: var(--mc-card); color: var(--mc-fg);
    font: inherit; font-size: 14px; font-weight: 500;
    cursor: pointer; transition: background .15s ease, border-color .15s ease, color .15s ease;
  }
  .mc-btn:hover { border-color: var(--mc-accent); color: var(--mc-accent); }
  .mc-btn-primary { background: var(--mc-accent); color: var(--mc-bg); border-color: var(--mc-accent); font-weight: 600; }
  .mc-btn-primary:hover { color: var(--mc-bg); filter: brightness(1.05); }
  .mc-btn-ghost { background: transparent; }
  .mc-btn-lg { padding: 12px 24px; font-size: 15px; }

  .mc-stage { padding: 64px 0 32px; text-align: center; }
  .mc-eyebrow { font-family: "JetBrains Mono", monospace; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mc-muted); margin: 0 0 16px; }
  .mc-cost {
    font-family: "Fraunces", serif; font-weight: 500;
    font-size: clamp(64px, 14vw, 132px); line-height: 1; letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    color: var(--mc-fg);
    margin: 0 0 20px;
    transition: color .3s ease;
  }
  .mc-row { display: flex; justify-content: center; gap: 10px; margin-bottom: 28px; flex-wrap: wrap; }
  .mc-pill {
    background: var(--mc-card); border: 1px solid var(--mc-line);
    padding: 6px 12px; border-radius: 999px;
    font-family: "JetBrains Mono", monospace; font-size: 12px; color: var(--mc-muted);
  }
  .mc-controls { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }

  .mc-config { background: var(--mc-card); border: 1px solid var(--mc-line); border-radius: 16px; padding: 22px; margin-top: 28px; }
  .mc-config-row { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  .mc-field { display: flex; flex-direction: column; gap: 6px; }
  .mc-field-label { font-size: 12px; color: var(--mc-muted); font-weight: 500; }
  .mc-field input, .mc-field select {
    font: inherit; padding: 10px 12px; border-radius: 10px;
    border: 1px solid var(--mc-line); background: var(--mc-bg); color: var(--mc-fg);
    outline: none;
  }
  .mc-field input:focus, .mc-field select:focus { border-color: var(--mc-accent); }

  .mc-presets { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 18px; padding-top: 18px; border-top: 1px dashed var(--mc-line); }
  .mc-presets-label { font-size: 12px; color: var(--mc-muted); margin-right: 4px; }
  .mc-chip {
    font: inherit; font-size: 13px;
    padding: 6px 12px; border-radius: 999px;
    border: 1px solid var(--mc-line); background: transparent; color: var(--mc-fg);
    cursor: pointer; transition: background .15s ease, border-color .15s ease;
  }
  .mc-chip:hover { border-color: var(--mc-accent); color: var(--mc-accent); }

  .mc-why { margin-top: 64px; }
  .mc-why h2, .mc-faq h2 { font-family: "Fraunces", serif; font-weight: 400; font-size: 28px; margin: 0 0 16px; letter-spacing: -0.01em; }
  .mc-why p { font-size: 16px; line-height: 1.6; color: var(--mc-fg); max-width: 64ch; margin: 0; }

  .mc-faq { margin-top: 56px; }
  .mc-faq dl { display: grid; gap: 18px; margin: 0; }
  .mc-faq-item { background: var(--mc-card); border: 1px solid var(--mc-line); border-radius: 14px; padding: 16px 20px; }
  .mc-faq-item dt { font-weight: 600; margin: 0 0 6px; }
  .mc-faq-item dd { color: var(--mc-muted); line-height: 1.55; margin: 0; }

  .mc-toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
    background: var(--mc-fg); color: var(--mc-bg);
    padding: 10px 18px; border-radius: 999px; font-size: 14px;
    box-shadow: 0 4px 16px rgba(0,0,0,.18); z-index: 60;
  }
  .mc-toast[hidden] { display: none !important; }

  @media (max-width: 640px) {
    .mc-config-row { grid-template-columns: 1fr; }
  }
</style>

<script>
type Config = { people: number; rate: number; currency: string };
type Persist = { v: 1; cfg: Config };

const STORAGE_KEY = "meeting-cost:v1";
const DEFAULT_CFG: Config = { people: 6, rate: 120, currency: "USD" };

function loadPersist(): Persist {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return { v: 1, cfg: { ...DEFAULT_CFG } };
    const p = JSON.parse(raw);
    if (p && p.v === 1 && p.cfg) return { v: 1, cfg: { ...DEFAULT_CFG, ...p.cfg } };
  } catch {}
  return { v: 1, cfg: { ...DEFAULT_CFG } };
}

function savePersist(p: Persist): void {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(p)); } catch {}
}

let persist = loadPersist();
let running = false;
let elapsedMs = 0;
let lastTick = 0;
let raf = 0;

function formatCurrency(value: number, currency: string): string {
  try {
    return new Intl.NumberFormat(undefined, {
      style: "currency",
      currency,
      maximumFractionDigits: 2,
      minimumFractionDigits: 2,
    }).format(value);
  } catch {
    return `${currency} ${value.toFixed(2)}`;
  }
}

function formatElapsed(ms: number): string {
  const total = Math.floor(ms / 1000);
  const h = Math.floor(total / 3600);
  const m = Math.floor((total % 3600) / 60);
  const s = total % 60;
  if (h > 0) return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")} elapsed`;
  return `${m}:${String(s).padStart(2, "0")} elapsed`;
}

function dollarsPerSec(): number {
  return (persist.cfg.people * persist.cfg.rate) / 3600;
}

function update(): void {
  const display = document.getElementById("cost-display") as HTMLElement;
  const elapsedEl = document.getElementById("elapsed-display") as HTMLElement;
  const rateEl = document.getElementById("rate-display") as HTMLElement;
  const cost = dollarsPerSec() * (elapsedMs / 1000);
  display.textContent = formatCurrency(cost, persist.cfg.currency);
  elapsedEl.textContent = formatElapsed(elapsedMs);
  rateEl.textContent = `${formatCurrency(dollarsPerSec(), persist.cfg.currency)} / sec`;
}

function loop(now: number): void {
  if (!running) return;
  if (lastTick === 0) lastTick = now;
  elapsedMs += now - lastTick;
  lastTick = now;
  update();
  raf = requestAnimationFrame(loop);
}

function start(): void {
  if (running) return;
  running = true;
  lastTick = 0;
  raf = requestAnimationFrame(loop);
  (document.getElementById("start-btn") as HTMLButtonElement).hidden = true;
  (document.getElementById("pause-btn") as HTMLButtonElement).hidden = false;
}

function pause(): void {
  if (!running) return;
  running = false;
  cancelAnimationFrame(raf);
  (document.getElementById("start-btn") as HTMLButtonElement).hidden = false;
  (document.getElementById("pause-btn") as HTMLButtonElement).hidden = true;
  (document.getElementById("start-btn") as HTMLButtonElement).textContent = "Resume";
}

function reset(): void {
  running = false;
  cancelAnimationFrame(raf);
  elapsedMs = 0;
  lastTick = 0;
  (document.getElementById("start-btn") as HTMLButtonElement).hidden = false;
  (document.getElementById("start-btn") as HTMLButtonElement).textContent = "Start";
  (document.getElementById("pause-btn") as HTMLButtonElement).hidden = true;
  update();
}

function readForm(): void {
  const people = Math.max(1, Math.min(999, Number((document.getElementById("people-input") as HTMLInputElement).value) || 1));
  const rate = Math.max(0, Math.min(100000, Number((document.getElementById("rate-input") as HTMLInputElement).value) || 0));
  const currency = (document.getElementById("currency-input") as HTMLSelectElement).value;
  persist.cfg = { people, rate, currency };
  savePersist(persist);
  update();
}

function writeForm(): void {
  (document.getElementById("people-input") as HTMLInputElement).value = String(persist.cfg.people);
  (document.getElementById("rate-input") as HTMLInputElement).value = String(persist.cfg.rate);
  (document.getElementById("currency-input") as HTMLSelectElement).value = persist.cfg.currency;
}

function importParams(): void {
  const params = new URLSearchParams(window.location.search);
  const p = params.get("p");
  const r = params.get("r");
  const c = params.get("c");
  let changed = false;
  if (p) { const n = Math.max(1, Math.min(999, Number(p))); if (!Number.isNaN(n)) { persist.cfg.people = n; changed = true; } }
  if (r) { const n = Math.max(0, Math.min(100000, Number(r))); if (!Number.isNaN(n)) { persist.cfg.rate = n; changed = true; } }
  if (c && /^[A-Z]{3}$/.test(c)) { persist.cfg.currency = c; changed = true; }
  if (changed) {
    savePersist(persist);
    history.replaceState(null, "", window.location.pathname);
  }
}

function shareLink(): void {
  const url = new URL(window.location.href);
  url.search = "";
  url.searchParams.set("p", String(persist.cfg.people));
  url.searchParams.set("r", String(persist.cfg.rate));
  url.searchParams.set("c", persist.cfg.currency);
  navigator.clipboard.writeText(url.toString()).then(
    () => showToast("Link copied!"),
    () => showToast("Copy failed."),
  );
}

function showToast(msg: string): void {
  const toast = document.getElementById("toast") as HTMLElement;
  toast.textContent = msg;
  toast.hidden = false;
  setTimeout(() => { toast.hidden = true; }, 2200);
}

function applyPreset(kind: string): void {
  const presets: Record<string, Config> = {
    standup: { people: 5, rate: 100, currency: persist.cfg.currency },
    planning: { people: 8, rate: 130, currency: persist.cfg.currency },
    exec: { people: 4, rate: 250, currency: persist.cfg.currency },
    allhands: { people: 50, rate: 110, currency: persist.cfg.currency },
  };
  const c = presets[kind];
  if (!c) return;
  persist.cfg = c;
  savePersist(persist);
  writeForm();
  reset();
  showToast("Preset applied.");
}

function init(): void {
  importParams();
  writeForm();
  update();

  document.getElementById("start-btn")?.addEventListener("click", start);
  document.getElementById("pause-btn")?.addEventListener("click", pause);
  document.getElementById("reset-btn")?.addEventListener("click", reset);
  document.getElementById("share-btn")?.addEventListener("click", shareLink);
  document.getElementById("people-input")?.addEventListener("input", readForm);
  document.getElementById("rate-input")?.addEventListener("input", readForm);
  document.getElementById("currency-input")?.addEventListener("change", readForm);

  document.querySelectorAll<HTMLButtonElement>(".mc-chip[data-preset]").forEach((btn) => {
    btn.addEventListener("click", () => applyPreset(btn.dataset.preset ?? ""));
  });

  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("/meeting-cost/sw.js").catch(() => {});
  }
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", init);
} else {
  init();
}
</script>
