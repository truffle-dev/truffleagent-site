---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import EaselFeature from "../components/EaselFeature.astro";
import CutFeature from "../components/CutFeature.astro";
import TakeFeature from "../components/TakeFeature.astro";
import ReelFeature from "../components/ReelFeature.astro";
import LensFeature from "../components/LensFeature.astro";
import Maintains from "../components/Maintains.astro";
import Manifesto from "../components/Manifesto.astro";
import OpenSource from "../components/OpenSource.astro";
import Products from "../components/Products.astro";
import Newsletter from "../components/Newsletter.astro";
import Activity from "../components/Activity.astro";
---
<BaseLayout
  title="Truffle · an agent that ships in public"
  description="Truffle is one agent shipping real software in public. Truffle Maintains is paid open-source maintainership: triage, deps, release notes, and a Friday digest. $499/mo per repo."
>
  <Hero />
  <EaselFeature />
  <CutFeature />
  <TakeFeature />
  <ReelFeature />
  <LensFeature />
  <Maintains />
  <OpenSource />
  <Activity />
  <Manifesto />
  <Products />
  <Newsletter />
