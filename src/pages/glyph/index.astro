---
import BaseLayout from "../../layouts/BaseLayout.astro";

// One row per component in the v0.1 seed. Snippets are the smallest
// hello-world that compiles after a glyph add, so anyone scanning the
// page can read the API without leaving the tab.
const components = [
  {
    slug: "theme",
    title: "Theme",
    blurb: "Token palette every component reads from. Edit one file to retheme an entire app.",
    snippet: `import "github.com/truffle-dev/glyph/components/theme"

t := theme.Default     // dark
t := theme.Light       // warm paper
fmt.Println(t.Primary) // lipgloss.Color`,
  },
  {
    slug: "chat-bubble",
    title: "Chat bubble",
    blurb: "Role-aware speech bubble with width-aware wrapping. user / assistant / system / tool.",
    snippet: `b := chatbubble.New(theme.Default).
  WithRole(chatbubble.RoleAssistant).
  WithLabel("glyph").
  WithText("Welcome.").
  WithWidth(72)
fmt.Println(b.View())`,
  },
  {
    slug: "chat-input",
    title: "Chat input",
    blurb: "Single-line chat prompt with placeholder, cursor, focus state, submit and cancel bindings.",
    snippet: `i := chatinput.New(theme.Default).
  WithPlaceholder("Type a message…").
  WithPrompt("you › ").
  WithWidth(72).
  Focus()`,
  },
  {
    slug: "chat-thread",
    title: "Chat thread",
    blurb: "Vertically scrolling conversation surface. Composes chat-bubble. Arrow keys, PgUp/PgDn, Home/End.",
    snippet: `t := chatthread.New(theme.Default).WithSize(72, 12)
t = t.Append(chatthread.Message{
  Role: chatbubble.RoleAssistant,
  Label: "glyph", Text: "Welcome.",
})`,
  },
  {
    slug: "command-palette",
    title: "Command palette",
    blurb: "Filterable modal command picker. Substring matcher by default; swap in your own.",
    snippet: `p := commandpalette.New(theme.Default).
  WithCommands([]commandpalette.Command{
    {ID: "save", Title: "Save file", Keybinding: "ctrl+s"},
  }).
  WithSize(72, 14)`,
  },
  {
    slug: "markdown-viewer",
    title: "Markdown viewer",
    blurb: "Scrollable terminal markdown. Headings, paragraphs, bullets, blockquotes, code, links.",
    snippet: `md := markdownviewer.New(theme.Default).
  WithSize(80, 18).
  WithSource(source)`,
  },
  {
    slug: "log-stream",
    title: "Log stream",
    blurb: "Bounded color-coded log view that tails like tail -f. Level filter, capacity ring.",
    snippet: `s := logstream.New(theme.Default).
  WithSize(96, 16).
  WithMinLevel(logstream.LevelInfo)
s = s.Append(logstream.Entry{
  Level: logstream.LevelWarn, Source: "auth",
  Message: "deprecated token format",
})`,
  },
  {
    slug: "diff-view",
    title: "Diff view",
    blurb: "Unified-diff renderer with line numbers, color-coded additions and removals.",
    snippet: `lines := diffview.ParseUnified(rawDiff)
d := diffview.New(theme.Default).
  WithSize(96, 18).
  WithLines(lines)`,
  },
  {
    slug: "notification-toast",
    title: "Notification toast",
    blurb: "Stacked dismissible notifications with level-aware coloring and per-toast TTLs.",
    snippet: `tray := notificationtoast.New(theme.Default).
  WithWidth(48).WithMaxItems(3)
tray = tray.Push(notificationtoast.Toast{
  ID: "build-1", Level: notificationtoast.LevelSuccess,
  Title: "Success", Message: "Build complete.",
  ExpiresAt: time.Now().Add(6 * time.Second),
})`,
  },
  {
    slug: "status-bar",
    title: "Status bar",
    blurb: "Single-line three-segment status bar. Left fills from left, right anchors right, truncates left first under pressure.",
    snippet: `bar := statusbar.New(theme.Default).
  WithWidth(80).
  WithLeft(statusbar.Item{Text: "glyph"}).
  WithCenter(statusbar.Item{Text: "main"}).
  WithRight(statusbar.Item{Text: "OK",
    Style: statusbar.StyleSuccess})`,
  },
  {
    slug: "spinner",
    title: "Spinner",
    blurb: "Animated single-glyph indicator with an optional label. Five styles: dots, line, arc, pulse, bounce. TickMsg carries an ID so a parent can multiplex several spinners.",
    snippet: `s := spinner.New(theme.Default).
  WithStyle(spinner.StyleDots).
  WithLabel("Working")`,
  },
  {
    slug: "tabs",
    title: "Tabs",
    blurb: "Horizontal labeled tab row primitive. Arrow keys or Tab cycle with wrap. Parent owns the panels rendered below.",
    snippet: `t := tabs.New(theme.Default).
  WithTabs([]string{"chat", "logs", "diff"}).
  WithActive(0)`,
  },
  {
    slug: "panel",
    title: "Panel",
    blurb: "Bordered container with optional title and footer. The workhorse layout primitive: wrap any view in one. Two border weights, configurable padding.",
    snippet: `p := panel.New(theme.Default).
  WithTitle("Logs").
  WithFooter("3 entries").
  WithContent(logs.View())`,
  },
  {
    slug: "list",
    title: "List",
    blurb: "Vertical selectable list with cursor highlight, optional hints, disabled items, and internal scrolling. The navigation primitive most agent UIs reach for after tabs.",
    snippet: `l := list.New(theme.Default).
  WithHeight(8).
  WithItems([]list.Item{
    {Label: "Inbox", Hint: "12 unread"},
    {Label: "Drafts"},
  })`,
  },
  {
    slug: "progress-bar",
    title: "Progress bar",
    blurb: "Determinate progress indicator with an optional label and percentage readout. Color- and glyph-tunable. Pair with spinner for indeterminate work.",
    snippet: `bar := progressbar.New(theme.Default).
  WithPercent(0.42).
  WithLabel("uploading").
  WithWidth(40)`,
  },
  {
    slug: "key-hints",
    title: "Key hints",
    blurb: "Compact footer of key-and-description pairs. The bottom-row cheatsheet every TUI grows into. Width-clamped so it never wraps mid-binding.",
    snippet: `hints := keyhints.New(theme.Default).
  WithHints([]keyhints.Hint{
    {Key: "Tab", Desc: "next pane"},
    {Key: "q",   Desc: "quit"},
  })`,
  },
  {
    slug: "text-input",
    title: "Text input",
    blurb: "Multi-line text input with 2D cursor, placeholder, focus. Alt+Left/Right jump words. Ctrl-U kills to cursor, Ctrl-K kills to end of line. Enter inserts a newline; Ctrl-D accepts.",
    snippet: `t := textinput.New(theme.Default).
  WithPlaceholder("Commit message…").
  WithWidth(72).
  WithHeight(6).
  Focus()`,
  },
  {
    slug: "select",
    title: "Select",
    blurb: "Bounded single-choice popover with optional substring typeahead, scroll window, hint column, and inlaid title. Emits SelectMsg on commit and CancelMsg on Esc.",
    snippet: `s := selectinput.New(theme.Default).
  WithTitle("Pick a region").
  WithOptions([]selectinput.Option{
    {Label: "us-east", Hint: "Virginia"},
    {Label: "us-west", Hint: "Oregon"},
  }).
  WithTypeahead(true)`,
  },
  {
    slug: "modal",
    title: "Modal",
    blurb: "Border-with-title overlay container with body, footer, and a configurable close key. Pairs with lipgloss.Place to position over a parent view; emits CloseMsg on Esc.",
    snippet: `m := modal.New(theme.Default).
  WithTitle("Confirm action").
  WithBody("This cannot be undone.").
  WithFooter("Enter to confirm · Esc to cancel").
  WithSize(60, 8)`,
  },
  {
    slug: "confirmation",
    title: "Confirmation",
    blurb: "Two-button yes/no prompt with focus-managed buttons, single-keystroke y/n shortcuts, dangerous-action styling, and prompt reflow.",
    snippet: `c := confirmation.New(theme.Default).
  WithPrompt("Delete this engagement?").
  WithDangerous(true).
  WithYesLabel("Delete").
  WithNoLabel("Keep")`,
  },
  {
    slug: "kbd",
    title: "Kbd",
    blurb: "Stateless keycap atom. Renders single keys and chords as Unicode-cap glyphs (ctrl+k → ⌃ + K, enter → ⏎). No Model. Drop inside hint rows, command palettes, modals.",
    snippet: `import "github.com/truffle-dev/glyph/components/kbd"

cap := kbd.Render("ctrl")        // ⌃
chord := kbd.Chord("ctrl", "k")  // ⌃ + K
seq := kbd.Sequence(
  kbd.Chord("g"), kbd.Chord("g")) // g , g`,
  },
  {
    slug: "table",
    title: "Table",
    blurb: "Sortable, scrollable data grid with column alignment, numeric-aware sort, cursor highlight, optional row selection, PgUp/PgDn/Home/End, and ←→ to move the active sort column.",
    snippet: `tbl := table.New().
  WithColumns(
    table.Column{Key: "repo",  Title: "Repo",  Sortable: true},
    table.Column{Key: "stars", Title: "Stars", Align: table.AlignRight, Sortable: true},
  ).
  WithRowSelection(true)`,
  },
  {
    slug: "stat-card",
    title: "Stat card",
    blurb: "Dashboard metric tile with label, value, trend glyph (▲/▼/—), delta, sublabel, and an optional emphasis treatment that swaps the border + surface tokens.",
    snippet: `c := statcard.New().
  WithLabel("Merged this week").
  WithValue("30").
  WithDelta("+8").
  WithTrend(statcard.TrendUp).
  WithSublabel("vs prior 7d").
  WithEmphasis(true)`,
  },
];

const principles = [
  {
    n: "01",
    h: "Copy, don't depend.",
    p: "Every component is downloadable as source. No glyph runtime dependency. Delete glyph after install and your app still works.",
  },
  {
    n: "02",
    h: "One framework at a time.",
    p: "v0.1 is Bubble Tea. Adapters for ratatui, Textual, and Ink follow. The launch will not dilute itself across three frameworks.",
  },
  {
    n: "03",
    h: "Tokens, not hardcoded colors.",
    p: "Every component references theme.Default. Theming a whole app is one file change.",
  },
  {
    n: "04",
    h: "Stories are tests are screenshots.",
    p: "A component without a story file doesn't ship. Stories drive the screenshot pipeline and the demo equally.",
  },
];
---
<BaseLayout
  title="glyph · components for the terminal"
  description="A copy-paste component library for terminal UIs. Install the CLI, run glyph add chat-thread, and a chat surface drops into your repo as plain Go source you own."
>
  <article class="glyph">
    <header class="glyph-head">
      <div class="container-page">
        <p class="eyebrow">An open-source project by Truffle</p>
        <h1 class="display text-balance">
          glyph. Components for the <em>terminal.</em>
        </h1>
        <p class="lede text-balance">
          Beautifully designed components for terminal UIs. Yours to copy, paste, own. Install the CLI, run <code class="mono">glyph add chat-thread</code>, and a chat surface drops into your repo as plain Go source you own. No glyph runtime dependency. No version pinning. No magic.
        </p>

        <div class="install-box">
          <pre class="install-pre mono"><code>{`go install github.com/truffle-dev/glyph/cmd/glyph@latest
cd path/to/your/project
glyph init
glyph add chat-thread`}</code></pre>
        </div>

        <p class="meta head-meta">
          v0.1 is <a href="https://github.com/charmbracelet/bubbletea">Bubble Tea</a>. Adapters for ratatui, Textual, and Ink follow.
        </p>

        <div class="head-chips">
          <a class="head-chip" href="https://github.com/truffle-dev/glyph">
            <span class="head-chip-label mono">repo</span>
            <span class="head-chip-value mono">github.com/truffle-dev/glyph</span>
          </a>
          <a class="head-chip" href="https://github.com/truffle-dev/glyph/releases/tag/v0.2.0">
            <span class="head-chip-label mono">release</span>
            <span class="head-chip-value mono">v0.2.0</span>
          </a>
          <a class="head-chip" href="https://pkg.go.dev/github.com/truffle-dev/glyph">
            <span class="head-chip-label mono">docs</span>
            <span class="head-chip-value mono">pkg.go.dev</span>
          </a>
          <a class="head-chip" href="/glyph/demo/">
            <span class="head-chip-label mono">demos</span>
            <span class="head-chip-value mono">three runnable surfaces</span>
          </a>
        </div>
      </div>
    </header>

    <section class="reel-section">
      <div class="container-page">
        <figure class="reel">
          <div class="reel-frame">
            <div class="reel-chrome">
              <span class="reel-dot reel-dot-red" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-yellow" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-green" aria-hidden="true"></span>
              <span class="reel-title mono">glyph · reel</span>
            </div>
            <img
              src="/img/glyph/reel.gif"
              alt="A thirty-second TUI reel showing glyph's chat thread, command palette, log stream, sidebar with toast, progress bar, and diff view, all composed from copy-paste components."
              width="979"
              height="694"
              loading="lazy"
              decoding="async"
              class="reel-img"
            />
          </div>
          <figcaption class="reel-caption">
            Six surfaces in thirty seconds. Every frame is real Bubble Tea output, recorded from <code class="mono">examples/reel</code>. The whole binary fits in one file.
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="components-section">
      <div class="container-page">
        <div class="components-head">
          <p class="eyebrow">v0.1 + v0.2 · twenty-three components</p>
          <h2 class="editorial text-balance">
            Twenty-three <em>opinionated</em> surfaces, one design language.
          </h2>
          <p class="prose-truffle components-intro">
            Each card shows the smallest hello-world that compiles after a <code class="mono">glyph add</code>. Click through for the full source, the JSON manifest, and the install command.
          </p>
        </div>

        <div class="components-grid">
          {components.map((c) => (
            <article class="component-card">
              <header class="component-head">
                <h3 class="component-title">{c.title}</h3>
                <a class="component-slug mono" href={`https://github.com/truffle-dev/glyph/tree/main/components/${c.slug}`} rel="noopener">
                  {c.slug}
                </a>
              </header>
              <figure class="component-preview">
                <img
                  src={`/img/glyph/${c.slug}.png`}
                  alt={`Terminal preview of the ${c.slug} component.`}
                  width="689"
                  height="490"
                  loading="lazy"
                  decoding="async"
                />
              </figure>
              <p class="component-blurb">{c.blurb}</p>
              <pre class="component-snippet mono"><code>{c.snippet}</code></pre>
              <div class="component-actions">
                <code class="component-install mono">glyph add {c.slug}</code>
                <a class="component-source mono" href={`https://github.com/truffle-dev/glyph/tree/main/components/${c.slug}`} rel="noopener">
                  source ↗
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="principles-section">
      <div class="container-page">
        <div class="principles-head">
          <p class="eyebrow">Design principles</p>
          <h2 class="editorial text-balance">
            Four sentences that <em>shape</em> every component.
          </h2>
        </div>
        <ol class="principles-list">
          {principles.map((p) => (
            <li class="principle">
              <span class="principle-n mono">{p.n}</span>
              <div class="principle-body">
                <h3 class="principle-h">{p.h}</h3>
                <p class="prose-truffle">{p.p}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="runlocal-section">
      <div class="container-prose">
        <p class="eyebrow">See it move</p>
        <h2 class="editorial text-balance">
          One <em>binary</em>. Every component, on stage.
        </h2>
        <p class="prose-truffle">
          The glyph repo ships an <code class="mono">examples/showcase</code> binary: five tabs, a status bar at the bottom, a toast tray overlaying every tab. The seven main component surfaces composed into one TUI. The fastest way to feel the library. The remaining nine components each ship a runnable story under <code class="mono">components/&lt;name&gt;/story/</code>.
        </p>
        <pre class="install-pre mono"><code>{`git clone https://github.com/truffle-dev/glyph
cd glyph
go run ./examples/showcase`}</code></pre>
        <p class="meta">Tab cycles tabs forward, Shift-Tab cycles back. On any non-chat tab, <code class="mono">t</code> fires a toast and <code class="mono">l</code> appends a log entry.</p>
      </div>
    </section>

    <section class="credits-section">
      <div class="container-prose">
        <p class="eyebrow">Credits</p>
        <p class="prose-truffle">
          The shape of glyph is borrowed from <a href="https://ui.shadcn.com">shadcn/ui</a>, which solved this distribution problem for React. The terminal needed the same answer. Built on <a href="https://github.com/charmbracelet/bubbletea">Bubble Tea</a> by Charm. Open source under MIT.
        </p>
        <p class="prose-truffle">
          The repo lives at <a href="https://github.com/truffle-dev/glyph">github.com/truffle-dev/glyph</a>. The fastest first contribution is a new component: copy <code class="mono">components/chat-bubble/</code> as a template, replace the body, add a story file, open a PR.
        </p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .glyph { padding-top: clamp(2rem, 5vw, 4rem); }

  .glyph-head { padding-bottom: clamp(2.5rem, 5vw, 4rem); }
  .glyph-head .eyebrow { display: inline-block; margin-bottom: 1.5rem; }
  .glyph-head h1 { margin: 0 0 1.5rem; max-width: 900px; }
  .glyph-head em { color: var(--accent); }
  .glyph-head .lede {
    max-width: 720px;
    margin: 0 0 2.25rem;
  }
  .glyph-head code {
    background: var(--surface-2);
    padding: 0.1em 0.4em;
    border-radius: 0.25em;
    font-size: 0.95em;
  }

  .install-box {
    margin: 0 0 1.25rem;
    max-width: 720px;
  }
  .install-pre {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }
  .head-meta {
    max-width: 720px;
  }
  .head-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 1.25rem;
  }
  .head-chip {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    overflow: hidden;
    background: var(--surface);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--content);
    transition: border-color 150ms var(--ease-out), transform 150ms var(--ease-out);
  }
  .head-chip:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .head-chip-label {
    background: var(--surface-2);
    color: var(--content-3);
    padding: 0.35rem 0.625rem;
    border-right: 1px solid var(--border);
  }
  .head-chip-value {
    padding: 0.35rem 0.75rem;
  }

  .reel-section {
    padding-block: clamp(1rem, 3vw, 2.5rem) clamp(3rem, 6vw, 5rem);
  }
  .reel {
    margin: 0;
    max-width: 980px;
  }
  .reel-frame {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      0 12px 32px -16px rgba(0, 0, 0, 0.18);
  }
  .reel-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .reel-dot {
    width: 0.6875rem;
    height: 0.6875rem;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .reel-dot-red    { background: #ec6a5e; }
  .reel-dot-yellow { background: #f4bf4f; }
  .reel-dot-green  { background: #61c554; }
  .reel-title {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--content-3);
    letter-spacing: 0.02em;
  }
  .reel-img {
    display: block;
    width: 100%;
    height: auto;
    background: #272822;
  }
  .reel-caption {
    margin: 1rem 0 0;
    color: var(--content-2);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: 640px;
  }
  .reel-caption code {
    background: var(--surface-2);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
  }

  .components-section {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--border);
  }
  .components-head {
    max-width: 760px;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .components-head .eyebrow { display: inline-block; margin-bottom: 1rem; }
  .components-head h2 { margin: 0 0 1.25rem; }
  .components-head em { color: var(--accent); }
  .components-intro { max-width: 640px; margin: 0; }
  .components-intro code {
    background: var(--surface-2);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
  }

  .components-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.5rem;
  }

  .component-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 150ms var(--ease-out), transform 150ms var(--ease-out);
  }
  .component-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .component-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .component-preview {
    margin: 0;
    background: #272822;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    aspect-ratio: 689 / 490;
  }
  .component-preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
  }
  .component-title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
  }
  .component-slug {
    color: var(--content-3);
    font-size: 0.8125rem;
  }
  .component-blurb {
    margin: 0;
    color: var(--content-2);
    line-height: 1.55;
    font-size: 0.9375rem;
  }
  .component-snippet {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1rem 1.125rem;
    overflow-x: auto;
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--content);
  }
  .component-actions {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .component-source {
    color: var(--content-2);
    font-size: 0.8125rem;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 150ms var(--ease-out), border-color 150ms var(--ease-out);
  }
  .component-source:hover {
    color: var(--accent);
