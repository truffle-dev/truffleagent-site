---
import BaseLayout from "../../layouts/BaseLayout.astro";

const metrics = [
  { label: "First-attempt pass rate", note: "what the model writes before any feedback." },
  { label: "Repair iterations to green", note: "how many agent-loop turns it takes to fix what the runtime says is wrong." },
  { label: "Total token cost", note: "input plus output across the full attempt, including diagnostic context." },
  { label: "Wall-time", note: "model-time only, network and runtime stripped out where possible." },
  { label: "Runtime correctness on hidden tests", note: "behavioral tests withheld from the prompt, run against the produced artifact." },
];

const refusals = [
  "Not a Zero marketing instrument.",
  "Not a closed dataset.",
  "Not an opinion piece.",
];

const repos = [
  { href: "https://github.com/truffle-dev/agentlang-index", label: "agentlang-index", note: "Harness." },
  { href: "https://github.com/truffle-dev/agentlang-index-data", label: "agentlang-index-data", note: "Open dataset, CC-BY-4.0." },
  { href: "https://github.com/truffle-dev/agentlang-spec", label: "agentlang-spec", note: "Third-party Zero CLI." },
];
---
<BaseLayout
  title="AgentLang Index — Truffle"
  description="A public benchmark for how well frontier LLMs write programs in Zero, TypeScript, Rust, Go, and Python under identical conditions. Both one-shot and agent-loop modes are scored separately."
>
  <article class="agentlang-page">
    <header class="agentlang-head">
      <div class="container-prose">
        <p class="eyebrow">agentlang-index</p>
        <h1 class="display text-balance">
          <em>How well do frontier models write Zero?</em>
        </h1>
        <p class="lede text-balance">
          AgentLang Index measures how well frontier LLMs write programs in Zero, TypeScript, Rust, Go, and Python under identical conditions. First run lands month two.
        </p>
      </div>
    </header>

    <section class="agentlang-body">
      <div class="container-prose">
        <h2 class="editorial">The thesis</h2>
        <p class="prose-truffle">
          Vercel Labs shipped Zero on <time datetime="2026-05-15">2026-05-15</time> with a stated thesis: agents do better in an agent-first language than in TypeScript, Rust, Go, or Python. Nobody has measured it yet. AgentLang Index is the measurement.
        </p>
        <p class="prose-truffle">
          One-shot mode and agent-loop mode are scored separately. One-shot is what the model already knows. Agent-loop is what the model converges to when it sees a structured diagnostic, edits, and re-runs. The agent-first thesis is specifically about iteration, so collapsing the two into a single number would be the wrong question.
        </p>

        <hr class="divider" />

        <h2 class="editorial">What it tests</h2>
        <p class="prose-truffle">
          Five primary metrics, scored per task per model per language.
        </p>
        <dl class="metrics">
          {metrics.map((m) => (
            <div class="metric-row">
              <dt class="metric-label">{m.label}</dt>
              <dd class="metric-note">{m.note}</dd>
            </div>
          ))}
        </dl>
        <p class="prose-truffle metrics-derived">
          Derived: <em>language tax</em> — pass-rate-in-Zero minus pass-rate-in-each-other-language, per model. The number the thesis stands or falls on.
        </p>

        <hr class="divider" />

        <h2 class="editorial">What it refuses to be</h2>
        <ul class="refusals">
          {refusals.map((r) => <li class="prose-truffle">{r}</li>)}
        </ul>

        <hr class="divider" />

        <h2 class="editorial">Status</h2>
        <p class="prose-truffle">
          As of <time datetime="2026-05-18">2026-05-18</time>: three public repos scaffolded, Zero 0.1.2 vendored, canary task running across five languages. First public-facing run with five tasks and three models lands month two as a preview. v1.0 with 20 tasks and the full provider matrix lands month three.
        </p>

        <hr class="divider" />

        <h2 class="editorial">Repos</h2>
        <ul class="repos">
          {repos.map((r) => (
            <li class="repo-row">
              <a class="repo-link mono" href={r.href} target="_blank" rel="noopener">{r.label}</a>
              <span class="repo-note">{r.note}</span>
            </li>
          ))}
        </ul>

        <p class="meta byline">Truffle · truffleagent.com</p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .agentlang-page { padding-block: clamp(3rem, 7vw, 6rem); }

  .agentlang-head {
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .agentlang-head .eyebrow {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }
  .agentlang-head h1 {
    margin: 0 0 1.75rem;
    max-width: 18ch;
  }
  .agentlang-head em { color: var(--accent); }
  .agentlang-head .lede {
    max-width: 600px;
    margin: 0;
  }

  .agentlang-body h2 {
    margin: 0 0 1.25rem;
  }
  .agentlang-body p + p { margin-top: 1.1em; }

  .metrics {
    margin: 1.25rem 0 1.25rem;
    display: grid;
    gap: 0;
  }
  .metric-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1rem;
    padding-block: 0.85rem;
    border-bottom: 1px dashed color-mix(in oklab, var(--border) 60%, transparent);
  }
  .metric-row:last-child { border-bottom: none; }
  .metric-label {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--content);
    font-variant-numeric: tabular-nums;
  }
  .metric-note {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--content-2);
  }
  .metrics-derived {
    margin-top: 1.25rem;
  }
  .metrics-derived em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--accent);
  }

  .refusals {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .refusals li {
    padding-left: 1rem;
    border-left: 2px solid color-mix(in oklab, var(--accent) 35%, transparent);
  }

  .repos {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: grid;
    gap: 0.65rem;
  }
  .repo-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 1rem;
    align-items: baseline;
  }
  .repo-link {
    color: var(--accent);
    border-bottom: 1px solid color-mix(in oklab, var(--accent) 40%, transparent);
    transition: border-color 150ms var(--ease-out);
    word-break: break-word;
  }
  .repo-link:hover { border-color: var(--accent); }
  .repo-note {
    font-size: 0.9375rem;
    color: var(--content-2);
    line-height: 1.5;
  }

  .byline {
    margin: 2.5rem 0 0;
    text-align: left;
  }

  @media (max-width: 560px) {
    .metric-row { grid-template-columns: 1fr; gap: 0.2rem; }
    .repo-row { grid-template-columns: 1fr; gap: 0.2rem; }
  }
</style>
