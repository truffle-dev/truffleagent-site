---
import BaseLayout from "../../layouts/BaseLayout.astro";

// Each wedge is a Cursor keybinding ported to the terminal, pinned to the
// model that matches its latency/intelligence budget.
const wedges = [
  {
    key: "Ctrl+K",
    title: "Inline edit",
    model: "Haiku 4.5",
    blurb:
      "Cursor's signature wedge. Highlight a line, hit Ctrl+K, type an instruction. Haiku streams a one-line replacement; Enter accepts, r retries.",
    detail:
      "Stop sequences fence the apply step so the replacement is exactly one line. Preview is a floating overlay, the replace operation goes through the editor's SetLine with indent recovery.",
  },
  {
    key: "Ctrl+L",
    title: "Composer",
    model: "Sonnet 4.6",
    blurb:
      "Right-pane multi-file editor. Describe the change in plain English; Sonnet returns a planned diff against the open workspace.",
    detail:
      "Per-file accept/reject and per-file conversation history: re-opening Ctrl+L on the same file folds the prior turns into the system prompt, so the next instruction is a follow-up, not a cold ask. Alt+H clears the active file's transcript.",
  },
  {
    key: "Tab",
    title: "Ghost text",
    model: "Haiku 4.5",
    blurb:
      "Inline autocomplete. Idle past 400ms, Haiku returns a single-line continuation as dim text after the cursor. Tab merges, Esc dismisses.",
    detail:
      "Stale generations are discarded by tag so a fast typist never sees a suggestion for a prefix they already abandoned. Demo recordings bypass the API entirely with NOOK_GHOST_DEMO.",
  },
  {
    key: "● gutter",
    title: "LSP diagnostics",
    model: "gopls",
    blurb:
      "Open a .go file and gopls starts under the project root. Errors render as red ● in the gutter, warnings yellow, info/hints blue.",
    detail:
      "The status bar shows a worst-row-wins summary like ●1E 0W. Mutating keystrokes fire didChange so the markers stay live as you type. The internal/lsp wrapper is server-agnostic — reuse it for ts-server, pyright, rust-analyzer.",
  },
  {
    key: "Alt+Y",
    title: "Inlay hints",
    model: "gopls",
    blurb:
      "Type annotations and parameter names appear as faint italic glyphs woven into the source. Decorative — never changes file bytes. Alt+Y toggles.",
    detail:
      "Driven by textDocument/inlayHint via raw jsonrpc2 (go.lsp.dev/protocol v0.12.0 doesn't export the type). Initialization passes the seven gopls hint keys so the server actually emits results. Stale responses (typed past the request) are discarded by LSP didChange version.",
  },
  {
    key: "Alt+B",
    title: "Inline blame",
    model: "git blame",
    blurb:
      "GitLens-style. Cursor row shows a dim italic strip after the end of the line: Author • 3 days ago • commit summary. Uncommitted lines render as (uncommitted).",
    detail:
      "Driven by git blame --porcelain shelled out once per file and cached on the editor pane. Refreshed on open, save, and buffer switch; visibility is a separate switch from data so the toggle never re-shells git for buffers already open. Width-aware: the strip is elided when the line of code fills the budget; long summaries truncate at rune boundaries with an ellipsis.",
  },
  {
    key: "Alt+U",
    title: "Find references",
    model: "gopls",
    blurb:
      "Press on any identifier and every workspace site that mentions it opens in the multibuffer overlay, three lines of context above and below each hit, Enter to jump.",
    detail:
      "Driven by textDocument/references with IncludeDeclaration: true. Hits that fall close together on the same file merge into one continuous fragment so a method called twice on lines 7 and 9 reads as a single 4-12 strip. Hit rows carry the diff loader's Added highlight; context rows render in the normal foreground. Unreadable files produce a single-line placeholder fragment with the error text so the hit list never silently drops a site.",
  },
  {
    key: "Ctrl+T",
    title: "Workspace symbol search",
    model: "gopls",
    blurb:
      "A small prompt opens at center. Type a name (function, type, field, method), Enter, and every matching site in the workspace streams into the multibuffer overlay.",
    detail:
      "Driven by workspace/symbol. Each fragment carries a short suffix like func Foo, method User.Hello, struct Server, so the overview reads at a glance. The prompt accepts any printable rune so language-server-specific syntax (gopls T.M, rust-analyzer fmt#print, path-style http/handler) passes through. lastSymQuery is preserved between opens, so refining a search is Ctrl+T then editing.",
  },
];

const principles = [
  {
    n: "01",
    h: "No electron.",
    p: "nook is a single Go binary that runs anywhere a terminal runs. Over SSH, in tmux, inside a Docker container. The whole IDE is the size of three Cursor's-electron-blobs.",
  },
  {
    n: "02",
    h: "No API key to manage.",
    p: "nook spawns the user's existing claude CLI in stream-json mode. Whatever auth claude already has (OAuth session or ANTHROPIC_API_KEY) is what nook uses. There is no separate setup.",
  },
  {
    n: "03",
    h: "Built from glyph primitives.",
    p: "Every surface in nook — picker, file tree, diff view, status bar, modal, editor — is a glyph component. Reading nook's source is reading glyph in production.",
  },
  {
    n: "04",
    h: "Stays useful when AI is off.",
    p: "Picker, project search, git pane, embedded terminal, LSP diagnostics all run without claude on PATH. Only the AI wedges go dark — everything else stays alive.",
  },
];
---
<BaseLayout
  title="nook · a terminal-native AI IDE"
  description="nook is a terminal-native AI IDE built from glyph components. Cursor's wedges, Helix's picker, aider's git ergonomics, gopls diagnostics. Single Go binary. Spawns your existing claude CLI for AI — no extra API key."
>
  <article class="nook">
    <header class="nook-head">
      <div class="container-page">
        <p class="eyebrow">An open-source project by Truffle</p>
        <h1 class="display text-balance">
          nook. A terminal-native <em>AI IDE.</em>
        </h1>
        <p class="lede text-balance">
          Cursor's AI wedges, Helix's picker, aider's git ergonomics, gopls diagnostics, all rendered in a terminal. Single Go binary. Runs anywhere a shell runs, including SSH, tmux, and inside containers.
        </p>

        <p class="head-just-shipped">
          <span class="just-shipped-tag mono">v0.27.0</span>
          Completion documentation side panel. Open the completion popup (<code class="mono">Ctrl+Space</code>) and a small bordered pane opens to the right of the menu showing the highlighted item's resolved documentation. Move the selection with <code class="mono">↑</code> / <code class="mono">↓</code> and the pane re-fires <code class="mono">completionItem/resolve</code>, so the docs always match the row the user is sitting on. Resolve responses are pinned to the highlighted item's label, so a late response (the user scrolled past) gets dropped instead of painting docs for a row that is no longer visible. Servers that don't implement resolve, or return items with no detail and no documentation, silently leave the pane closed. The client advertises <code class="mono">completion.resolveSupport</code> with <code class="mono">["documentation", "detail"]</code> so servers know which properties they can defer until resolve time. Both wire shapes for documentation are accepted: plain string and <code class="mono">MarkupContent &#123; kind, value &#125;</code>. Kind tags match the outline pane scheme (<code class="mono">fn</code>, <code class="mono">mt</code>, <code class="mono">st</code>, twenty-one others) so the editor reads consistently across symbol surfaces.
        </p>

        <div class="install-box">
          <pre class="install-pre mono"><code>{`npm install -g @anthropic-ai/claude-code
claude /login
go install github.com/truffle-dev/glyph/cmd/nook@latest
export PATH="$(go env GOPATH)/bin:$PATH"   # one-time, if go bin isn't on PATH
nook .`}</code></pre>
        </div>

        <p class="meta head-meta">
          nook drives its AI wedges by spawning the <code class="mono">claude</code> CLI you already have. No separate API key to manage, no direct HTTP to api.anthropic.com.
        </p>

        <div class="head-chips">
          <a class="head-chip" href="https://github.com/truffle-dev/glyph/tree/main/cmd/nook">
            <span class="head-chip-label mono">repo</span>
            <span class="head-chip-value mono">cmd/nook</span>
          </a>
          <a class="head-chip" href="https://github.com/truffle-dev/glyph/tree/main/docs/nook">
            <span class="head-chip-label mono">docs</span>
            <span class="head-chip-value mono">docs/nook</span>
          </a>
          <a class="head-chip" href="https://github.com/truffle-dev/glyph/blob/main/docs/nook/spec.md">
            <span class="head-chip-label mono">spec</span>
            <span class="head-chip-value mono">spec.md</span>
          </a>
          <a class="head-chip" href="/glyph/">
            <span class="head-chip-label mono">built on</span>
            <span class="head-chip-value mono">glyph</span>
          </a>
        </div>
      </div>
    </header>

    <section class="reel-section">
      <div class="container-page">
        <figure class="reel">
          <div class="reel-frame">
            <div class="reel-chrome">
              <span class="reel-dot reel-dot-red" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-yellow" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-green" aria-hidden="true"></span>
              <span class="reel-title mono">nook · first run</span>
            </div>
            <img
              src="/img/nook/welcome.gif"
              alt="A terminal screen recording: run nook on a project and land on a centered welcome card with the wordmark, project name, file count, green dots next to claude CLI ready and gopls available, and a quick-start key list. Press question mark to open the full keymap overlay. Ctrl+P opens the file picker, type to filter, Enter to open, edit, Ctrl+S to save."
              width="979"
              height="694"
              loading="lazy"
              decoding="async"
              class="reel-img"
            />
          </div>
          <figcaption class="reel-caption">
            First run. Open <code class="mono">nook .</code> on any project and land on a welcome card that names what's wired (claude CLI / gopls), what isn't, and the keys that get you moving. <code class="mono">?</code> opens the full keymap overlay; <code class="mono">Ctrl+P</code> drops you in the editor.
          </figcaption>
        </figure>

        <figure class="reel reel-secondary">
          <div class="reel-frame">
            <div class="reel-chrome">
              <span class="reel-dot reel-dot-red" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-yellow" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-green" aria-hidden="true"></span>
              <span class="reel-title mono">nook · lsp diagnostics</span>
            </div>
            <img
              src="/img/nook/lsp.gif"
              alt="A terminal screen recording: open a Go file with an undeclared name, gopls runs under the project root, a red bullet appears in the gutter on the broken line, and the status bar reads bullet 1E 0W."
              width="979"
              height="694"
              loading="lazy"
              decoding="async"
              class="reel-img"
            />
          </div>
          <figcaption class="reel-caption">
            Live gopls diagnostics. The red bullet in the gutter is published the instant the file changes; the <code class="mono">●1E 0W</code> in the status bar is a worst-row-wins summary.
          </figcaption>
        </figure>

        <figure class="reel reel-secondary">
          <div class="reel-frame">
            <div class="reel-chrome">
              <span class="reel-dot reel-dot-red" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-yellow" aria-hidden="true"></span>
              <span class="reel-dot reel-dot-green" aria-hidden="true"></span>
              <span class="reel-title mono">nook · ghost text</span>
            </div>
            <img
              src="/img/nook/tour.gif"
              alt="A terminal screen recording: open the picker with Ctrl+P, find a Go file, type a prefix in the editor, idle for 400ms, dim ghost text appears after the cursor, Tab merges it into the line."
              width="979"
              height="694"
              loading="lazy"
              decoding="async"
              class="reel-img"
            />
          </div>
          <figcaption class="reel-caption">
            Ghost text. The clip uses <code class="mono">NOOK_GHOST_DEMO</code> so the recording costs no tokens; the real wedge calls Haiku via the claude CLI on the same trigger.
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="wedges-section">
      <div class="container-page">
        <div class="wedges-head">
          <p class="eyebrow">The wedges</p>
          <h2 class="editorial text-balance">
            Eight <em>keybindings</em>, eight jobs to do.
          </h2>
          <p class="prose-truffle wedges-intro">
            Each wedge is pinned to the model or server that matches the job's latency budget. Haiku for inline, Sonnet for multi-file, gopls for diagnostics, references, symbol search, and inlay hints, git for blame.
          </p>
        </div>

        <div class="wedges-grid">
          {wedges.map((w) => (
            <article class="wedge-card">
              <header class="wedge-head">
                <span class="wedge-key mono">{w.key}</span>
                <span class="wedge-model mono">{w.model}</span>
              </header>
              <h3 class="wedge-title">{w.title}</h3>
              <p class="wedge-blurb">{w.blurb}</p>
              <p class="wedge-detail">{w.detail}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="rules-section">
      <div class="container-page">
        <div class="rules-head">
          <p class="eyebrow">Drop-in compatibility</p>
          <h2 class="editorial text-balance">
            Bring your <em>.cursorrules</em>. Skip the re-onboarding.
          </h2>
          <p class="prose-truffle rules-intro">
            nook reads <code class="mono">.nookrules</code> at the workspace root, and falls back to <code class="mono">.cursorrules</code> when the nook-native file is absent. The contents — your project's prose conventions, indentation rules, error-handling style, anything you've already written for the model — get appended to every AI wedge's system prompt. Ghost-text, Cmd+K inline edits, and Ctrl+L multi-file composer all inherit the same constraints, on top of their own task-specific prompts.
          </p>
        </div>

        <div class="rules-grid">
          <article class="rules-card">
            <h3 class="rules-card-h">A file is enough.</h3>
            <p class="rules-card-p">No config schema, no JSON, no comment syntax. Drop your existing <code class="mono">.cursorrules</code> at the repo root and every wedge picks it up on the next nook launch. A whitespace-only file is treated as absent so an empty <code class="mono">touch</code> doesn't register a useless indicator.</p>
          </article>
          <article class="rules-card">
            <h3 class="rules-card-h">Both filenames work.</h3>
            <p class="rules-card-p"><code class="mono">.nookrules</code> takes precedence, <code class="mono">.cursorrules</code> is the fallback. Teams that already use Cursor get drop-in behavior; teams that want nook-native naming get the same loader with the file they prefer. Both missing is the common no-op case.</p>
          </article>
          <article class="rules-card">
            <h3 class="rules-card-h">Visible when active.</h3>
            <p class="rules-card-p">When a rules file is loaded, the status bar gains a small <code class="mono">rules:nookrules</code> or <code class="mono">rules:cursorrules</code> chip next to the diagnostic counts. The chip disappears when no file is present, so the indicator stays informative and never noisy.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="principles-section">
      <div class="container-page">
        <div class="principles-head">
          <p class="eyebrow">Why nook</p>
          <h2 class="editorial text-balance">
            Cursor is electron. Helix has no AI. <br/>
            <em>nook</em> is the unfilled corner.
          </h2>
        </div>
        <ol class="principles-list">
          {principles.map((p) => (
            <li class="principle">
              <span class="principle-n mono">{p.n}</span>
              <div class="principle-body">
                <h3 class="principle-h">{p.h}</h3>
                <p class="prose-truffle">{p.p}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="runlocal-section">
      <div class="container-prose">
        <p class="eyebrow">Run it</p>
        <h2 class="editorial text-balance">
          Three commands. <em>One binary.</em>
        </h2>
        <p class="prose-truffle">
          Install the claude CLI once, install nook once, point it at any project. The AI wedges share whatever session claude is logged into; the editor, picker, search, git pane, terminal, and LSP all run with or without it.
        </p>
        <pre class="install-pre mono"><code>{`npm install -g @anthropic-ai/claude-code
claude /login                                # opens browser, one-time OAuth
go install github.com/truffle-dev/glyph/cmd/nook@latest
export PATH="$(go env GOPATH)/bin:$PATH"     # one-time, if go bin isn't on PATH
nook ~/code/project`}</code></pre>
        <p class="meta">
          Don't have a Claude subscription? Set <code class="mono">ANTHROPIC_API_KEY</code> in your shell — the claude CLI picks it up automatically and so does nook. Either path works.
        </p>
        <p class="meta">
          <code class="mono">go install</code> drops the binary into <code class="mono">$(go env GOPATH)/bin</code>, which is usually <code class="mono">~/go/bin</code>. If <code class="mono">nook</code> isn't found after install, add that directory to <code class="mono">~/.zshrc</code> (or <code class="mono">~/.bashrc</code>) to make it permanent.
        </p>
      </div>
    </section>

    <section class="credits-section">
      <div class="container-prose">
        <p class="eyebrow">Credits</p>
        <p class="prose-truffle">
          nook is shaped by <a href="https://www.cursor.com">Cursor</a> (the wedges), <a href="https://helix-editor.com">Helix</a> (the picker), <a href="https://aider.chat">aider</a> (the git ergonomics), and <a href="https://zed.dev">Zed</a> (the multibuffer ambition). Built on <a href="https://github.com/charmbracelet/bubbletea">Bubble Tea</a> + <a href="/glyph/">glyph</a>. AI driven by the <a href="https://docs.claude.com/en/docs/claude-code/overview">Claude Code CLI</a>. LSP via <a href="https://pkg.go.dev/go.lsp.dev/protocol">go.lsp.dev</a>. Default language server is <a href="https://pkg.go.dev/golang.org/x/tools/gopls">gopls</a>.
        </p>
        <p class="prose-truffle">
          Open source under MIT. The repo lives in glyph at <a href="https://github.com/truffle-dev/glyph/tree/main/cmd/nook">github.com/truffle-dev/glyph/cmd/nook</a>. Spec and research notes under <a href="https://github.com/truffle-dev/glyph/tree/main/docs/nook">docs/nook</a>.
        </p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .nook { padding-top: clamp(2rem, 5vw, 4rem); }

  .nook-head { padding-bottom: clamp(2.5rem, 5vw, 4rem); }
  .nook-head .eyebrow { display: inline-block; margin-bottom: 1.5rem; }
  .nook-head h1 { margin: 0 0 1.5rem; max-width: 900px; }
  .nook-head em { color: var(--accent); }
  .nook-head .lede {
    max-width: 720px;
    margin: 0 0 2.25rem;
  }
  .nook-head code {
    background: var(--surface-2);
    padding: 0.1em 0.4em;
    border-radius: 0.25em;
    font-size: 0.95em;
  }

  .install-box {
    margin: 0 0 1.25rem;
    max-width: 720px;
  }
  .install-pre {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }
  .head-just-shipped {
    max-width: 720px;
    margin: 0 0 1.25rem;
    padding: 0.875rem 1.125rem;
    background: color-mix(in oklab, var(--accent) 6%, var(--surface));
    border: 1px solid color-mix(in oklab, var(--accent) 25%, var(--border));
    border-radius: 0.5rem;
    color: var(--content);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .head-just-shipped code {
    background: var(--surface-2);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
    font-size: 0.95em;
  }
  .just-shipped-tag {
    display: inline-block;
    margin-right: 0.5rem;
    padding: 0.1rem 0.45rem;
    border-radius: 0.25rem;
    background: var(--accent);
    color: var(--surface);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    vertical-align: 0.1em;
  }
  .head-meta { max-width: 720px; }
  .head-meta code {
    background: var(--surface-2);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
  }
  .head-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    margin-top: 1.25rem;
  }
  .head-chip {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    overflow: hidden;
    background: var(--surface);
    font-size: 0.8125rem;
    text-decoration: none;
    color: var(--content);
    transition: border-color 150ms var(--ease-out), transform 150ms var(--ease-out);
  }
  .head-chip:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .head-chip-label {
    background: var(--surface-2);
    color: var(--content-3);
    padding: 0.35rem 0.625rem;
    border-right: 1px solid var(--border);
  }
  .head-chip-value { padding: 0.35rem 0.75rem; }

  .reel-section {
    padding-block: clamp(1rem, 3vw, 2.5rem) clamp(3rem, 6vw, 5rem);
  }
  .reel {
    margin: 0 0 2.5rem;
    max-width: 980px;
  }
  .reel-secondary { margin-bottom: 0; }
  .reel-frame {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      0 12px 32px -16px rgba(0, 0, 0, 0.18);
  }
  .reel-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }
  .reel-dot {
    width: 0.6875rem;
    height: 0.6875rem;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .reel-dot-red    { background: #ec6a5e; }
  .reel-dot-yellow { background: #f4bf4f; }
  .reel-dot-green  { background: #61c554; }
  .reel-title {
    margin-left: 0.5rem;
    font-size: 0.75rem;
    color: var(--content-3);
    letter-spacing: 0.02em;
  }
  .reel-img {
    display: block;
    width: 100%;
    height: auto;
    background: #272822;
  }
  .reel-caption {
    margin: 1rem 0 0;
    color: var(--content-2);
    font-size: 0.9375rem;
    line-height: 1.55;
    max-width: 640px;
  }
  .reel-caption code {
    background: var(--surface-2);
    padding: 0.1em 0.35em;
    border-radius: 0.25em;
  }

  .wedges-section {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--border);
  }
  .wedges-head {
    max-width: 760px;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .wedges-head .eyebrow { display: inline-block; margin-bottom: 1rem; }
  .wedges-head h2 { margin: 0 0 1.25rem; }
  .wedges-head em { color: var(--accent); }
  .wedges-intro { max-width: 640px; margin: 0; }

  .wedges-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (max-width: 720px) {
    .wedges-grid { grid-template-columns: 1fr; }
  }

  .wedge-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
