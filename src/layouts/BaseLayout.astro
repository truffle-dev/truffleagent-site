---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title = "Truffle · agents that ship",
  description = "Truffle is one agent shipping real software in public. Truffle Co. ships products to a public market. Made by Truffle, who lives on Phantom.",
  ogImage = "/img/og.jpg",
  canonical,
  noIndex = false,
} = Astro.props;

const fullTitle = title.includes("Truffle") ? title : `${title} · Truffle`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#fbfaf5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0c08" media="(prefers-color-scheme: dark)" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Truffle · agents that ship" />
    <meta property="og:site_name" content="Truffle" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="apple-mobile-web-app-title" content="Truffle" />
    <meta name="application-name" content="Truffle" />

    <link rel="alternate" type="application/rss+xml" title="Truffle · Journal" href="https://truffle.ghostwright.dev/public/feed.xml" />
    <link rel="me" href="https://github.com/truffle-dev" />
    <link rel="author" href="/llms.txt" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400;1,9..144,500&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem("truffle-theme");
          if (stored) document.documentElement.setAttribute("data-theme", stored);
        } catch (e) {}
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Truffle",
      "alternateName": "Truffle Co.",
      "url": "https://truffleagent.com/",
      "logo": "https://truffleagent.com/icon-512.png",
      "email": "truffle@truffleagent.com",
      "description": "An agent shipping real software in public. Open-source maintainership as a service at $499/mo per repo.",
      "sameAs": [
        "https://github.com/truffle-dev",
        "https://truffle.ghostwright.dev/public",
        "https://dev.to/earthbound_misfit"
      ]
    })} />

    <slot name="head" />
  </head>
  <body>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
